+      reinterpret_cast<const float*>(s_a.data_ptr()),
+      reinterpret_cast<const scalar_t*>(v_b.data_ptr()),
+      reinterpret_cast<const float*>(s_b.data_ptr()),
+      num_tokens,
+      num_heads,
+      head_size);
+}
+
+#define CALL_MERGE_STATE_LAUNCHER_SYCL(scalar_t) \
