+                                    block_offset,
+                                    b,
+                                    h,
+                                    row,
+                                    range_start,
+                                    range_end,
+                                    block_size_N,
+                                    kv_len,
+                                    tmp_blk_cnt,
+                                )
+                                while v_ptr < NNZ_V:
+                                    v_idx = v_list[v_ptr]
+                                    v_ptr += 1
+                                    if causal and v_idx >= causal_col_limit:
+                                        break
+                                    if v_idx >= range_end:
+                                        column_index[b, h, row, tmp_col_cnt] = v_idx
+                                        tmp_col_cnt += 1
+                                break
+                else:
