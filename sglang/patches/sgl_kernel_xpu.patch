 foreach(QG_SZ ${FMHA_DECODE_QG_SIZES})
     foreach(HEAD_DIM ${FMHA_DECODE_HEAD_DIMS})
+        if(HEAD_DIM IN_LIST FMHA_DECODE_PAGED_HEAD_DIMS)
+            set(EMIT_PAGED 1)
+        else()
+            set(EMIT_PAGED 0)
+        endif()
+
+        if(HEAD_DIM IN_LIST FMHA_DECODE_NP_HEAD_DIMS)
