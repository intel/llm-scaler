+        else()
+            set(EMIT_NP 0)
+            set(TILED_KV_NP 16)
+        endif()
+
         foreach(PAGE_SIZE ${FMHA_DECODE_PAGE_SIZES})
             set(GENERATED_FILE
                 "${CMAKE_CURRENT_BINARY_DIR}/sycl/xe_fmha_fwd_decode_kernel_${QG_SZ}_${HEAD_DIM}_${PAGE_SIZE}.cpp")
