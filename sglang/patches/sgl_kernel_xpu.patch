-        for (int z = 0; z < FragsN; z++) {
-          out_reg(x, y, z) *= cur_scale;
-        }
-      }
-    }
-
-    // Indexing variables
-    auto [batch, num_heads_q, num_heads_kv, head_size_vo] = select<0, 1, 2, 7>(problem_shape);
-    auto [seq_len_qo] = select<0>(sequence_length_shape);
