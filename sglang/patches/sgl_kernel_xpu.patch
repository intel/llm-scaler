+      has_initial_state.has_value()                                \
+          ? reinterpret_cast<bool*>(has_initial_state->data_ptr()) \
+          : nullptr,                                               \
+      act_mode,                                                    \
+      pad_slot_id,                                                 \
+      batch_size,                                                  \
+      num_actual_tokens,                                           \
+      num_virtual_tokens,                                          \
+      num_k_heads,                                                 \
+      head_k_dim,                                                  \
