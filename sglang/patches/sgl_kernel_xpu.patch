+// Reciprocal with zero check. If x is zero, return zero; else return 1/x.
+template <typename T>
+inline T safe_recip(T x) {
+  const auto nz = (x != T(0));
+  const T safe_d = sycl::select(T(1), x, nz);
+  const T inv = sycl::native::recip(safe_d);
+  return sycl::select(T(0), inv, nz);
+}
