-    auto [m_coord, n_coord, k_coord, l_coord] = tile_coord;
-    // Tile the output tensor per WG
-    Tensor g_wg_O =
-        local_tile(mO_mnl, select<0, 1>(TileShapeOutput{}), make_coord(m_coord, n_coord, 0));  // (BLK_M,BLK_N,m,n,l)
