+        hc_base_c,
+        residual_flat,
+        post_mix,
+        comb_mix,
+        layer_input,
+        hc_mult,
+        sinkhorn_iters,
+        n_splits,
+        float(rms_eps),
+        float(hc_pre_eps),
+        float(hc_sinkhorn_eps),
+        float(hc_post_mult_value),
+        norm_weight_arg,
+        norm_eps_arg,
+    )
