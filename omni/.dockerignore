# Keep the docker build context free of local build artifacts so the image's
# own `pip install` compiles everything cleanly against the image toolchain/ABI.
# (A .so built inside a dev container can have a mismatched torch/oneAPI ABI.)
**/__pycache__/
**/*.pyc
**/*.pyo

# Compiled extensions / build trees (rebuilt inside the image)
**/*.so
**/*.egg-info/
**/build/
**/dist/
omni_xpu_kernel/build/

# Local-only
local_build.sh
.git/

# Files outside the focused ComfyUI image build. Keep these sources in the
# repository without sending them in the focused Docker build context.
README.md
Releases.md
docs/
assets/
benchmarks/
example_inputs/
standalone_examples/
tests/
workflows/
docker/Dockerfile.full
docker/Dockerfile-extension
docker/sgl_kernel_xpu_device_target.patch

# Common local runtime state.
**/.env
**/.vscode/
**/logs/
**/models/
**/node_modules/
**/outputs/
**/tmp/
