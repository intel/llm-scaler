diff --git a/reactor_utils.py b/reactor_utils.py
index cdd3eb8..4082b70 100644
--- a/reactor_utils.py
+++ b/reactor_utils.py
@@ -212,10 +212,98 @@ def get_ort_session():
     global ORT_SESSION
     return ORT_SESSION
 
-def set_ort_session(model_path, providers) -> Any:
+def _torch_cuda_available() -> bool:
+    try:
+        return torch.cuda.is_available()
+    except Exception:
+        return False
+
+
+def _torch_xpu_available() -> bool:
+    try:
+        return hasattr(torch, "xpu") and torch.xpu.is_available()
+    except Exception:
+        return False
+
+
+def _torch_mps_available() -> bool:
+    try:
+        return hasattr(torch.backends, "mps") and torch.backends.mps.is_available()
+    except Exception:
+        return False
+
+
+def _torch_rocm_like_available() -> bool:
+    return hasattr(torch, "dml") or hasattr(torch, "privateuseone")
+
+
+def resolve_onnx_providers(providers=None):
+    try:
+        available_providers = onnxruntime.get_available_providers()
+    except Exception:
+        available_providers = ["CPUExecutionProvider"]
+
+    if providers:
+        resolved = [provider for provider in providers if provider in available_providers]
+        if "CPUExecutionProvider" in available_providers and "CPUExecutionProvider" not in resolved:
+            resolved.append("CPUExecutionProvider")
+        if resolved:
+            return resolved
+
+    preferred = []
+    if _torch_cuda_available():
+        preferred.append("CUDAExecutionProvider")
+    if _torch_xpu_available():
+        preferred.append("OpenVINOExecutionProvider")
+    if _torch_mps_available():
+        preferred.append("CoreMLExecutionProvider")
+    if _torch_rocm_like_available():
+        preferred.append("ROCMExecutionProvider")
+    preferred.append("CPUExecutionProvider")
+
+    resolved = [provider for provider in preferred if provider in available_providers]
+    if not resolved:
+        return ["CPUExecutionProvider"]
+    return resolved
+
+
+def _safe_empty_cache(device_type: str) -> None:
+    if device_type == "cuda" and _torch_cuda_available():
+        torch.cuda.empty_cache()
+    elif device_type == "xpu" and _torch_xpu_available() and hasattr(torch.xpu, "empty_cache"):
+        torch.xpu.empty_cache()
+    elif device_type == "mps" and hasattr(torch, "mps") and hasattr(torch.mps, "empty_cache"):
+        torch.mps.empty_cache()
+
+
+def clear_torch_cache(device=None) -> None:
+    try:
+        if device is not None:
+            if isinstance(device, torch.device):
+                device_type = device.type
+            else:
+                device_type = torch.device(device).type
+            _safe_empty_cache(device_type)
+            return
+    except Exception:
+        pass
+
+    # Fallback: clear caches on all known backends, if available.
+    for device_type in ("cuda", "xpu", "mps"):
+        try:
+            _safe_empty_cache(device_type)
+        except Exception:
+            continue
+
+
+def set_ort_session(model_path, providers=None) -> Any:
     global ORT_SESSION
     onnxruntime.set_default_logger_severity(3)
-    ORT_SESSION = onnxruntime.InferenceSession(model_path, providers=providers)
+    resolved_providers = resolve_onnx_providers(providers)
+    try:
+        ORT_SESSION = onnxruntime.InferenceSession(model_path, providers=resolved_providers)
+    except Exception:
+        ORT_SESSION = onnxruntime.InferenceSession(model_path, providers=["CPUExecutionProvider"])
     return ORT_SESSION
 
