+def _synchronize_device(target_device=None) -> None:
+    if target_device is None:
+        if torch.cuda.is_available():
+            torch.cuda.synchronize()
+            return
+        if hasattr(torch, "xpu") and torch.xpu.is_available():
+            try:
+                torch.xpu.synchronize()
+            except TypeError:
+                torch.xpu.synchronize(0)
+            return
+        return
+
+    device_module, device = _get_device_module(target_device)
+    if device_module is None or not hasattr(device_module, "synchronize"):
+        return
+    try:
+        device_module.synchronize(device=device)
+    except TypeError:
+        device_module.synchronize()
+
+
+def _empty_device_caches() -> None:
+    if torch.cuda.is_available():
+        torch.cuda.empty_cache()
+    if hasattr(torch, "xpu") and torch.xpu.is_available():
+        torch.xpu.empty_cache()
