+  static inline float act_sigmoid(float& x) {
+    return 1.0f / (1.0f + sycl::exp(-x));
+  }
+
+  static inline float
+  act_softplus(float& x, float beta = 1.0f, float threshold = 20.0f) {
+    if (beta * x < threshold) {
+      return sycl::log(1.0f + sycl::exp(beta * x)) / beta;
+    } else
+      return x;
+  }
