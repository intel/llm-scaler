+    const int k_dim = head_k_dim;
+    const int v_dim = head_v_dim * num_v_heads / num_k_heads;
+    const int z_dim = head_v_dim * num_v_heads / num_k_heads;
+    const int qkvz_dim = q_dim + k_dim + v_dim + z_dim;
