+                layer.qweight,
+                bias,
+                layer.scales,
+                layer.qzeros,
+                self.quant_config.group_size,
+                None,
+            )
+            out_shape = x.shape[:-1] + (layer.xpu_output_size,)
+            return out.reshape(out_shape)
+
         qweight = layer.qweight
         scales = layer.scales
         qzeros = layer.qzeros
