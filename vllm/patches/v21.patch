     def apply(
         self,
@@ -265,6 +283,20 @@ class AWQLinearMethod(LinearMethodBase):
         x: torch.Tensor,
         bias: torch.Tensor | None = None,
     ) -> torch.Tensor:
+        if current_platform.is_xpu():
+            reshaped_x = x.reshape(-1, x.shape[-1])
+            out = torch.ops._xpu_C.int4_gemm_w4a16(
