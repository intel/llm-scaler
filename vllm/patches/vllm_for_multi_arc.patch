diff --git a/vllm/model_executor/layers/esimd_utils.py b/vllm/model_executor/layers/esimd_utils.py
new file mode 100644
index 000000000..43dce8d29
--- /dev/null
+++ b/vllm/model_executor/layers/esimd_utils.py
@@ -0,0 +1,89 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""Shared infrastructure for the XPU ESIMD decode fast paths (Feature 1a).
+
+This module centralizes three things that the ESIMD fast paths scattered
+across layernorm / scaled_mm / the Qwen3-Next & Qwen3.5 model files all need:
+
+1. A single, import-safe handle on the external ``custom_esimd_kernels_vllm``
+   package. On non-XPU machines (or when the kernels are not installed) the
+   import fails gracefully and ``ESIMD_AVAILABLE`` is ``False`` -- callers must
+   gate on it so the modules still import everywhere.
+
+2. Per-feature ``DISABLE_<FEATURE>`` env switches, read once at import time and
+   cached. Setting any of them to ``"1"`` must restore the upstream path 1:1
+   (this is the basis of the toggle-equivalence acceptance check). Do NOT read
+   ``os.environ`` inside ``forward``.
+
+3. Quant-config gating helpers (``quant_is_fp8`` / ``quant_is_sym_int4``) keyed
+   off ``quant_config.get_name()``. This is deliberate: ESIMD gating must use
+   the quant config, NOT ``hasattr(layer, "weight_scale")`` -- the latter is
+   always False before ``process_weights_after_loading`` runs (see #90).
+"""
+
+import os
+
+# --------------------------------------------------------------------------- #
+# 1. Import-safe handle on the external ESIMD kernel package.
+# --------------------------------------------------------------------------- #
+try:
+    import custom_esimd_kernels_vllm as _esimd
+
+    ESIMD_AVAILABLE = True
+except ImportError:
+    _esimd = None
+    ESIMD_AVAILABLE = False
+
+
+# --------------------------------------------------------------------------- #
+# 2. Per-feature DISABLE_<FEATURE> switches (read once, cached).
+# --------------------------------------------------------------------------- #
+def _env_disabled(name: str) -> bool:
+    return os.environ.get(name, "0") == "1"
+
+
+# FP8 M==1 GEMV short-circuit in the XPU scaled_mm kernel.
+_DISABLE_ESIMD_GEMV = _env_disabled("DISABLE_ESIMD_GEMV")
+# Fused RMSNorm / gated-RMSNorm decode fast path in layernorm.py.
+_DISABLE_ESIMD_NORM = _env_disabled("DISABLE_ESIMD_NORM")
+
+
+def disable_esimd_gemv() -> bool:
+    return _DISABLE_ESIMD_GEMV
+
+
+def disable_esimd_norm() -> bool:
+    return _DISABLE_ESIMD_NORM
+
+
+# --------------------------------------------------------------------------- #
+# 3. Quant-config gating helpers (#90: gate off quant_config, not weight attrs).
+# --------------------------------------------------------------------------- #
+def quant_is_fp8(quant_config) -> bool:
+    return quant_config is not None and quant_config.get_name() == "fp8"
+
+
+def quant_is_sym_int4(quant_config) -> bool:
+    return quant_config is not None and quant_config.get_name() == "sym_int4"
+
+
+# --------------------------------------------------------------------------- #
+# Re-exported kernels used by this round's fast paths. Callers import from here
+# so the hard dependency on the external package lives in one place. These are
+# ``None`` when the package is unavailable; callers must gate on
+# ``ESIMD_AVAILABLE`` before using them.
+# --------------------------------------------------------------------------- #
+if ESIMD_AVAILABLE:
+    # FP8 per-tensor decode GEMV. Expects weight in [out, in] (i.e. [N, K])
+    # layout with a scalar fp32 scale -- which is how the XPU FP8 linear kernel
+    # stores layer.weight (it skips the upstream transpose precisely so this
+    # runs copy-free; see scaled_mm/xpu.py). A non-contiguous transposed view is
+    # read incorrectly by the kernel, so weight must be passed as the contiguous
+    # [out, in] tensor. (Calibrated vs fp8_gemm_w8a16 on XPU, rel_err ~1.9e-4.)
+    esimd_gemv_fp8_pert = _esimd.esimd_gemv_fp8_pert
+    esimd_fused_add_rms_norm = _esimd.esimd_fused_add_rms_norm
+    esimd_rms_norm_gated = _esimd.esimd_rms_norm_gated
+else:
+    esimd_gemv_fp8_pert = None
+    esimd_fused_add_rms_norm = None
+    esimd_rms_norm_gated = None
