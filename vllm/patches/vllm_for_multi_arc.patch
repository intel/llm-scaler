+            torch.empty(num_experts, scales_size2, hidden_size, dtype=params_dtype),
+            requires_grad=False,
+        )
+        layer.register_parameter("w2_scales", w2_scales)
+        set_weight_attrs(w2_scales, extra_weight_attrs)
+        # don't shard the w2 scales when running act order
+        set_weight_attrs(w2_scales, {"load_full_w2": self.quant_config.desc_act})
+        # up_proj scales
+        w13_qzeros = torch.nn.Parameter(
+            torch.empty(
+                num_experts,
+                scales_size13,
+                2 * intermediate_size_per_partition // self.quant_config.pack_factor,
+                dtype=params_dtype,
+            ),
+            requires_grad=False,
+        )
+        layer.register_parameter("w13_qzeros", w13_qzeros)
+        set_weight_attrs(w13_qzeros, extra_weight_attrs)
+        # down_proj scales
+        w2_qzeros = torch.nn.Parameter(
+            torch.empty(
+                num_experts,
+                scales_size2,
+                hidden_size // self.quant_config.pack_factor,
+                dtype=params_dtype,
+            ),
+            requires_grad=False,
+        )
+        layer.register_parameter("w2_qzeros", w2_qzeros)
+        set_weight_attrs(w2_qzeros, extra_weight_attrs)
+        # don't shard the w2 scales when running act order
+        set_weight_attrs(w2_qzeros, {"load_full_w2": self.quant_config.desc_act})
+        w13_g_idx = torch.nn.Parameter(
+            torch.empty(
+                num_experts,
+                hidden_size,
+                dtype=torch.int32,
+            ),
+            requires_grad=False,
+        )
+        layer.register_parameter("w13_g_idx", w13_g_idx)
+        set_weight_attrs(w13_g_idx, extra_weight_attrs)
+        w2_g_idx = torch.nn.Parameter(
+            torch.empty(
+                num_experts,
+                intermediate_size_per_partition,
+                dtype=torch.int32,
+            ),
+            requires_grad=False,
+        )
+        layer.register_parameter("w2_g_idx", w2_g_idx)
+        set_weight_attrs(w2_g_idx, extra_weight_attrs)
+        w13_g_idx_sort_indices = torch.nn.Parameter(
+            torch.empty(
+                num_experts,
+                hidden_size,
+                dtype=torch.int32,
+            ),
+            requires_grad=False,
+        )
+        layer.register_parameter("w13_g_idx_sort_indices", w13_g_idx_sort_indices)
+        set_weight_attrs(w13_g_idx_sort_indices, extra_weight_attrs)
+        w2_g_idx_sort_indices = torch.nn.Parameter(
+            torch.empty(
+                num_experts,
+                intermediate_size_per_partition,
+                dtype=torch.int32,
+            ),
+            requires_grad=False,
+        )
+        layer.register_parameter("w2_g_idx_sort_indices", w2_g_idx_sort_indices)
+        set_weight_attrs(w2_g_idx_sort_indices, extra_weight_attrs)
+
+    @staticmethod
+    def _gptq_int32_to_uint8(qw):
+        """Convert GPTQ int32 [E, K/8, N] to CUTLASS uint8 [E, N, K/2].
+
+        GPTQ packs 8 nibbles per int32 along the K axis (K-major).
+        CUTLASS grouped GEMM expects uint8 with 2 nibbles per byte and
+        N as the leading feature axis (N-major). This unpacks, transposes
+        K<->N, then repacks pairs of consecutive K nibbles into bytes
+        (low-nibble = K-row 2*k, high-nibble = K-row 2*k+1).
+        """
+        assert qw.dtype == torch.int32
+        E, K8, N = qw.shape
+        # Unpack 8 nibbles per int32 along K -> [E, K, N] uint8 (values 0..15)
+        shifts = torch.arange(0, 32, 4, dtype=torch.int32).view(1, 1, 8, 1)
+        nibbles = (qw.unsqueeze(2) >> shifts) & 0xF
+        unpacked = nibbles.reshape(E, K8 * 8, N).to(torch.uint8)
+        # Transpose K<->N -> [E, N, K], then repack pairs along K
+        unpacked = unpacked.transpose(1, 2).contiguous()
+        low = unpacked[..., 0::2]
+        high = unpacked[..., 1::2]
+        return (high << 4) | low
+
+    @staticmethod
+    def _implement_zp(qw):
+        """Convert uint4 to signed int4 for CUTLASS kernel.
+
+        The CUTLASS grouped GEMM expects signed INT4 weights. GPTQ stores
+        unsigned uint4 (0-15). Subtract 8 to center around zero (-8..+7),
+        then repack into the 4-bit signed format CUTLASS expects.
+        """
+        hi = (qw >> 4) & 0x0F
+        lo = qw & 0x0F
+        hi_s = hi.to(torch.int8) - 8
+        lo_s = lo.to(torch.int8) - 8
+        def pack(a, b):
+            def p(x):
+                s = (x < 0).to(torch.uint8)
+                a3 = (x.view(torch.uint8) & 0x7).to(torch.uint8)
+                return (s << 3) | a3
+            return (p(a) << 4) | p(b)
+        return pack(hi_s, lo_s)
+
+    def process_weights_after_loading(self, layer: torch.nn.Module) -> None:
+        if self.quant_config.linear_quant_method != "gptq":
+            raise NotImplementedError(
+                f"Unsupported quant method "
+                f"{self.quant_config.linear_quant_method} for XPU MOE."
+            )
+        # Backend selector: "cutlass" (default) or "onednn".
+        # Both bypass IPEX GatedMLPMOE (Bug H / IPEX #838).
+        if self.MOE_BACKEND == "onednn":
+            return self._prep_onednn(layer)
+        # --- CUTLASS path ---
+        # Convert GPTQ int32-packed weights to CUTLASS uint8 format.
+        # GPTQ stores [E, K/8, N] int32 (K-major); CUTLASS grouped GEMM
+        # requires [E, N, K/2] uint8 (N-major). The conversion below
+        # unpacks, transposes K<->N, then repacks nibble pairs.
+        # _implement_zp then converts uint4 -> signed int4 (sign-mag).
+        # NOTE: assumes symmetric quantization (ZP=8). AutoRound with
+        # sym=True satisfies this; asymmetric GPTQ models are not
+        # supported by this path.
+        device = layer.w13_qweight.device
+        num_experts = layer.w13_qweight.shape[0]
+
+        # Convert int32 → uint8 on CPU (avoids XPU allocator pressure)
+        w13_uint8 = self._gptq_int32_to_uint8(layer.w13_qweight.cpu())
+        w2_uint8 = self._gptq_int32_to_uint8(layer.w2_qweight.cpu())
+
+        # Apply implement_zp (uint4 → signed int4) on CPU
+        for i in range(num_experts):
+            w13_uint8[i] = self._implement_zp(w13_uint8[i])
+            w2_uint8[i] = self._implement_zp(w2_uint8[i])
+
+        # Free original int32 weights to reduce memory
+        layer.w13_qweight.data = torch.empty(
+            0, dtype=torch.int32, device=device)
+        layer.w2_qweight.data = torch.empty(
+            0, dtype=torch.int32, device=device)
+        torch.xpu.empty_cache()
+
+        # Store CUTLASS-format weights as layer attributes
+        layer.cutlass_w13 = w13_uint8.contiguous().to(device)
+        layer.cutlass_w2 = w2_uint8.contiguous().to(device)
+        # Scales: CUTLASS expects [E, N, K//group_size]
+        layer.cutlass_s13 = layer.w13_scales.permute(0, 2, 1).contiguous()
+        layer.cutlass_s2 = layer.w2_scales.permute(0, 2, 1).contiguous()
+
+    def _prep_onednn(self, layer: torch.nn.Module) -> None:
+        """Prepare GPTQ weights for oneDNN int4_gemm_w4a16.
+
+        oneDNN expects weights K-contiguous in their original GPTQ shape
+        [K/8, N] int32. The transpose(0,1).contiguous().transpose(0,1)
+        trick produces K-contiguous strides without changing the shape.
+        No uint8 conversion, no shuffling, no implement_zp. For symmetric
+        GPTQ (AutoRound sym=True) the zero-point is a scalar 8.
+        """
+        device = layer.w13_qweight.device
+        num_experts = layer.w13_qweight.shape[0]
+        w13_list, w2_list = [], []
+        s13_list, s2_list = [], []
+        for e in range(num_experts):
+            w13_e = layer.w13_qweight[e].cpu()
+            w2_e = layer.w2_qweight[e].cpu()
+            w13_list.append(
+                w13_e.transpose(0, 1).contiguous().transpose(0, 1))
+            w2_list.append(
+                w2_e.transpose(0, 1).contiguous().transpose(0, 1))
+            s13_list.append(layer.w13_scales[e].cpu().contiguous())
+            s2_list.append(layer.w2_scales[e].cpu().contiguous())
+        # Free original tensors
+        layer.w13_qweight.data = torch.empty(
+            0, dtype=torch.int32, device=device)
+        layer.w2_qweight.data = torch.empty(
+            0, dtype=torch.int32, device=device)
+        torch.xpu.empty_cache()
+        layer.int4_w13 = [w.to(device) for w in w13_list]
+        layer.int4_w2 = [w.to(device) for w in w2_list]
+        layer.int4_s13 = [s.to(device) for s in s13_list]
+        layer.int4_s2 = [s.to(device) for s in s2_list]
+        # Symmetric GPTQ: scalar zero-point = 8
+        layer.int4_zp = torch.tensor(
+            [8], dtype=torch.int8, device=device)
+        layer.int4_num_experts = num_experts
+        layer.int4_group_size = self.quant_config.group_size
+
+    # Backend selector: "onednn" (default) or "cutlass".
+    # - onednn:  per-expert int4_gemm_w4a16 — reads native GPTQ int32 and
+    #   does proper (nibble - zp) * scale dequantization. Correct for INT4.
+    # - cutlass: BROKEN for INT4. cutlass_grouped_gemm_interface(is_B_int4)
+    #   actually treats nibbles as FP4 E2M1 (microscaling format), NOT as
+    #   integer 4-bit. Value 15 → NaN, other values exponentially wrong.
+    #   Kept only for reference/debugging — do NOT use for production.
+    MOE_BACKEND = os.environ.get("VLLM_XPU_MOE_BACKEND", "onednn").lower()
+
+    # Max experts per CUTLASS grouped GEMM dispatch. Matches the 8 Xe-cores
+    # on Lunar Lake Arc 140V — one expert group per Xe-core. Dispatching
+    # 50+ expert groups simultaneously causes DEVICE_LOST due to workgroup
+    # scheduler oversubscription. Chunking to 8 gives ~8x speedup over
+    # sequential (1-at-a-time) while staying within hardware limits.
+    # On B580 (20 Xe-cores) this could be raised to ~16-20.
+    EXPERTS_PER_CHUNK = int(os.environ.get(
+        "VLLM_XPU_MOE_CHUNK_SIZE", "8"))
+
+    def _chunked_moe_gemm(self, input_by_expert, weights, scales,
+                           expert_ids, N, K, output_dim, dtype, device):
+        """Run CUTLASS grouped GEMM on a chunk of experts.
+
+        Groups up to EXPERTS_PER_CHUNK experts into a single
+        cutlass_grouped_gemm_interface call. The interface expects:
+          - ptr_A: concatenated input rows [total_tokens, K]
+          - ptr_B: stacked expert weights [num_experts_in_chunk, ...]
+          - expert_first_token_offset: cumulative token offsets [num+1]
+        """
+        chunk_size = len(expert_ids)
+        # Build concatenated input and offset array
+        inputs = [input_by_expert[eid] for eid in expert_ids]
+        counts = [inp.shape[0] for inp in inputs]
+        total = sum(counts)
+        if total == 0:
+            return {}
+
+        cat_input = torch.cat(inputs, dim=0)  # [total, K]
+        # Cumulative offsets: [0, n0, n0+n1, ..., total]
+        offsets = torch.zeros(chunk_size + 1, dtype=torch.int64,
+                              device=device)
+        for i, c in enumerate(counts):
+            offsets[i + 1] = offsets[i] + c
+
+        # Stack weights and scales for this chunk
+        w_chunk = weights[expert_ids]   # [chunk, ...]
+        s_chunk = scales[expert_ids]    # [chunk, ...]
+
+        out = torch.empty(total, output_dim, dtype=dtype, device=device)
+        torch.ops._xpu_C.cutlass_grouped_gemm_interface(
+            cat_input, w_chunk, s_chunk,
+            None, out, offsets,
+            N, K, chunk_size, True, False)
+
+        # Split output back per expert
+        results = {}
+        for i, eid in enumerate(expert_ids):
+            start = offsets[i].item()
+            end = offsets[i + 1].item()
+            if end > start:
+                results[eid] = out[start:end]
+        return results
+
+    def apply(
+        self,
+        layer: FusedMoE,
+        router: FusedMoERouter,
+        x: torch.Tensor,
+        router_logits: torch.Tensor,
+    ) -> torch.Tensor | tuple[torch.Tensor, torch.Tensor]:
+        if self.MOE_BACKEND == "onednn":
+            return self._apply_onednn(layer, x, router_logits)
+        # CUTLASS chunked expert dispatch — bypasses IPEX GatedMLPMOE.
+        # Processes EXPERTS_PER_CHUNK experts at a time (default 8,
+        # matching Lunar Lake's 8 Xe-cores) to avoid DEVICE_LOST from
+        # workgroup scheduler oversubscription with 50+ expert groups.
+        from vllm_xpu_kernels import _xpu_C  # noqa: F401
+
+        num_tokens, hidden_dim = x.shape
+        top_k = layer.top_k
+        W13 = layer.cutlass_w13
+        W2 = layer.cutlass_w2
+        S13 = layer.cutlass_s13
+        S2 = layer.cutlass_s2
+        num_experts = W13.shape[0]
+        inter_size = W13.shape[1] // 2
+
+        # Routing: topk softmax
+        topk_weights, topk_ids = torch.topk(
+            router_logits.float(), k=top_k, dim=-1)
+        topk_weights = torch.softmax(topk_weights, dim=-1)
+        if layer.renormalize:
+            topk_weights = topk_weights / topk_weights.sum(
+                dim=-1, keepdim=True)
+
+        # Pre-sort tokens by expert: build per-expert input tensors
+        # and track (token_idx, slot_idx) for weighted accumulation
+        expert_inputs = {}   # eid -> input tensor [n, hidden_dim]
+        expert_meta = {}     # eid -> (token_indices, expert_weights)
+        active_experts = []
+        for eid in range(num_experts):
+            mask = (topk_ids == eid)
+            if not mask.any():
+                continue
+            tok_idx, slot_idx = mask.nonzero(as_tuple=True)
+            expert_inputs[eid] = x[tok_idx]
+            expert_meta[eid] = (tok_idx,
+                                topk_weights[tok_idx, slot_idx])
+            active_experts.append(eid)
+
+        output = torch.zeros(num_tokens, hidden_dim,
+                             dtype=x.dtype, device=x.device)
+
+        # Process active experts in chunks of EXPERTS_PER_CHUNK
+        chunk_sz = self.EXPERTS_PER_CHUNK
+        for ci in range(0, len(active_experts), chunk_sz):
+            chunk_eids = active_experts[ci:ci + chunk_sz]
+
+            # GEMM1: gate_up projection [n, hidden] -> [n, 2*inter]
+            g1_results = self._chunked_moe_gemm(
+                expert_inputs, W13, S13, chunk_eids,
+                2 * inter_size, hidden_dim,
+                2 * inter_size, x.dtype, x.device)
+
+            # SiLU activation + prepare input for GEMM2
+            activated_inputs = {}
+            for eid, g1_out in g1_results.items():
+                activated_inputs[eid] = (
+                    torch.nn.functional.silu(g1_out[:, :inter_size])
+                    * g1_out[:, inter_size:]
+                ).contiguous()
+
+            # GEMM2: down projection [n, inter] -> [n, hidden]
+            g2_results = self._chunked_moe_gemm(
+                activated_inputs, W2, S2, chunk_eids,
+                hidden_dim, inter_size,
+                hidden_dim, x.dtype, x.device)
+
+            # Weighted accumulate
+            for eid, g2_out in g2_results.items():
+                tok_idx, weights = expert_meta[eid]
+                output[tok_idx] += weights.unsqueeze(1) * g2_out
+
+        return output
+
+    def _apply_onednn(
+        self,
+        layer: FusedMoE,
+        x: torch.Tensor,
+        router_logits: torch.Tensor,
+    ) -> torch.Tensor:
+        """Sequential per-expert MoE using oneDNN int4_gemm_w4a16.
+
+        Uses the native GPTQ int32 layout (no CUTLASS conversion). One
+        kernel call per expert per gemm — slower than the chunked CUTLASS
+        path but known-good on oneDNN. Useful as a fallback when the
+        CUTLASS path has issues on a given model/shape.
+        """
+        num_tokens, hidden_dim = x.shape
+        top_k = layer.top_k
+        num_experts = layer.int4_num_experts
+        group_size = layer.int4_group_size
+        zp = layer.int4_zp
+        inter_size = layer.int4_w13[0].shape[1] // 2  # W13: [K//8, 2N]
+
+        topk_weights, topk_ids = torch.topk(
+            router_logits.float(), k=top_k, dim=-1)
+        topk_weights = torch.softmax(topk_weights, dim=-1)
+        if layer.renormalize:
+            topk_weights = topk_weights / topk_weights.sum(
+                dim=-1, keepdim=True)
+
+        output = torch.zeros(num_tokens, hidden_dim,
+                             dtype=x.dtype, device=x.device)
+
+        for expert_id in range(num_experts):
+            mask = (topk_ids == expert_id)
+            if not mask.any():
+                continue
+            token_indices, slot_indices = mask.nonzero(as_tuple=True)
+            expert_weights = topk_weights[token_indices, slot_indices]
+            expert_input = x[token_indices]
+
+            # GEMM1: [n, hidden] -> [n, 2*inter]
+            g1_out = torch.ops._xpu_C.int4_gemm_w4a16(
+                expert_input,
+                layer.int4_w13[expert_id],
+                None,  # bias
+                layer.int4_s13[expert_id],
+                zp,
+                group_size,
+                None,  # g_idx
+            )
+
+            activated = (torch.nn.functional.silu(g1_out[:, :inter_size])
+                         * g1_out[:, inter_size:])
+
+            # GEMM2: [n, inter] -> [n, hidden]
+            g2_out = torch.ops._xpu_C.int4_gemm_w4a16(
+                activated.contiguous(),
+                layer.int4_w2[expert_id],
+                None,
+                layer.int4_s2[expert_id],
+                zp,
+                group_size,
+                None,
+            )
+
+            output[token_indices] += expert_weights.unsqueeze(1) * g2_out
+
+        return output
