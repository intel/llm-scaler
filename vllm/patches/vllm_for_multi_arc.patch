+            f"sym_int4 MoE requires hidden_size % {QK4_GROUP_SIZE} == 0"
+        )
+        assert (
+            layer._int4_intermediate_size % QK4_GROUP_SIZE == 0
+        ), f"sym_int4 MoE requires intermediate_size % {QK4_GROUP_SIZE} == 0"
