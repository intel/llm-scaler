+    do_normalize = False
+    patch_size = 16
+    max_soft_tokens = 280
+    pooling_kernel_size = 3
+    valid_kwargs = Gemma4UnifiedImageProcessorKwargs
+    model_input_names = ["pixel_values", "image_position_ids", "num_soft_tokens_per_image"]
