new file mode 100644
index 000000000..18aa39706
--- /dev/null
+++ b/vllm/model_executor/layers/quantization/sym_int4.py
@@ -0,0 +1,659 @@
+# SPDX-License-Identifier: Apache-2.0
+# SPDX-FileCopyrightText: Copyright contributors to the vLLM project
+"""SYM_INT4 weight-only quantization for XPU.
+
+BF16/FP16 weights are quantized on the fly to GGML Q4_0 layout
+(``qweight [N, K/8] int32`` + ``scale [N, K/128] fp16``, group size 128, with a
+symmetric zero-point of 8) and executed through the vllm-xpu-kernels oneDNN
+INT4 GEMM — the same IPEX-free backend the upstream ``gptq.py`` XPU path uses
+(``transpose_onednn_woq_format`` + ``torch.ops._xpu_C.int4_gemm_w4a16``).
+
+This is the downstream XPU ``sym_int4`` scheme, rebuilt on the v0.21.0 quant
+API. It is structurally modeled on this repo's ``fp8.py`` (config dispatch +
+streaming loader helpers); the GGML Q4_0 weight quantizer is kept because
+vllm-xpu-kernels only ships activation quant + format conversion, not a weight
+RTN-to-Q4_0 quantizer.
+
+Scope of this module right now: the **Linear** and **FusedMoE** paths on the
+legacy ``VLLM_OFFLOAD_WEIGHTS_BEFORE_QUANT=1`` load (full BF16 buffered on CPU,
+then quantized in ``process_weights_after_loading``). The FusedMoE path runs
+through vllm-xpu-kernels ``xpu_fused_moe(is_int4=True)`` (cutlass grouped INT4
+GEMM). The meta-device streaming loader is added in a follow-up PR (Feature 2a);
+until then both paths require ``VLLM_OFFLOAD_WEIGHTS_BEFORE_QUANT=1``.
+"""
+
+import ctypes
+from typing import Any, Optional
+
+import torch
+from torch.nn import Module
+from torch.nn.parameter import Parameter
+
+from vllm.envs import VLLM_OFFLOAD_WEIGHTS_BEFORE_QUANT, VLLM_QUANTIZE_Q40_LIB
+from vllm.logger import init_logger
+from vllm.model_executor.layers.fused_moe import (
+    FusedMoE,
+    FusedMoEConfig,
+    FusedMoEMethodBase,
+)
+from vllm.model_executor.layers.fused_moe.config import FusedMoEQuantConfig
+from vllm.model_executor.layers.fused_moe.layer import UnquantizedFusedMoEMethod
+from vllm.model_executor.layers.linear import (
+    LinearBase,
+    LinearMethodBase,
+    UnquantizedLinearMethod,
+)
+from vllm.model_executor.layers.quantization import QuantizationMethods
+from vllm.model_executor.layers.quantization.base_config import (
+    QuantizationConfig,
+    QuantizeMethodBase,
+)
+from vllm.model_executor.parameter import ModelWeightParameter
+from vllm.model_executor.utils import set_weight_attrs
+
+logger = init_logger(__name__)
+
+QK4_GROUP_SIZE: int = 128
+QK4_PACK_FACTOR: int = 8
+
+
+# ==============================================================================
+#  GGML Q4_0 quantization kernel (CPU C library)
+# ==============================================================================
+
+_QLIB_CACHE = None
+
+
+def _get_quant_lib():
+    """Lazily load the Q4_0 quantization C library and set up argtypes.
+
+    Singleton: the DLL is loaded once and reused for every layer.
+    """
+    global _QLIB_CACHE
+    if _QLIB_CACHE is not None:
+        return _QLIB_CACHE
+
+    try:
+        clib = ctypes.CDLL(VLLM_QUANTIZE_Q40_LIB)
+    except OSError as e:
+        raise RuntimeError(
+            f"Failed to load required quantization lib at "
+            f"{VLLM_QUANTIZE_Q40_LIB}: {e}"
+        )
+
+    # C signature:
+    # (float *src, int32_t *qweight, ggml_fp16_t *scale,
+    #  int out_features, int in_features, int block_size)
+    clib.quantize_q4_0_to_qweight_and_scale.argtypes = [
+        ctypes.POINTER(ctypes.c_float),
+        ctypes.POINTER(ctypes.c_int32),
+        ctypes.POINTER(ctypes.c_uint16),
+        ctypes.c_int,
+        ctypes.c_int,
+        ctypes.c_int,
+    ]
+    clib.quantize_q4_0_to_qweight_and_scale.restype = ctypes.c_size_t
+
+    _QLIB_CACHE = clib
+    return clib
+
+
+def ggml_quantize_tensor(
+    weight: torch.Tensor,
+    out_qweight: torch.Tensor,
+    out_scale: torch.Tensor,
+    out_features: int,
+    in_features: int,
+    block_size: int = QK4_GROUP_SIZE,
+    transpose: bool = True,
+):
+    """Quantize a 2D FP32 weight to GGML Q4_0 via the C library.
+
+    Args:
+        transpose: If True, transpose the outputs to column-major. The Linear
+            method here passes ``transpose=False`` (keeping the row-major
+            ``[out_features, ...]`` layout) and transposes explicitly afterward
+            into the oneDNN ``[K/8, N]`` layout.
+    """
+    assert weight.dim() == 2
+    assert out_qweight.shape == (out_features, in_features // QK4_PACK_FACTOR)
+    assert out_scale.shape == (out_features, in_features // block_size)
+    assert weight.dtype == torch.float32
+    assert out_qweight.dtype == torch.int32
+    assert out_scale.dtype == torch.float16
+    assert out_qweight.is_contiguous()
+    assert out_scale.is_contiguous()
+
+    src = ctypes.cast(weight.data.data_ptr(), ctypes.POINTER(ctypes.c_float))
+    qweight = ctypes.cast(
+        out_qweight.data.data_ptr(), ctypes.POINTER(ctypes.c_int32)
+    )
+    scale = ctypes.cast(
+        out_scale.data.data_ptr(), ctypes.POINTER(ctypes.c_uint16)
+    )
+
+    clib = _get_quant_lib()
+    clib.quantize_q4_0_to_qweight_and_scale(
+        src, qweight, scale, out_features, in_features, block_size
+    )
+
+    if transpose:
+        out_qweight = out_qweight.transpose(0, 1).contiguous()
+        out_scale = out_scale.transpose(0, 1).contiguous()
+
+    return out_qweight, out_scale
+
+
+# ==============================================================================
+#  Config
+# ==============================================================================
+
+
+class SymInt4Config(QuantizationConfig):
+    """Config for the XPU SYM_INT4 (GGML Q4_0 + oneDNN int4) scheme."""
+
+    def __init__(self) -> None:
+        super().__init__()
+
+    @classmethod
+    def get_name(cls) -> QuantizationMethods:
+        return "sym_int4"
+
+    @classmethod
+    def get_supported_act_dtypes(cls) -> list[torch.dtype]:
+        return [torch.half]
+
+    @classmethod
+    def get_min_capability(cls) -> int:
+        return -1
+
+    @classmethod
+    def get_config_filenames(cls) -> list[str]:
+        return []
+
+    @classmethod
+    def from_config(cls, config: dict[str, Any]) -> "SymInt4Config":
+        return cls()
+
+    def get_quant_method(
+        self, layer: torch.nn.Module, prefix: str
+    ) -> Optional["QuantizeMethodBase"]:
+        # The skip check is applied inside each layer-type branch so that
+        # skipped layers get a type-correct unquantized method
+        # (Linear vs FusedMoE), rather than always returning the Linear one.
+        if isinstance(layer, LinearBase):
+            if self._is_layer_skipped(prefix):
+                return UnquantizedLinearMethod()
+            return SymInt4LinearMethod(self)
+        if isinstance(layer, FusedMoE):
+            if self._is_layer_skipped(prefix):
+                return UnquantizedFusedMoEMethod(layer.moe_config)
+            return XPUGPTQInt4LinearMoEMethod(self, layer.moe_config)
+        return None
+
+    @staticmethod
+    def _is_layer_skipped(prefix: str) -> bool:
+        # Vision / shared-expert branches stay in their original precision.
+        # ``vision_experts`` is an explicit opt-back-in so MoE-style vision
+        # towers are still quantized.
+        modules_to_not_convert = [
+            "visual",
+            "vision",
+            "vpm",
+            "resampler",
+            "shared_expert",
+        ]
+        modules_to_convert = ["vision_experts"]
+        return any(key in prefix for key in modules_to_not_convert) and not any(
+            key in prefix for key in modules_to_convert
+        )
+
+
+# ==============================================================================
+#  Linear method
+# ==============================================================================
+
+
+class SymInt4LinearMethod(LinearMethodBase):
+    """INT4 weight-only Linear method backed by the vllm-xpu-kernels oneDNN
+    INT4 GEMM (IPEX-free, same backend as the upstream gptq.py XPU path).
+
+    Currently supports the legacy ``VLLM_OFFLOAD_WEIGHTS_BEFORE_QUANT=1`` load:
+    BF16 weights are buffered on CPU, moved onto XPU by ``device_loading_context``,
+    quantized to GGML Q4_0, laid out for oneDNN (``transpose_onednn_woq_format``),
+    and executed with ``torch.ops._xpu_C.int4_gemm_w4a16``.
+    """
+
+    def __init__(self, quant_config: SymInt4Config):
+        self.quant_config = quant_config
+        # Ensure the quantization lib is loadable as early as possible so a
+        # misconfigured VLLM_QUANTIZE_Q40_LIB fails at setup, not mid-load.
+        _get_quant_lib()
+
+    def create_weights(
+        self,
+        layer: torch.nn.Module,
+        input_size_per_partition: int,
+        output_partition_sizes: list[int],
+        input_size: int,
+        output_size: int,
+        params_dtype: torch.dtype,
+        **extra_weight_attrs,
+    ):
+        output_size_per_partition = sum(output_partition_sizes)
+        weight_loader = extra_weight_attrs.get("weight_loader")
+
+        layer.logical_widths = output_partition_sizes
+        layer.input_size_per_partition = input_size_per_partition
+        layer.output_size_per_partition = output_size_per_partition
+        layer.orig_dtype = params_dtype
+
+        if not VLLM_OFFLOAD_WEIGHTS_BEFORE_QUANT:
+            # Meta-device streaming load lands in the follow-up streaming PR
+            # (Feature 2a). Until then the only supported load is the legacy
+            # CPU-buffer path; surface the requirement explicitly.
+            raise NotImplementedError(
+                "sym_int4 currently requires VLLM_OFFLOAD_WEIGHTS_BEFORE_QUANT=1; "
+                "the streaming (meta-device) loader is added in the follow-up "
+                "streaming PR (Feature 2a)."
+            )
+
+        # Legacy path: buffer BF16 weights on CPU. They are moved onto XPU by
+        # device_loading_context and quantized in process_weights_after_loading.
+        weight = ModelWeightParameter(
+            data=torch.empty(
+                output_size_per_partition,
+                input_size_per_partition,
+                dtype=params_dtype,
+                device="cpu",
+            ),
+            input_dim=1,
+            output_dim=0,
+            weight_loader=weight_loader,
+        )
+        layer.register_parameter("weight", weight)
+
+    def process_weights_after_loading(self, layer: Module) -> None:
+        if getattr(
+            layer, "_already_called_process_weights_after_loading", False
+        ):
+            return
+        _quantize_linear_int4_inplace(layer)
+
+    def apply(
+        self,
+        layer: torch.nn.Module,
+        x: torch.Tensor,
+        bias: Optional[torch.Tensor] = None,
+    ) -> torch.Tensor:
+        # oneDNN INT4 GEMM (same op as gptq.py's XPU path). The bias is fused
+        # by the kernel. qzeros holds the symmetric scalar 8 set up by
+        # transpose_onednn_woq_format.
+        reshaped_x = x.reshape(-1, x.shape[-1])
+        out = torch.ops._xpu_C.int4_gemm_w4a16(
+            reshaped_x,
+            layer.qweight,
+            bias,
+            layer.scales,
+            layer.qzeros,
+            QK4_GROUP_SIZE,
+            None,
+        )
+        return out.reshape(x.shape[:-1] + (layer.qweight.shape[-1],))
+
+
+def _quantize_linear_int4_inplace(layer: Module) -> None:
+    """Quantize a Linear layer's BF16/FP16 weight to INT4 for the oneDNN backend.
+
+    The BF16 weight (on CPU, or temporarily moved to XPU by
+    ``device_loading_context``) is upcast to FP32 on CPU and quantized to GGML
+    Q4_0 via the C library. The int32 qweight + fp16 scales are moved onto XPU
+    and registered in the gptq.py layout (``qweight [K/8, N]``,
+    ``scales [K/group, N]``, plus a ``qzeros`` placeholder), then
+    ``transpose_onednn_woq_format`` lays them out for the oneDNN int4 GEMM
+    (symmetric => qzeros becomes the scalar 8 the kernel broadcasts).
+    """
+    from vllm_xpu_kernels.quantization._quantize_convert import (
+        transpose_onednn_woq_format,
+    )
+
+    bf16 = layer.weight.data
+    out_features = bf16.shape[0]
+    in_features = bf16.shape[1]
+
+    if bf16.device.type == "xpu":
+        # Pull to CPU before the BF16->FP32 upcast so the FP32 temporary never
+        # lives on XPU (``bf16.float().cpu()`` would briefly hold BF16 + FP32).
+        bf16_cpu = bf16.cpu()
+        layer.weight = None
+        del bf16
+        try:
+            torch.xpu.empty_cache()
+        except Exception:
+            pass
+        weight_cpu = bf16_cpu.float().contiguous()
+        del bf16_cpu
+    else:
+        weight_cpu = bf16.float().contiguous()
+
+    qweight = torch.zeros(
+        (out_features, in_features // QK4_PACK_FACTOR),
+        dtype=torch.int32,
+        device="cpu",
+    )
+    scale = torch.zeros(
+        (out_features, in_features // QK4_GROUP_SIZE),
+        dtype=torch.float16,
+        device="cpu",
+    )
+    # transpose=False keeps the ggml [N, K/8] / [N, K/group] layout; we
+    # transpose below to the [K/8, N] / [K/group, N] layout oneDNN expects.
+    qweight, scale = ggml_quantize_tensor(
+        weight_cpu,
+        qweight,
+        scale,
+        out_features,
+        in_features,
+        block_size=QK4_GROUP_SIZE,
+        transpose=False,
+    )
+    del weight_cpu
+
+    qweight_xpu = qweight.to("xpu")
+    scale_xpu = scale.to("xpu")
+    del qweight, scale
+
+    # ESIMD views ([N, K/2] uint8) registered so later ESIMD integration
+    # (Feature 2b) can reuse the quantized weights without re-quantizing.
+    layer.weight_esimd = Parameter(
+        qweight_xpu.view(torch.uint8), requires_grad=False
+    )
+    layer.scale_esimd = Parameter(scale_xpu, requires_grad=False)
+
+    # oneDNN / gptq.py layout: qweight [K/8, N], scales [K/group, N].
+    layer.qweight = Parameter(qweight_xpu.t().contiguous(), requires_grad=False)
+    layer.scales = Parameter(scale_xpu.t().contiguous(), requires_grad=False)
+    # Symmetric qzeros placeholder; transpose_onednn_woq_format overwrites it
+    # with the scalar 8 for the "gptq" symmetric case.
+    layer.qzeros = Parameter(
+        torch.zeros(
+            in_features // QK4_GROUP_SIZE,
+            out_features // QK4_PACK_FACTOR,
+            dtype=torch.int32,
+            device=qweight_xpu.device,
+        ),
+        requires_grad=False,
+    )
+    # Drop the now-quantized BF16 weight parameter.
+    layer.weight = None
+
+    transpose_onednn_woq_format(layer, "gptq", True)
+    layer._already_called_process_weights_after_loading = True
+
+
+# ==============================================================================
+#  FusedMoE method
+# ==============================================================================
+
+
+def _quantize_moe_int4_side_inplace(layer: Module, which: str) -> None:
+    """Quantize one MoE side (``w13`` or ``w2``) of a layer to GGML Q4_0.
+
+    The BF16 weight ``[E, N, K]`` (on CPU, or moved to XPU by
+    ``device_loading_context``) is quantized per expert to int32 qweight
+    ``[E, N, K/8]`` + fp16 scales ``[E, N, K/group]``.
+
+    The quantized result is stored under NEW names ``<which>_qweight`` /
+    ``<which>_qscales`` and the original ``<which>_weight`` is cleared to None.
+    This is deliberate: ``process_weights_after_loading`` runs inside
+    ``device_loading_context``, which records every parameter that started on
+    CPU and moves it BACK to CPU on exit (keyed by name). The BF16 buffers were
+    created on CPU, so reusing the ``<which>_weight`` name for the quantized XPU
+    tensor would get it dragged back to CPU — leaving weights on CPU while
+    scales stay on XPU, and the cutlass int4 GEMM then crashes on the
+    cross-device pointers. New names are not in that record, so they stay on XPU.
+    (v0.14.0-b8.3 instead patched device_loading_context to skip the move-back
+    when VLLM_OFFLOAD_WEIGHTS_BEFORE_QUANT=1; v0.21.0 dropped that guard, so we
+    avoid the name collision here instead of touching the loader.)
+    """
+    assert which in ("w13", "w2"), f"unknown side {which!r}"
+    weight_name = f"{which}_weight"
+    qweight_name = f"{which}_qweight"
+    scale_name = f"{which}_qscales"
+
+    src = getattr(layer, weight_name).data
+    if src.dim() != 3:
+        raise RuntimeError(
+            f"expected 3D MoE weight for {weight_name}, got {tuple(src.shape)}"
+        )
+    E_all, out_features, in_features = src.shape
+    num_loop = getattr(layer, "local_num_experts", E_all)
+
+    # Pull BF16 to CPU once (BF16 is half of FP32) and release XPU storage
+    # before allocating the quantized result, keeping XPU peak low.
+    if src.device.type == "xpu":
+        src_cpu = src.cpu().contiguous()
+        setattr(layer, weight_name, None)
+        del src
+        try:
+            torch.xpu.empty_cache()
+        except Exception:
+            pass
+    else:
+        src_cpu = src
+
+    qweight = torch.zeros(
+        E_all,
+        out_features,
+        in_features // QK4_PACK_FACTOR,
+        dtype=torch.int32,
+        device="cpu",
+    )
+    scales = torch.zeros(
+        E_all,
+        out_features,
+        in_features // QK4_GROUP_SIZE,
+        dtype=torch.float16,
+        device="cpu",
+    )
+    # Experts outside [0, num_loop) are not local; their slices stay zero.
+    # Quantize into the per-expert output slices directly: qweight[e]/scales[e]
+    # are already contiguous with the expected [N, K/8] / [N, K/group] shape, so
+    # no extra per-expert buffers + copies are needed. transpose=False keeps the
+    # row-major layout the oneDNN / cutlass int4 path expects (verified against
+    # the dequant reference).
+    for e in range(num_loop):
+        ggml_quantize_tensor(
+            src_cpu[e].float().contiguous(),
+            qweight[e],
+            scales[e],
+            out_features,
+            in_features,
+            block_size=QK4_GROUP_SIZE,
+            transpose=False,
+        )
+    del src_cpu
+    # Clear the original CPU-born BF16 parameter so device_loading_context does
+    # not later move our XPU quantized weight back to CPU (see docstring).
+    setattr(layer, weight_name, None)
+
+    qweight_xpu = qweight.to("xpu")
+    scales_xpu = scales.to("xpu")
+    del qweight, scales
+
+    # Store under NEW names so device_loading_context leaves them on XPU.
+    setattr(
+        layer,
+        qweight_name,
+        torch.nn.Parameter(qweight_xpu, requires_grad=False),
+    )
+    setattr(
+        layer,
+        scale_name,
+        torch.nn.Parameter(scales_xpu, requires_grad=False),
+    )
+
+
+class XPUGPTQInt4LinearMoEMethod(FusedMoEMethodBase):
+    """INT4 FusedMoE method backed by vllm-xpu-kernels ``xpu_fused_moe``
+    (``is_int4=True`` -> cutlass grouped INT4 GEMM, IPEX-free).
+
+    Like the Linear method this currently supports the legacy
+    ``VLLM_OFFLOAD_WEIGHTS_BEFORE_QUANT=1`` load only; the meta-device streaming
+    loader is added in a follow-up PR.
+    """
+
+    def __init__(self, quant_config: SymInt4Config, moe: FusedMoEConfig) -> None:
+        super().__init__(moe)
+        self.quant_config = quant_config
+        # Ensure the quantization lib is loadable at setup, not mid-load.
+        _get_quant_lib()
+
+    def get_fused_moe_quant_config(
+        self, layer: torch.nn.Module
+    ) -> Optional[FusedMoEQuantConfig]:
+        # sym_int4 drives the kernel directly via xpu_fused_moe; it does not use
+        # the modular-kernel quant config. v0.21.0 makes this abstract, so
+        # implement it as a no-op returning None.
+        return None
+
+    def create_weights(
+        self,
+        layer: Module,
+        num_experts: int,
+        hidden_size: int,
+        intermediate_size_per_partition: int,
+        params_dtype: torch.dtype,
+        **extra_weight_attrs,
+    ):
+        layer.num_experts = num_experts
+        layer.orig_dtype = params_dtype
+        layer.weight_block_size = None
+        # NOTE: hidden_size / intermediate_size_per_partition are read-only
+        # @property on FusedMoE (backed by moe_config), so we cannot assign
+        # them. Stash the create_weights args under private names for the
+        # quantize helper instead.
+        layer._int4_hidden_size = hidden_size
+        layer._int4_intermediate_size = intermediate_size_per_partition
+
+        if not VLLM_OFFLOAD_WEIGHTS_BEFORE_QUANT:
+            raise NotImplementedError(
+                "sym_int4 currently requires VLLM_OFFLOAD_WEIGHTS_BEFORE_QUANT=1; "
+                "the streaming (meta-device) loader is added in the follow-up "
+                "streaming PR (Feature 2a)."
+            )
+
+        # w13 is built as [E, 2I, H] (gate+up fused), which assumes an
+        # act-and-mul activation (e.g. SiLU). All current sym_int4 targets
+        # (qwen3_moe / qwen3_5_moe) are act-and-mul; the FP8 MoE path makes the
+        # same assumption. Fail loud rather than silently allocating the wrong
+        # shape for a non-act-and-mul MoE.
+        if not self.moe.is_act_and_mul:
+            raise NotImplementedError(
+                "sym_int4 MoE only supports act-and-mul activations "
+                "(is_act_and_mul=True); got is_act_and_mul=False."
+            )
+
+        # Legacy path: full BF16 buffers on CPU. device_loading_context moves
+        # them onto XPU prior to process_weights_after_loading. w13 is
+        # [E, 2I, H]; w2 is [E, H, I].
+        w13_weight = torch.nn.Parameter(
+            torch.empty(
+                num_experts,
+                2 * intermediate_size_per_partition,
+                hidden_size,
+                dtype=params_dtype,
+                device="cpu",
+            ),
+            requires_grad=False,
+        )
