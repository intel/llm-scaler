+    def _apply_xpu_int4(self, layer, x, topk_weights, topk_ids):
+        # XPU INT4 MoE apply via vllm_xpu_kernels'
+        # cutlass_grouped_gemm_interface(is_B_int4=True) + IPEX routing ops.
+        # Weights were prepared in process_weights_after_loading.
+        from vllm_xpu_kernels import _xpu_C  # noqa: F401
+
+        num_tokens, hidden_dim = x.shape
+        top_k = topk_ids.shape[-1]
+        num_experts = layer.xpu_int4_num_experts
+        group_size = layer.xpu_int4_group_size
+        W13 = layer.xpu_w13  # [E, 2I, H/2] uint8
+        W2 = layer.xpu_w2  # [E, H,  I/2] uint8
+        S13 = layer.xpu_s13  # [E, 2I, H/GS]
+        S2 = layer.xpu_s2  # [E, H,  I/GS]
+        inter_size = W13.shape[1] // 2
+
+        topk_ids_i32 = topk_ids.to(torch.int32)
+        topk_weights_f32 = topk_weights.to(torch.float32)
+
+        # IPEX routing: counts + scatter
+        rows_for_experts, expert_offsets = torch.ops.torch_ipex.moe_rows_counts(
+            topk_ids_i32, 0, num_experts
+        )
+        reordered, mapped_slot = torch.ops.torch_ipex.moe_scatter(
+            x,
+            rows_for_experts,
+            topk_ids_i32,
+            expert_offsets,
+            0,
+            num_experts,
+            top_k,
+        )
+
+        # Prefix-sum offsets for cutlass grouped gemm
+        ef_offset = torch.cat(
+            [
+                torch.zeros(1, device=x.device, dtype=torch.int64),
+                torch.cumsum(rows_for_experts.to(torch.int64), dim=0),
+            ]
+        )
+
+        M = num_tokens * top_k
+        # GEMM1: W13 (gate+up)
+        g1 = torch.empty((M, 2 * inter_size), dtype=x.dtype, device=x.device)
+        torch.ops._xpu_C.cutlass_grouped_gemm_interface(
+            ptr_A=reordered,
+            ptr_B=W13,
+            ptr_scales=S13,
+            ptr_bias=None,
+            ptr_D=g1,
+            expert_first_token_offset=ef_offset,
+            N=2 * inter_size,
+            K=hidden_dim,
+            num_experts=num_experts,
+            is_B_int4=True,
+            is_B_mxfp4=False,
+        )
+
+        # SiLU + mul
+        act = torch.empty((M, inter_size), dtype=x.dtype, device=x.device)
+        act = torch.ops.torch_ipex.silu_and_mul(g1, act)
+
+        # GEMM2: W2 (down)
+        g2 = torch.empty((M, hidden_dim), dtype=x.dtype, device=x.device)
+        torch.ops._xpu_C.cutlass_grouped_gemm_interface(
+            ptr_A=act,
+            ptr_B=W2,
+            ptr_scales=S2,
+            ptr_bias=None,
+            ptr_D=g2,
+            expert_first_token_offset=ef_offset,
+            N=hidden_dim,
+            K=inter_size,
+            num_experts=num_experts,
+            is_B_int4=True,
+            is_B_mxfp4=False,
+        )
+
+        # Gather (weighted un-permutation)
+        return torch.ops.torch_ipex.moe_gather(
+            g2, topk_weights_f32, mapped_slot, num_experts, top_k, False
+        )
