+            layer.xpu_w13 = w13_cpu_xpu.to(device)
+            del w13_cpu_xpu
+            layer.xpu_w2  = w2_cpu_xpu.to(device)
+            del w2_cpu_xpu
+            layer.xpu_s13 = s13_cpu.to(device)
+            del s13_cpu
+            layer.xpu_s2  = s2_cpu.to(device)
+            del s2_cpu
+            torch.xpu.empty_cache()
