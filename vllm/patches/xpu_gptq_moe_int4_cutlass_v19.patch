     def process_weights_after_loading(self, layer: torch.nn.Module) -> None:
+        from vllm.platforms import current_platform
+
+        if current_platform.is_xpu() and self.quant_config.weight_bits == 4:
+            # XPU INT4 MoE path: upstream GPTQ uses CUDA-only
+            # gptq_marlin_moe_repack + marlin_moe_permute_scales. Instead,
+            # convert GPTQ int32-packed [E, K/8, 2N] -> uint8 2's-complement
+            # [E, 2N, K/2], scales to [E, 2N, K/GS], and route apply()
+            # through vllm_xpu_kernels' cutlass_grouped_gemm_interface
+            # (is_B_int4=True, verified real INT4 in v0.1.5).
+            device = layer.w13_qweight.device
+            num_experts = layer.w13_qweight.shape[0]
+
+            def gptq_to_xpu_int4(qw_i32):
+                # qw_i32: [E, K/8, N] int32 (GPTQ: 8 nibbles per int32 along K)
+                # out: [E, N, K/2] uint8 2's-complement int4, 2 nibbles/byte
+                u32 = qw_i32.to(torch.int64) & 0xFFFFFFFF
+                nibs = torch.stack(
+                    [((u32 >> (p * 4)) & 0xF).to(torch.int32) for p in range(8)],
+                    dim=2,
+                )  # [E, K/8, 8, N]
+                E = qw_i32.shape[0]
+                N = qw_i32.shape[-1]
+                unpacked = nibs.reshape(E, -1, N)  # [E, K, N]
+                # symmetric GPTQ: (nibble - 8) & 0xF -> 2's-comp int4
+                int4 = ((unpacked - 8) & 0xF).to(torch.uint8)
+                int4_nk = int4.permute(0, 2, 1).contiguous()  # [E, N, K]
+                lo = int4_nk[..., 0::2]  # [E, N, K/2]
+                hi = int4_nk[..., 1::2]  # [E, N, K/2]
+                return (lo | (hi << 4)).to(torch.uint8)
+
+            # Transform per-tensor on CPU (frees XPU allocator).
+            w13_cpu = layer.w13_qweight.detach().cpu()
+            w2_cpu = layer.w2_qweight.detach().cpu()
+            s13_cpu = layer.w13_scales.detach().cpu().permute(0, 2, 1).contiguous()
+            s2_cpu = layer.w2_scales.detach().cpu().permute(0, 2, 1).contiguous()
+
+            # Free original GPTQ-format XPU tensors
+            layer.w13_qweight.data = torch.empty(0, dtype=torch.int32, device=device)
+            layer.w2_qweight.data = torch.empty(0, dtype=torch.int32, device=device)
+            layer.w13_scales.data = torch.empty(
+                0, dtype=layer.w13_scales.dtype, device=device
+            )
+            layer.w2_scales.data = torch.empty(
+                0, dtype=layer.w2_scales.dtype, device=device
+            )
+            torch.xpu.empty_cache()
+
+            w13_packed = gptq_to_xpu_int4(w13_cpu)  # [E, 2I, H/2]
+            w2_packed = gptq_to_xpu_int4(w2_cpu)    # [E, H,  I/2]
+            del w13_cpu, w2_cpu
+
+            layer.xpu_w13 = w13_packed.to(device)
+            del w13_packed
+            layer.xpu_w2 = w2_packed.to(device)
+            del w2_packed
+            layer.xpu_s13 = s13_cpu.to(device)
+            del s13_cpu
+            layer.xpu_s2 = s2_cpu.to(device)
+            del s2_cpu
+            torch.xpu.empty_cache()
+
+            layer.xpu_int4_num_experts = num_experts
+            layer.xpu_int4_group_size = self.quant_config.group_size
+            layer.xpu_int4_ready = True
+            return
+
