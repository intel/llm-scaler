+        # --- XPU branch: convert GPTQ int32-packed -> uint8-packed 2's-comp ---
+        from vllm.platforms import current_platform
+        if current_platform.is_xpu():
+            device = layer.w13_qweight.device
+            num_experts = layer.w13_qweight.shape[0]
+
+            def gptq_to_xpu_int4(qw_i32):
+                # qw_i32: [E, K/8, N] int32  (GPTQ: 8 nibbles per int32 along K)
+                # out: [E, N, K/2] uint8 2's-complement int4, packed 2 nibbles/byte
+                u32 = qw_i32.to(torch.int64) & 0xFFFFFFFF  # [E, K/8, N]
+                # Unpack to [E, K, N] uint8 with values 0..15 (GPTQ nibbles)
+                nibs = torch.stack([
+                    ((u32 >> (p * 4)) & 0xF).to(torch.int32) for p in range(8)
+                ], dim=2)  # [E, K/8, 8, N]
+                E = qw_i32.shape[0]
+                N = qw_i32.shape[-1]
+                unpacked = nibs.reshape(E, -1, N)  # [E, K, N]
+                # zp=8 (symmetric GPTQ): (nibble - 8) & 0xF -> 2's-comp int4
+                int4 = ((unpacked - 8) & 0xF).to(torch.uint8)
+                # Transpose to [E, N, K] then pack 2 nibbles per byte along K
+                int4_nk = int4.permute(0, 2, 1).contiguous()  # [E, N, K]
+                K_dim = int4_nk.shape[-1]
+                lo = int4_nk[..., 0::2]   # [E, N, K/2]
+                hi = int4_nk[..., 1::2]   # [E, N, K/2]
+                packed = (lo | (hi << 4)).to(torch.uint8)     # [E, N, K/2]
+                return packed
+
