+        # Sequential expert loop using int4_gemm_w4a16 (oneDNN format).
+        # Bypasses IPEX GatedMLPMOE entirely — uses vllm-xpu-kernels
+        # CUTLASS INT4 GEMM which works on Xe2 iGPU.
+        from vllm_xpu_kernels import _xpu_C  # noqa: F401
+
+        num_tokens, hidden_dim = x.shape
+        top_k = layer.top_k
+        num_experts = layer.int4_num_experts
+        group_size = layer.int4_group_size
+        zp = layer.int4_zp
+        inter_size = layer.int4_w13[0].shape[1] // 2  # W13: [K//8, 2N]
+
+        # Routing: topk softmax
+        topk_weights, topk_ids = torch.topk(
+            router_logits.float(), k=top_k, dim=-1)
+        topk_weights = torch.softmax(topk_weights, dim=-1)
+        if layer.renormalize:
+            topk_weights = topk_weights / topk_weights.sum(
+                dim=-1, keepdim=True)
+
+        # Sequential expert loop
+        output = torch.zeros(num_tokens, hidden_dim,
+                             dtype=x.dtype, device=x.device)
+
+        for expert_id in range(num_experts):
+            mask = (topk_ids == expert_id)
+            if not mask.any():
+                continue
+
+            token_indices, slot_indices = mask.nonzero(as_tuple=True)
+            expert_weights = topk_weights[token_indices, slot_indices]
+            expert_input = x[token_indices]  # [n, hidden_dim]
+
