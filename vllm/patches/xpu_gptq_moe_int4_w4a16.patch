+    @staticmethod
+    def _gptq_int32_to_uint8(qw):
+        """Convert GPTQ int32-packed (8 nibbles/int32) to uint8 (2 nibbles/byte)"""
+        shape = qw.shape
+        flat = qw.reshape(-1)
+        nibbles = [(flat >> (4 * i)) & 0xF for i in range(8)]
+        bytes_out = [
+            (nibbles[i + 1].to(torch.uint8) << 4) | nibbles[i].to(torch.uint8)
+            for i in range(0, 8, 2)
+        ]
+        return torch.stack(bytes_out, dim=-1).reshape(
+            *shape[:-2], shape[-2] * 4, shape[-1])
+
+    @staticmethod
+    def _implement_zp(qw):
+        """Convert uint4 to signed int4 for CUTLASS kernel"""
+        hi = (qw >> 4) & 0x0F
+        lo = qw & 0x0F
+        hi_s = hi.to(torch.int8) - 8
+        lo_s = lo.to(torch.int8) - 8
+        def pack(a, b):
+            def p(x):
+                s = (x < 0).to(torch.uint8)
+                a3 = (x.view(torch.uint8) & 0x7).to(torch.uint8)
+                return (s << 3) | a3
+            return (p(a) << 4) | p(b)
+        return pack(hi_s, lo_s)
 
