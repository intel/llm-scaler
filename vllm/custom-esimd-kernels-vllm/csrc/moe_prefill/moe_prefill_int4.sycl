#include <torch/extension.h>
#include <c10/xpu/XPUStream.h>
#include <sycl/sycl.hpp>
#include <sycl/ext/intel/esimd.hpp>
#include <sycl/ext/intel/experimental/esimd/memory.hpp>
#include <cstdio>
#include <cstdlib>
#include <cmath>
#include <cstring>
#include <algorithm>
#include <vector>
#include <cassert>

using fp16 = sycl::half;
using bf16 = sycl::ext::oneapi::bfloat16;
using namespace sycl::ext::intel::esimd;
namespace xesimd = sycl::ext::intel::experimental::esimd;
namespace xmx_ns = sycl::ext::intel::esimd::xmx;


// ======================== moe_prefill_gather_forward_kernel: Compute routing indices ========================
// Single work-group kernel using local memory atomics.
// Local memory layout: [counters: num_experts] [expert_offsets: num_experts]
template<int GS = 1024>
sycl::event moe_prefill_gather_forward_kernel(
    sycl::queue& q,
    const int* selected_experts, int* expert_offsets, int* expert_tokens,
    int num_experts, int total_seqlen)
{
    return q.submit([&](sycl::handler& cgh) {
        sycl::local_accessor<int, 1> slm_counters(sycl::range<1>(num_experts), cgh);
        sycl::local_accessor<int, 1> slm_offsets(sycl::range<1>(num_experts), cgh);

        cgh.parallel_for<class K0>(
            sycl::nd_range<1>(GS, GS),
            [=](sycl::nd_item<1> item) {
            const int lid = (int)item.get_local_id(0);

            // Phase 0: Zero local counters and offsets
            for (int i = lid; i < num_experts; i += GS) {
                slm_counters[i] = 0;
                slm_offsets[i] = 0;
            }
            item.barrier(sycl::access::fence_space::local_space);

            // Phase 1: Histogram from selected_experts into local counters
            for (int i = lid; i < total_seqlen; i += GS) {
                int eid = selected_experts[i];
                sycl::atomic_ref<int, sycl::memory_order::relaxed,
                    sycl::memory_scope::work_group,
                    sycl::access::address_space::local_space> ref(slm_counters[eid]);
                ref.fetch_add(1);
            }
            item.barrier(sycl::access::fence_space::local_space);

            // Phase 2: Prefix sum (thread 0)
            if (lid == 0) {
                int sum = 0;
                for (int i = 0; i < num_experts; i++) {
                    slm_offsets[i] = sum;
                    sum += slm_counters[i];
                }
            }
            item.barrier(sycl::access::fence_space::local_space);

            // Phase 3: Copy offsets to global
            for (int i = lid; i < num_experts; i += GS) {
                expert_offsets[i] = slm_offsets[i];
            }

            // Phase 4: Scatter expert_tokens (store pair_idx, not token_idx)
            for (int i = lid; i < total_seqlen; i += GS) {
                int eid = selected_experts[i];
                sycl::atomic_ref<int, sycl::memory_order::relaxed,
                    sycl::memory_scope::work_group,
                    sycl::access::address_space::local_space> ref(slm_offsets[eid]);
                int pos = ref.fetch_add(1);
                expert_tokens[pos] = i;
            }

        }); // parallel_for
    }); // submit
}

// ======================== moe_prefill_up_forward_kernel: Gate+Up+SiLU (GGEMV style) ========================
// Each thread computes MAX_M input rows x N weight rows.
// Input  -> VNNI b_tile (gathered per token lane)
// Weight -> row-major a_tile (loaded via lsc_load_2d, dequanted)
// DPAS(acc, b_tile=input, a_tile=weight) -> acc[weight_row*16+tok]
template<typename IT, int BS, int MAX_M = 32, int N = 16>
sycl::event moe_prefill_up_forward_kernel(
    sycl::queue& q,
    const IT* input, const uint8_t* gate_up_weight, const IT* gate_up_scale,
    IT* intermediate, const int* expert_offsets, const int* expert_tokens,
    int num_experts, int total_seqlen, int hidden_size, int intermediate_size, int top_k)
{
    static_assert(MAX_M % 16 == 0, "MAX_M must be multiple of 16");
    static_assert(N % 8 == 0, "N must be multiple of 8");
    static_assert(BS % 32 == 0, "BS must be multiple of 32");
    constexpr int MS      = MAX_M / 16;
    constexpr int NS      = N / 8;
    constexpr int ACC_SZ  = MS * NS * 128;

    return q.submit([&](sycl::handler& cgh) {
        cgh.parallel_for(
            sycl::range<2>(num_experts, intermediate_size / N),
            [=](sycl::id<2> id) SYCL_ESIMD_KERNEL {

            const int nblocks = hidden_size / BS;
            const int eid  = (int)id[0];
            const int tid  = (int)id[1];
            const int r_base = tid * N;
            const int t0 = expert_offsets[eid];
            const int t1 = (eid + 1 < num_experts) ? expert_offsets[eid + 1] : total_seqlen;
            if (t0 == t1) return;

            const int two_inter = 2 * intermediate_size;
            const size_t gate_row_base = (size_t)eid * two_inter + r_base;
            const size_t up_row_base   = gate_row_base + intermediate_size;
            const uint8_t* gate_w_ptr = gate_up_weight + gate_row_base * (hidden_size / 2);
            const uint8_t* up_w_ptr   = gate_up_weight + up_row_base * (hidden_size / 2);

            const simd<uint32_t, N> scl_byte_off =
                simd<uint32_t, N>(0u, 1u) * (uint32_t)(nblocks * sizeof(IT));
            const IT* gate_s_base = gate_up_scale + gate_row_base * nblocks;
            const IT* up_s_base   = gate_up_scale + up_row_base * nblocks;

            for (int m_base = t0; m_base < t1; m_base += MAX_M) {
                // --- Load pair indices, derive token indices for input ---
                simd<uint32_t, MAX_M> sorted_idxs =
                    min(simd<uint32_t, MAX_M>(0u, 1u) + (uint32_t)m_base,
                        simd<uint32_t, MAX_M>((uint32_t)(t1 - 1)));
                simd<uint32_t, MAX_M> pair_idxs =
                    convert<uint32_t>(gather<int, MAX_M>(expert_tokens, sorted_idxs * 4u));
                simd<uint32_t, MAX_M> in_off =
                    (pair_idxs / (uint32_t)top_k) * (uint32_t)(hidden_size * sizeof(IT));

                simd<fp16, ACC_SZ> g_acc(fp16(0));
                simd<fp16, ACC_SZ> u_acc(fp16(0));

                for (int blk = 0; blk < hidden_size / BS; blk++) {
                    const simd<fp16, N> gate_scl = convert<fp16>(gather<IT, N>(gate_s_base + blk, scl_byte_off));
                    const simd<fp16, N> up_scl   = convert<fp16>(gather<IT, N>(up_s_base   + blk, scl_byte_off));

                    for (int k_base = 0; k_base < BS / 2; k_base += 8) {
                        const int x_byte = blk * (BS / 2) + k_base;

                        // Gather input VNNI b-tile (16 elements per token)
                        const uint32_t k_off = (uint32_t)(blk * BS + k_base * 2) * (uint32_t)sizeof(IT);
                        simd<fp16, MS * 256> b_tile;
                        #pragma unroll
                        for (int ms = 0; ms < MS; ms++) {
                            simd<IT, 256> btmp;
                            btmp.template bit_cast_view<uint32_t>() =
                                xesimd::lsc_gather<uint32_t, 8,
                                    xesimd::lsc_data_size::u32,
                                    xesimd::cache_hint::cached, xesimd::cache_hint::cached,
                                    16, uint32_t>(
                                    reinterpret_cast<const uint32_t*>(input),
                                    in_off.template select<16, 1>(ms * 16).read() + k_off);
                            b_tile.template select<256, 1>(ms * 256) = convert<fp16>(btmp);
                        }

                        // Load weight [N,8] bytes, dequant int4, DPAS into acc
                        auto dequant_dpas = [&](const uint8_t* w_ptr, const simd<fp16, N>& scl,
                                                simd<fp16, ACC_SZ>& acc) SYCL_ESIMD_FUNCTION {
                            #pragma unroll
                            for (int ns = 0; ns < NS; ns++) {
                                auto w_raw = xesimd::lsc_load_2d<uint8_t, 8, 8, 1,
                                    false, false,
                                    xesimd::cache_hint::cached, xesimd::cache_hint::cached>(
                                    w_ptr,
                                    (unsigned)(hidden_size / 2 - 1),
                                    (unsigned)(N - 1),
                                    (unsigned)(hidden_size / 2 - 1),
                                    x_byte,
                                    ns * 8);

                                simd<uint8_t, 128> wu;
                                wu.template select<64, 2>(0) = w_raw & (uint8_t)0x0F;
                                wu.template select<64, 2>(1) = w_raw >> 4;
                                simd<fp16, 128> a_tile = wu.template bit_cast_view<int8_t>() - (int8_t)8;
                                #pragma unroll
                                for (int r = 0; r < 8; ++r) {
                                    a_tile.template select<16, 1>(r * 16) *= scl[ns * 8 + r];
                                }

                                #pragma unroll
                                for (int ms = 0; ms < MS; ms++) {
                                    const int idx = ms * NS * 128 + ns * 128;
                                    simd<fp16, 128> a = acc.template select<128, 1>(idx);
                                    simd<fp16, 256> bv = b_tile.template select<256, 1>(ms * 256);
                                    a = xmx_ns::dpas<8, 8, fp16, fp16, fp16, fp16>(a, bv, a_tile);
                                    acc.template select<128, 1>(idx) = a;
                                }
                            }
                        };

                        dequant_dpas(gate_w_ptr, gate_scl, g_acc);
                        dequant_dpas(up_w_ptr,   up_scl,   u_acc);
                    } // k_base
                } // blk

                // --- SiLU(gate) * up on full accumulator ---
                simd<fp16, ACC_SZ> sv =
                    (g_acc / (fp16(1) + sycl::ext::intel::esimd::exp(-g_acc))) * u_acc;

                // --- Scatter output (indexed by pair_idx) ---
                simd<uint32_t, MAX_M> out_off =
                    pair_idxs * (uint32_t)(intermediate_size * sizeof(IT));

                #pragma unroll
                for (int ms = 0; ms < MS; ms++) {
                    simd<uint32_t, 16> ms_off =
                        out_off.template select<16, 1>(ms * 16).read();

                    #pragma unroll
                    for (int r = 0; r < N; r++) {
                        uint32_t ch = (uint32_t)(r_base + r) * (uint32_t)sizeof(IT);
                        simd<IT, 16> val = sv.template select<16, 1>(ms * N * 16 + r * 16);
                        scatter<IT, 16>(intermediate, ms_off + ch, val);
                    }
                }
            } // m_base
        }); // parallel_for
    }); // submit
}

// ======================== moe_prefill_down_forward_kernel: Down projection (GGEMV style) ========================
template<typename IT, int BS, int MAX_M = 32, int N = 32>
sycl::event moe_prefill_down_forward_kernel(
    sycl::queue& q,
    const IT* intermediate, const uint8_t* down_weight, const IT* down_scale,
    IT* expert_output, const int* expert_offsets, const int* expert_tokens,
    int num_experts, int total_seqlen, int intermediate_size, int hidden_size)
{
    static_assert(MAX_M % 16 == 0, "MAX_M must be multiple of 16");
    static_assert(N % 8 == 0, "N must be multiple of 8");
    static_assert(BS % 32 == 0, "BS must be multiple of 32");
    constexpr int MS       = MAX_M / 16;
    constexpr int NS       = N / 8;
    constexpr int ACC_SZ   = MS * NS * 128;

    return q.submit([&](sycl::handler& cgh) {
        cgh.parallel_for(
            sycl::range<2>(num_experts, hidden_size / N),
            [=](sycl::id<2> id) SYCL_ESIMD_KERNEL {

            const int nblocks = intermediate_size / BS;
            const int eid   = (int)id[0];
            const int tid   = (int)id[1];
            const int d_base = tid * N;
            const int t0 = expert_offsets[eid];
            const int t1 = (eid + 1 < num_experts) ? expert_offsets[eid + 1] : total_seqlen;
            if (t0 == t1) return;

            const size_t row_base = (size_t)eid * hidden_size + d_base;
            const uint8_t* down_w_ptr = down_weight + row_base * (intermediate_size / 2);

            const simd<uint32_t, N> scl_byte_off =
                simd<uint32_t, N>(0u, 1u) * (uint32_t)(nblocks * sizeof(IT));
            const IT* down_s_base = down_scale + row_base * nblocks;

            for (int m_base = t0; m_base < t1; m_base += MAX_M) {
                // --- Load pair indices for input/output ---
                simd<uint32_t, MAX_M> sorted_idxs =
                    min(simd<uint32_t, MAX_M>(0u, 1u) + (uint32_t)m_base,
                        simd<uint32_t, MAX_M>((uint32_t)(t1 - 1)));
                simd<uint32_t, MAX_M> pair_idxs =
                    convert<uint32_t>(gather<int, MAX_M>(expert_tokens, sorted_idxs * 4u));
                simd<uint32_t, MAX_M> in_off =
                    pair_idxs * (uint32_t)(intermediate_size * sizeof(IT));

                simd<fp16, ACC_SZ> acc(fp16(0));

                for (int blk = 0; blk < intermediate_size / BS; blk++) {
                    const simd<fp16, N> down_scl = convert<fp16>(gather<IT, N>(down_s_base + blk, scl_byte_off));

                    for (int k_base = 0; k_base < BS / 2; k_base += 8) {
                        const int x_byte = blk * (BS / 2) + k_base;

                        // Gather input VNNI b-tile (16 elements per token)
                        const uint32_t k_off = (uint32_t)(blk * BS + k_base * 2) * (uint32_t)sizeof(IT);
                        simd<fp16, MS * 256> b_tile;
                        #pragma unroll
                        for (int ms = 0; ms < MS; ms++) {
                            simd<IT, 256> btmp;
                            btmp.template bit_cast_view<uint32_t>() =
                                xesimd::lsc_gather<uint32_t, 8,
                                    xesimd::lsc_data_size::u32,
                                    xesimd::cache_hint::cached, xesimd::cache_hint::cached,
                                    16, uint32_t>(
                                    reinterpret_cast<const uint32_t*>(intermediate),
                                    in_off.template select<16, 1>(ms * 16).read() + k_off);
                            b_tile.template select<256, 1>(ms * 256) = convert<fp16>(btmp);
                        }

                        // Load [N, 8] byte weight, dequant, DPAS
                        #pragma unroll
                        for (int ns = 0; ns < NS; ns++) {
                            auto dw_raw = xesimd::lsc_load_2d<uint8_t, 8, 8, 1,
                                false, false,
                                xesimd::cache_hint::cached, xesimd::cache_hint::cached>(
                                down_w_ptr,
                                (unsigned)(intermediate_size / 2 - 1),
                                (unsigned)(N - 1),
                                (unsigned)(intermediate_size / 2 - 1),
                                x_byte,
                                ns * 8);

                            // Interleaved int4: byte[i] = {elem[2i] lo, elem[2i+1] hi}
                            simd<uint8_t, 128> du;
                            du.template select<64, 2>(0) = dw_raw & (uint8_t)0x0F;
                            du.template select<64, 2>(1) = dw_raw >> 4;
                            simd<fp16, 128> a_tile = du.template bit_cast_view<int8_t>() - (int8_t)8;
                            #pragma unroll
                            for (int r = 0; r < 8; ++r) {
                                a_tile.template select<16, 1>(r * 16) *= down_scl[ns * 8 + r];
                            }

                            // DPAS: one block per step
                            #pragma unroll
                            for (int ms = 0; ms < MS; ms++) {
                                const int idx = ms * NS * 128 + ns * 128;
                                simd<fp16, 256> bv = b_tile.template select<256, 1>(ms * 256);

                                simd<fp16, 128> a = acc.template select<128, 1>(idx);
                                a = xmx_ns::dpas<8, 8, fp16, fp16, fp16, fp16>(a, bv, a_tile);
                                acc.template select<128, 1>(idx) = a;
                            }
                        } // ns
                    } // k_base
                } // blk

                // --- Store: scatter (indexed by pair_idx) ---
                simd<uint32_t, MAX_M> out_off =
                    pair_idxs * (uint32_t)(hidden_size * sizeof(IT));

                #pragma unroll
                for (int ms = 0; ms < MS; ms++) {
                    simd<uint32_t, 16> ms_off =
                        out_off.template select<16, 1>(ms * 16).read();

                    #pragma unroll
                    for (int r = 0; r < N; r++) {
                        simd<IT, 16> rv = acc.template select<16, 1>(ms * N * 16 + r * 16);
                        uint32_t ch = (uint32_t)(d_base + r) * (uint32_t)sizeof(IT);
                        scatter<IT, 16>(expert_output, ms_off + ch, rv);
                    }
                }
            } // m_base

        }); // parallel_for
    }); // submit
}

// ======================== moe_prefill_accumulate_forward_kernel: Accumulate ========================
template<typename IT>
sycl::event moe_prefill_accumulate_forward_kernel(
    sycl::queue& q,
    const IT* output, const IT* routing_weights, IT* routing_output,
    int num_tokens, int hidden_size, int top_k)
{
    return q.submit([&](sycl::handler& cgh) {
        cgh.parallel_for(
            sycl::range<1>(num_tokens),
            [=](sycl::id<1> id) SYCL_ESIMD_KERNEL {
                const int tok = (int)id[0];
                for (int hoff = 0; hoff < hidden_size; hoff += 64) {
                    simd<float, 64> acc(0.f);
                    for (int s = 0; s < top_k; s++) {
                        float w = (float)routing_weights[tok * top_k + s];
                        int pi = tok * top_k + s;
                        acc += w * convert<float>(
                            block_load<IT, 64>(output + (size_t)pi * hidden_size + hoff));
                    }
                    block_store<IT, 64>(routing_output + (size_t)tok * hidden_size + hoff, convert<IT>(acc));
                }
            });
    });
}

// ======================== Torch Wrappers ========================

std::vector<torch::Tensor> moe_prefill_gather_forward_v2(
    torch::Tensor selected_experts,
    int64_t num_experts) {

    TORCH_CHECK(selected_experts.dim() == 2);
    TORCH_CHECK(selected_experts.scalar_type() == torch::kInt32);

    int top_k = selected_experts.size(1);
    int total_seqlen = selected_experts.numel();

    auto opts_int = torch::device(selected_experts.device()).dtype(torch::kInt32);
    torch::Tensor expert_offsets = torch::empty({num_experts}, opts_int);
    torch::Tensor expert_tokens = torch::empty({total_seqlen}, opts_int);

    sycl::queue& queue = c10::xpu::getCurrentXPUStream(selected_experts.device().index()).queue();

    moe_prefill_gather_forward_kernel(
        queue,
        selected_experts.data_ptr<int>(),
        expert_offsets.data_ptr<int>(),
        expert_tokens.data_ptr<int>(),
        num_experts, total_seqlen);

    return {expert_offsets, expert_tokens};
}

torch::Tensor moe_prefill_up_forward_v2(
    torch::Tensor x,
    torch::Tensor gate_up_weight,
    torch::Tensor gate_up_scale,
    torch::Tensor expert_offsets,
    torch::Tensor expert_tokens,
    int64_t top_k) {

    TORCH_CHECK(x.dim() == 2);
    TORCH_CHECK(gate_up_weight.dim() == 3);
    TORCH_CHECK(gate_up_weight.scalar_type() == torch::kByte);
    TORCH_CHECK(x.scalar_type() == gate_up_scale.scalar_type());
    TORCH_CHECK(expert_offsets.scalar_type() == torch::kInt32);
    TORCH_CHECK(expert_tokens.scalar_type() == torch::kInt32);

    int num_experts = gate_up_weight.size(0);
    int intermediate_size = gate_up_weight.size(1) / 2;
    int hidden_size = x.size(1);
    int total_seqlen = expert_tokens.numel();

    TORCH_CHECK(hidden_size % 64 == 0, "hidden_size must be multiple of 64");
    TORCH_CHECK(intermediate_size % 64 == 0, "intermediate_size must be multiple of 64");
    TORCH_CHECK(gate_up_weight.size(2) == hidden_size / 2);
    TORCH_CHECK(gate_up_scale.size(1) == 2 * intermediate_size);

    torch::Tensor intermediate = torch::empty(
        {total_seqlen, intermediate_size},
        torch::device(x.device()).dtype(x.scalar_type()));

    sycl::queue& queue = c10::xpu::getCurrentXPUStream(x.device().index()).queue();

    switch (x.scalar_type()) {
        case at::kHalf:
            moe_prefill_up_forward_kernel<fp16, 128>(
                queue,
                (const fp16*)x.data_ptr(),
                (const uint8_t*)gate_up_weight.data_ptr(),
                (const fp16*)gate_up_scale.data_ptr(),
                (fp16*)intermediate.data_ptr(),
                expert_offsets.data_ptr<int>(),
                expert_tokens.data_ptr<int>(),
                num_experts, total_seqlen, hidden_size, intermediate_size, top_k);
            break;
        case at::kBFloat16:
            moe_prefill_up_forward_kernel<bf16, 128>(
                queue,
                (const bf16*)x.data_ptr(),
                (const uint8_t*)gate_up_weight.data_ptr(),
                (const bf16*)gate_up_scale.data_ptr(),
                (bf16*)intermediate.data_ptr(),
                expert_offsets.data_ptr<int>(),
                expert_tokens.data_ptr<int>(),
                num_experts, total_seqlen, hidden_size, intermediate_size, top_k);
            break;
        default:
            TORCH_CHECK(false, "unsupported dtype (expected fp16 or bf16)");
    }

    return intermediate;
}

torch::Tensor moe_prefill_down_forward_v2(
    torch::Tensor intermediate,
    torch::Tensor down_weight,
    torch::Tensor down_scale,
    torch::Tensor expert_offsets,
    torch::Tensor expert_tokens) {

    TORCH_CHECK(intermediate.dim() == 2);
    TORCH_CHECK(down_weight.dim() == 3);
    TORCH_CHECK(down_weight.scalar_type() == torch::kByte);
    TORCH_CHECK(intermediate.scalar_type() == down_scale.scalar_type());
    TORCH_CHECK(expert_offsets.scalar_type() == torch::kInt32);
    TORCH_CHECK(expert_tokens.scalar_type() == torch::kInt32);

    int num_experts = down_weight.size(0);
    int hidden_size = down_weight.size(1);
    int intermediate_size = intermediate.size(1);
    int total_seqlen = expert_tokens.numel();

    TORCH_CHECK(intermediate_size % 64 == 0, "intermediate_size must be multiple of 64");
    TORCH_CHECK(hidden_size % 64 == 0, "hidden_size must be multiple of 64");

    torch::Tensor expert_output = torch::empty(
        {total_seqlen, hidden_size},
        torch::device(intermediate.device()).dtype(intermediate.scalar_type()));

    sycl::queue& queue = c10::xpu::getCurrentXPUStream(intermediate.device().index()).queue();

    switch (intermediate.scalar_type()) {
        case at::kHalf:
            moe_prefill_down_forward_kernel<fp16, 128>(
                queue,
                (const fp16*)intermediate.data_ptr(),
                (const uint8_t*)down_weight.data_ptr(),
                (const fp16*)down_scale.data_ptr(),
                (fp16*)expert_output.data_ptr(),
                expert_offsets.data_ptr<int>(),
                expert_tokens.data_ptr<int>(),
                num_experts, total_seqlen, intermediate_size, hidden_size);
            break;
        case at::kBFloat16:
            moe_prefill_down_forward_kernel<bf16, 128>(
                queue,
                (const bf16*)intermediate.data_ptr(),
                (const uint8_t*)down_weight.data_ptr(),
                (const bf16*)down_scale.data_ptr(),
                (bf16*)expert_output.data_ptr(),
                expert_offsets.data_ptr<int>(),
                expert_tokens.data_ptr<int>(),
                num_experts, total_seqlen, intermediate_size, hidden_size);
            break;
        default:
            TORCH_CHECK(false, "unsupported dtype (expected fp16 or bf16)");
    }

    return expert_output;
}

torch::Tensor moe_prefill_accumulate_forward_v2(
    torch::Tensor output,
    torch::Tensor routing_weights) {

    TORCH_CHECK(output.dim() == 2);
    TORCH_CHECK(routing_weights.dim() == 2);
    TORCH_CHECK(routing_weights.scalar_type() == output.scalar_type());

    int num_tokens = routing_weights.size(0);
    int top_k = routing_weights.size(1);
    int hidden_size = output.size(1);

    torch::Tensor routing_output = torch::empty(
        {num_tokens, hidden_size},
        torch::device(output.device()).dtype(output.scalar_type()));

    sycl::queue& queue = c10::xpu::getCurrentXPUStream(output.device().index()).queue();

    switch (output.scalar_type()) {
        case at::kHalf:
            moe_prefill_accumulate_forward_kernel<fp16>(
                queue,
                (const fp16*)output.data_ptr(),
                (const fp16*)routing_weights.data_ptr(),
                (fp16*)routing_output.data_ptr(),
                num_tokens, hidden_size, top_k);
            break;
        case at::kBFloat16:
            moe_prefill_accumulate_forward_kernel<bf16>(
                queue,
                (const bf16*)output.data_ptr(),
                (const bf16*)routing_weights.data_ptr(),
                (bf16*)routing_output.data_ptr(),
                num_tokens, hidden_size, top_k);
            break;
        default:
            TORCH_CHECK(false, "unsupported dtype (expected fp16 or bf16)");
    }

    return routing_output;
}

// ======================== Unified host function ========================

#include "../xpu/esimd_kernels/moe_ops.h"  // TopK V2

torch::Tensor moe_prefill_full_int4(
    torch::Tensor x,                    // [M, H] fp16
    torch::Tensor router_logits,        // [M, E] fp16
    torch::Tensor gate_up_weight,       // [E, 2*D, K/2] uint8 (GGML)
    torch::Tensor gate_up_scale,        // [E, 2*D, K/BS] fp16
    torch::Tensor down_weight,          // [E, H, D/2] uint8 (GGML)
    torch::Tensor down_scale,           // [E, H, D/BS] fp16
    int64_t top_k, int64_t n_routed_experts)
{
    TORCH_CHECK(x.scalar_type() == torch::kHalf);

    int n_tokens = x.size(0);
    int hidden_size = x.size(1);
    int num_experts = (int)n_routed_experts;

    sycl::queue& queue = c10::xpu::getCurrentXPUStream(x.device().index()).queue();

    // 1. TopK: softmax + topk selection
    auto topk_values = torch::empty({n_tokens, (int)top_k},
        torch::device(x.device()).dtype(torch::kHalf));
    auto topk_indices = torch::empty({n_tokens, (int)top_k},
        torch::device(x.device()).dtype(torch::kInt32));

    if (num_experts == 256 && top_k == 8) {
        moe_topk_v2_host<256, 8>(
            (const fp16*)router_logits.data_ptr(),
            (fp16*)topk_values.data_ptr(),
            topk_indices.data_ptr<int32_t>(),
            n_tokens, queue);
    } else {
        TORCH_CHECK(false, "moe_prefill_full_int4: unsupported (E=", num_experts,
                    ", top_k=", top_k, ") — add template to TopK V2");
    }

    // 2. Gather: compute expert_offsets + expert_tokens
    auto gather_result = moe_prefill_gather_forward_v2(topk_indices, n_routed_experts);
    auto expert_offsets = gather_result[0];
    auto expert_tokens = gather_result[1];

    // 3. Up GEMM: gate_up projection + SiLU
    auto intermediate = moe_prefill_up_forward_v2(
        x, gate_up_weight, gate_up_scale,
        expert_offsets, expert_tokens, top_k);

    // 4. Down GEMM: down projection
    auto expert_output = moe_prefill_down_forward_v2(
        intermediate, down_weight, down_scale,
        expert_offsets, expert_tokens);

    // 5. Accumulate: weighted gather
    auto final_output = moe_prefill_accumulate_forward_v2(
        expert_output, topk_values);

    return final_output;
}

// ======================== Registration ========================

TORCH_LIBRARY_FRAGMENT(moe_int4_prefill_ops, m) {
    m.def("moe_prefill_full_int4(Tensor x, Tensor router_logits, "
          "Tensor gate_up_weight, Tensor gate_up_scale, "
          "Tensor down_weight, Tensor down_scale, "
          "int top_k, int n_routed_experts) -> Tensor");
    m.def("moe_prefill_gather_forward_v2(Tensor selected_experts, "
          "int num_experts) -> Tensor[]");
    m.def("moe_prefill_up_forward_v2(Tensor x, Tensor gate_up_weight, "
          "Tensor gate_up_scale, Tensor expert_offsets, "
          "Tensor expert_tokens, int top_k) -> Tensor");
    m.def("moe_prefill_down_forward_v2(Tensor intermediate, "
          "Tensor down_weight, Tensor down_scale, "
          "Tensor expert_offsets, Tensor expert_tokens) -> Tensor");
    m.def("moe_prefill_accumulate_forward_v2(Tensor output, "
          "Tensor routing_weights) -> Tensor");
}

TORCH_LIBRARY_IMPL(moe_int4_prefill_ops, XPU, m) {
    m.impl("moe_prefill_full_int4", &moe_prefill_full_int4);
    m.impl("moe_prefill_gather_forward_v2", &moe_prefill_gather_forward_v2);
    m.impl("moe_prefill_up_forward_v2", &moe_prefill_up_forward_v2);
    m.impl("moe_prefill_down_forward_v2", &moe_prefill_down_forward_v2);
    m.impl("moe_prefill_accumulate_forward_v2", &moe_prefill_accumulate_forward_v2);
}

PYBIND11_MODULE(TORCH_EXTENSION_NAME, m) {
    m.def("moe_prefill_full_int4", &moe_prefill_full_int4);
    m.def("moe_prefill_gather_forward_v2", &moe_prefill_gather_forward_v2);
    m.def("moe_prefill_up_forward_v2", &moe_prefill_up_forward_v2);
    m.def("moe_prefill_down_forward_v2", &moe_prefill_down_forward_v2);
    m.def("moe_prefill_accumulate_forward_v2", &moe_prefill_accumulate_forward_v2);
}
