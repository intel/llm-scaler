// ═══════════════════════════════════════════════════════════════════════════════
// INT4 ESIMD MOE Kernels for Qwen3.5-35B-A3B (sym_int4 quantization)
//
// Weight format: GGML Q4_0 — 8 INT4 nibbles packed per int32, per-group fp16
// scale with group_size=128. Dequant: float_val = (nibble_unsigned - 8) * scale.
//
// IPEX GatedMLPMOE modifies expert weights IN-PLACE from [E, N, K_packed] to
// [E, K_packed, N] (contiguous, physically moved). This kernel reads IPEX's
// format directly — no weight cloning needed.
//
// Router uses IPEX's IPEXWeightOnlyQuantizedLinear (gate weight is internally
// repacked by IPEX in a format we don't replicate).
//
// Shared expert weights: FP16 (NOT quantized, no scale).
// ═══════════════════════════════════════════════════════════════════════════════

#include <torch/extension.h>
#include <c10/xpu/XPUStream.h>
#include <sycl/ext/intel/esimd.hpp>
#include <sycl/ext/intel/experimental/esimd/memory.hpp>

#include "moe_topk.h"
#include "../xpu/esimd_kernels/moe_ops.h"  // TopK V2 vectorized argmax

using fp16 = sycl::half;
using namespace sycl::ext::intel::esimd;
using namespace sycl::ext::intel::esimd::xmx;
namespace xesimd = sycl::ext::intel::experimental::esimd;

static inline sycl::event submit_kernel(
    std::function<void(sycl::handler&)> kernel,
    const torch::Device& device,
    const char* desc) {
    sycl::queue& queue = c10::xpu::getCurrentXPUStream(device.index()).queue();
    return queue.submit(kernel);
}

// ═══════════════════════════════════════════════════════════════════════════════
// Router GEMV (INT4)
// ═══════════════════════════════════════════════════════════════════════════════
// Gate weight after IPEX: physically transposed to [E, K_packed] in memory.
// Gate scale: NOT modified by IPEX, remains [K_groups, E] — kernel reads with stride.
// Weight: [num_experts, hidden_size//8] int32 (packed, row per expert)
// Scale:  [hidden_size//128, num_experts] fp16 (K_groups-major, NOT transposed)

// -- Option A: weight-reuse, 1 WI per expert, n_tokens <= 4 --
void moe_router_forward_int4_kernel(
    const fp16* x,
    const uint32_t* weight,
    const fp16* scale,
    fp16* output,
    const int n_tokens, const int hidden_size, const int num_experts,
    const bool ggml_layout,
    const torch::Device& device) {

    const int K_packed = hidden_size / 8;
    const int n_groups = hidden_size / 128;

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeRouterForwardInt4>(
            sycl::range<1>(num_experts),
            [=](sycl::id<1> idx) SYCL_ESIMD_KERNEL {
                const int row = (int)idx[0];
                const uint32_t* w_row = weight + (size_t)row * K_packed;

                simd<float, 64> acc0(0.f), acc1(0.f), acc2(0.f), acc3(0.f);

                for (int k = 0; k < hidden_size; k += 64) {
                    int kp = k / 8;
                    int gi = k / 128;
                    // IPEX: scale [K_groups, E], GGML: scale [E, K_groups]
                    fp16 s = ggml_layout ? scale[row * n_groups + gi]
                                         : scale[gi * num_experts + row];

                    simd<uint32_t, 8> packed = block_load<uint32_t, 8>(w_row + kp);
                    simd<fp16, 64> wv;
                    #pragma unroll
                    for (int i = 0; i < 8; i++) {
                        simd<uint32_t, 8> bcast(packed[i]);
                        simd<uint32_t, 8> shifts;
                        shifts[0]=0; shifts[1]=4; shifts[2]=8; shifts[3]=12;
                        shifts[4]=16; shifts[5]=20; shifts[6]=24; shifts[7]=28;
                        simd<uint32_t, 8> nibs = (bcast >> shifts) & 0xFu;
                        simd<float, 8> dq = (convert<float>(nibs) - 8.f) * (float)s;
                        wv.template select<8, 1>(i * 8) = convert<fp16>(dq);
                    }

                    simd<fp16, 64> xv0 = block_load<fp16, 64>(x + k);
                    acc0 += convert<float>(xv0 * wv);
                    if (n_tokens > 1) {
                        simd<fp16, 64> xv1 = block_load<fp16, 64>(x + (size_t)1 * hidden_size + k);
                        acc1 += convert<float>(xv1 * wv);
                    }
                    if (n_tokens > 2) {
                        simd<fp16, 64> xv2 = block_load<fp16, 64>(x + (size_t)2 * hidden_size + k);
                        acc2 += convert<float>(xv2 * wv);
                    }
                    if (n_tokens > 3) {
                        simd<fp16, 64> xv3 = block_load<fp16, 64>(x + (size_t)3 * hidden_size + k);
                        acc3 += convert<float>(xv3 * wv);
                    }
                }

                output[0 * num_experts + row] = fp16(sycl::ext::intel::esimd::detail::sum<float, float, 64>(acc0));
                if (n_tokens > 1)
                    output[1 * num_experts + row] = fp16(sycl::ext::intel::esimd::detail::sum<float, float, 64>(acc1));
                if (n_tokens > 2)
                    output[2 * num_experts + row] = fp16(sycl::ext::intel::esimd::detail::sum<float, float, 64>(acc2));
                if (n_tokens > 3)
                    output[3 * num_experts + row] = fp16(sycl::ext::intel::esimd::detail::sum<float, float, 64>(acc3));
            });
    };
    submit_kernel(cgf, device, "moe router forward int4");
}

// -- Option C: 1 WI per (token, expert), n_tokens > 4 --
void moe_router_forward_int4_wide_kernel(
    const fp16* x,
    const uint32_t* weight,
    const fp16* scale,
    fp16* output,
    const int n_tokens, const int hidden_size, const int num_experts,
    const bool ggml_layout,
    const torch::Device& device) {

    const int K_packed = hidden_size / 8;
    const int n_groups = hidden_size / 128;

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeRouterForwardInt4Wide>(
            sycl::range<2>(n_tokens, num_experts),
            [=](sycl::id<2> idx) SYCL_ESIMD_KERNEL {
                const int token = (int)idx[0];
                const int row   = (int)idx[1];
                const uint32_t* w_row = weight + (size_t)row * K_packed;

                simd<float, 64> acc(0.f);
                for (int k = 0; k < hidden_size; k += 64) {
                    int kp = k / 8;
                    int gi = k / 128;
                    fp16 s = ggml_layout ? scale[row * n_groups + gi]
                                         : scale[gi * num_experts + row];

                    simd<uint32_t, 8> packed = block_load<uint32_t, 8>(w_row + kp);
                    simd<fp16, 64> wv;
                    #pragma unroll
                    for (int i = 0; i < 8; i++) {
                        simd<uint32_t, 8> bcast(packed[i]);
                        simd<uint32_t, 8> shifts;
                        shifts[0]=0; shifts[1]=4; shifts[2]=8; shifts[3]=12;
                        shifts[4]=16; shifts[5]=20; shifts[6]=24; shifts[7]=28;
                        simd<uint32_t, 8> nibs = (bcast >> shifts) & 0xFu;
                        simd<float, 8> dq = (convert<float>(nibs) - 8.f) * (float)s;
                        wv.template select<8, 1>(i * 8) = convert<fp16>(dq);
                    }

                    simd<fp16, 64> xv = block_load<fp16, 64>(
                        x + (size_t)token * hidden_size + k);
                    acc += convert<float>(xv * wv);
                }

                output[token * num_experts + row] = fp16(
                    sycl::ext::intel::esimd::detail::sum<float, float, 64>(acc));
            });
    };
    submit_kernel(cgf, device, "moe router forward int4 wide");
}

// -- Host dispatch --
torch::Tensor moe_router_forward_int4(
    torch::Tensor x,
    torch::Tensor weight,
    torch::Tensor scale,
    bool use_ggml_layout) {

    TORCH_CHECK(x.dim() == 2 && x.is_contiguous() && x.scalar_type() == torch::kHalf);
    TORCH_CHECK(weight.scalar_type() == torch::kInt || weight.scalar_type() == torch::kByte);
    TORCH_CHECK(scale.scalar_type() == torch::kHalf);

    int n_tokens = x.size(0);
    int hidden_size = x.size(1);
    int K_packed = hidden_size / 8;

    TORCH_CHECK(hidden_size % 128 == 0);

    int num_experts;
    int K_groups = hidden_size / 128;

    if (use_ggml_layout) {
        // GGML layout: weight_esimd [E, K/2] uint8 → view as int32 gives [E, K/8]
        // Or already [E, K/8] int32. scale_esimd [E, K_groups] fp16.
        // Weight: if uint8, view as int32 first
        if (weight.scalar_type() == torch::kByte) {
            weight = weight.view(torch::kInt);
        }
        num_experts = weight.size(0);
        // weight is already [E, K_packed] contiguous
        TORCH_CHECK(weight.size(1) == K_packed,
            "gate weight shape mismatch: got [", weight.size(0), ", ", weight.size(1),
            "], expected [num_experts, ", K_packed, "]");
        // scale is [E, K_groups] — kernel reads as scale[row * n_groups + gi]
        TORCH_CHECK(scale.size(0) == num_experts && scale.size(1) == K_groups,
            "gate scale shape mismatch: got [", scale.size(0), ", ", scale.size(1),
            "], expected [", num_experts, ", ", K_groups, "]");
    } else {
        // IPEX layout: weight may be [K_packed, E] column-major repacked
        num_experts = weight.numel() / K_packed;
        weight = weight.reshape({num_experts, K_packed});
        TORCH_CHECK(weight.size(1) == K_packed,
            "gate weight shape mismatch: got [", weight.size(0), ", ", weight.size(1),
            "], expected [num_experts, ", K_packed, "]");
        // Scale: [K_groups, E]
        if (scale.size(0) != K_groups || scale.size(1) != num_experts) {
            if (scale.numel() == K_groups * num_experts) {
                scale = scale.reshape({K_groups, num_experts});
            }
        }
        TORCH_CHECK(scale.size(0) == K_groups && scale.size(1) == num_experts,
            "gate scale shape mismatch: got [", scale.size(0), ", ", scale.size(1),
            "], expected [", K_groups, ", ", num_experts, "]");
    }

    torch::Tensor output = torch::empty({n_tokens, num_experts},
        torch::device(x.device()).dtype(torch::kHalf));

    if (n_tokens <= 4) {
        moe_router_forward_int4_kernel(
            (const fp16*)x.data_ptr(), (const uint32_t*)weight.data_ptr(),
            (const fp16*)scale.data_ptr(), (fp16*)output.data_ptr(),
            n_tokens, hidden_size, num_experts, use_ggml_layout, x.device());
    } else {
        moe_router_forward_int4_wide_kernel(
            (const fp16*)x.data_ptr(), (const uint32_t*)weight.data_ptr(),
            (const fp16*)scale.data_ptr(), (fp16*)output.data_ptr(),
            n_tokens, hidden_size, num_experts, use_ggml_layout, x.device());
    }
    return output;
}

// ═══════════════════════════════════════════════════════════════════════════════
// Kernel 1: Fused Gate+Up+SiLU — Routed experts (INT4, IPEX K-major + marlin shuffled)
// ═══════════════════════════════════════════════════════════════════════════════
// Weight layout (IPEX): [E, K_packed, 2*d_ff] int32, marlin shuffled nibbles
// Scale layout (IPEX):  [E, K_groups, 2*d_ff] fp16
// 1 WI computes 16 consecutive outputs along N (contiguous in IPEX layout)

void moe_up_routed_int4_kernel(
    const fp16* x,
    const uint32_t* gate_up_qweight,  // IPEX: [E, K_packed, 2*d_ff] or GGML: [E, 2*d_ff, K_packed]
    const fp16* gate_up_scales,       // IPEX: [E, K_groups, 2*d_ff] or GGML: [E, 2*d_ff, K_groups]
    const int* selected_experts,
    fp16* intermediates,
    const int n_tokens, const int hidden_size, const int intermediate_size,
    const int top_k, const int rows_per_token,
    const bool ggml_layout,
    const torch::Device& device) {

    const int K_packed = hidden_size / 8;
    const int K_groups = hidden_size / 128;
    const int two_dff = 2 * intermediate_size;
    const int n_out_tiles = intermediate_size / 16;

    if (ggml_layout) {
        // GGML N-major: weight [E, 2*d_ff, K_packed], scale [E, 2*d_ff, K_groups]
        // Each WI computes 1 gate + 1 up output (scalar per N), vectorize along K
        auto cgf = [&](sycl::handler& cgh) {
            cgh.parallel_for<class MoeUpRoutedInt4GGML>(
                sycl::range<2>(n_tokens * top_k, intermediate_size),
                [=](sycl::id<2> idx) SYCL_ESIMD_KERNEL {
                    const int route_idx = (int)idx[0];
                    const int n_col     = (int)idx[1];
                    const int token     = route_idx / top_k;
                    const int k_idx     = route_idx % top_k;

                    const int eid = selected_experts[route_idx];
                    const fp16* x_row = x + (size_t)token * hidden_size;

                    const uint32_t* w_base = gate_up_qweight + (size_t)eid * two_dff * K_packed;
                    const fp16* s_base = gate_up_scales + (size_t)eid * two_dff * K_groups;

                    const uint32_t* g_row = w_base + (size_t)n_col * K_packed;
                    const uint32_t* u_row = w_base + (size_t)(intermediate_size + n_col) * K_packed;
                    const fp16* g_s_row = s_base + (size_t)n_col * K_groups;
                    const fp16* u_s_row = s_base + (size_t)(intermediate_size + n_col) * K_groups;

                    float g_acc = 0.f, u_acc = 0.f;
                    for (int kp = 0; kp < K_packed; kp++) {
                        uint32_t g_packed = g_row[kp];
                        uint32_t u_packed = u_row[kp];
                        int gi = kp / 16;
                        fp16 g_scale = g_s_row[gi];
                        fp16 u_scale = u_s_row[gi];

                        #pragma unroll
                        for (int b = 0; b < 8; b++) {
                            float g_val = (float(((g_packed >> (b * 4)) & 0xFu)) - 8.f) * (float)g_scale;
                            float u_val = (float(((u_packed >> (b * 4)) & 0xFu)) - 8.f) * (float)u_scale;
                            float xv = (float)x_row[kp * 8 + b];
                            g_acc += g_val * xv;
                            u_acc += u_val * xv;
                        }
                    }

                    float silu = g_acc / (1.f + sycl::exp(-g_acc));
                    const int routed_row = token * rows_per_token + k_idx;
                    intermediates[(size_t)routed_row * intermediate_size + n_col] = fp16(silu * u_acc);
                });
        };
        submit_kernel(cgf, device, "moe up routed int4 ggml");
    } else {
        // IPEX K-major: weight [E, K_packed, 2*d_ff], scale [E, K_groups, 2*d_ff]
        // Optimized: 64-wide tiles (2×32), preload x with block_load<fp16,8>
        const int n_out_tiles_ipex = intermediate_size / 64;
        auto cgf = [&](sycl::handler& cgh) {
            cgh.parallel_for<class MoeUpRoutedInt4>(
                sycl::range<2>(n_tokens * top_k, n_out_tiles_ipex),
                [=](sycl::id<2> idx) SYCL_ESIMD_KERNEL {
                    const int route_idx = (int)idx[0];
                    const int tile_idx  = (int)idx[1];
                    const int token     = route_idx / top_k;
                    const int k_idx     = route_idx % top_k;
                    const int n_start   = tile_idx * 64;

                    const int eid = selected_experts[route_idx];
                    const fp16* x_row = x + (size_t)token * hidden_size;

                    const uint32_t* w_base = gate_up_qweight + (size_t)eid * K_packed * two_dff;
                    const fp16* s_base = gate_up_scales + (size_t)eid * K_groups * two_dff;

                    const int g0 = n_start, g1 = n_start + 32;
                    const int u0 = intermediate_size + n_start, u1 = u0 + 32;

                    simd<float, 32> ga0(0.f), ga1(0.f), ua0(0.f), ua1(0.f);

                    constexpr int unshuffle[8] = {0, 2, 4, 6, 1, 3, 5, 7};

                    for (int kp = 0; kp < K_packed; kp++) {
                        simd<fp16, 8> x_chunk = block_load<fp16, 8>(x_row + kp * 8);

                        simd<uint32_t, 32> gp0 = block_load<uint32_t, 32>(w_base + (size_t)kp * two_dff + g0);
                        simd<uint32_t, 32> gp1 = block_load<uint32_t, 32>(w_base + (size_t)kp * two_dff + g1);
                        simd<uint32_t, 32> up0 = block_load<uint32_t, 32>(w_base + (size_t)kp * two_dff + u0);
                        simd<uint32_t, 32> up1 = block_load<uint32_t, 32>(w_base + (size_t)kp * two_dff + u1);

                        int kg = kp / 16;
                        simd<fp16, 32> gs0 = block_load<fp16, 32>(s_base + (size_t)kg * two_dff + g0);
                        simd<fp16, 32> gs1 = block_load<fp16, 32>(s_base + (size_t)kg * two_dff + g1);
                        simd<fp16, 32> us0 = block_load<fp16, 32>(s_base + (size_t)kg * two_dff + u0);
                        simd<fp16, 32> us1 = block_load<fp16, 32>(s_base + (size_t)kg * two_dff + u1);

                        #pragma unroll
                        for (int b = 0; b < 8; b++) {
                            int shift = unshuffle[b] * 4;
                            float xv = (float)(fp16)x_chunk[b];

                            ga0 += (convert<float>((gp0 >> shift) & 0xFu) - 8.f) * convert<float>(gs0) * xv;
                            ga1 += (convert<float>((gp1 >> shift) & 0xFu) - 8.f) * convert<float>(gs1) * xv;
                            ua0 += (convert<float>((up0 >> shift) & 0xFu) - 8.f) * convert<float>(us0) * xv;
                            ua1 += (convert<float>((up1 >> shift) & 0xFu) - 8.f) * convert<float>(us1) * xv;
                        }
                    }

                    const int routed_row = token * rows_per_token + k_idx;
                    fp16* out = intermediates + (size_t)routed_row * intermediate_size + n_start;
                    block_store<fp16, 32>(out,      convert<fp16>(ga0 / (1.f + exp(-ga0)) * ua0));
                    block_store<fp16, 32>(out + 32, convert<fp16>(ga1 / (1.f + exp(-ga1)) * ua1));
                });
        };
        submit_kernel(cgf, device, "moe up routed int4");
    }
}

// ── SLM reduction version: GS work-items cooperate on 16 outputs ────────────
// Used when WI count is too low (small D or small batch).
// GS WIs split the K-loop, accumulate partial sums in SLM, then reduce.

void moe_up_routed_int4_slm_kernel(
    const fp16* x,
    const uint32_t* gate_up_qweight,
    const fp16* gate_up_scales,
    const int* selected_experts,
    fp16* intermediates,
    const int n_tokens, const int hidden_size, const int intermediate_size,
    const int top_k, const int rows_per_token,
    const bool ggml_layout,
    const torch::Device& device) {

    // GGML layout: N-major, no block_load<16> along N possible — delegate to non-SLM path
    if (ggml_layout) {
        moe_up_routed_int4_kernel(x, gate_up_qweight, gate_up_scales,
            selected_experts, intermediates, n_tokens, hidden_size,
            intermediate_size, top_k, rows_per_token, true, device);
        return;
    }

    const int K_packed = hidden_size / 8;
    const int K_groups = hidden_size / 128;
    const int two_dff = 2 * intermediate_size;
    const int n_out_tiles = intermediate_size / 16;
    constexpr int GS = 16;

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeUpRoutedInt4SLM>(
            sycl::nd_range<2>(
                sycl::range<2>(n_tokens * top_k, n_out_tiles * GS),
                sycl::range<2>(1, GS)),
            [=](sycl::nd_item<2> item) SYCL_ESIMD_KERNEL {
                slm_init<GS * 2 * 16 * sizeof(float)>();

                const int route_idx = (int)item.get_global_id(0);
                const int tile_idx  = (int)item.get_group(1);
                const int tid       = (int)item.get_local_id(1);
                const int token     = route_idx / top_k;
                const int k_idx     = route_idx % top_k;
                const int n_start   = tile_idx * 16;

                const int eid = selected_experts[route_idx];
                const fp16* x_row = x + (size_t)token * hidden_size;

                const uint32_t* w_base = gate_up_qweight + (size_t)eid * K_packed * two_dff;
                const fp16* s_base = gate_up_scales + (size_t)eid * K_groups * two_dff;

                const int g_offset = n_start;
                const int u_offset = intermediate_size + n_start;

                constexpr int unshuffle[8] = {0, 2, 4, 6, 1, 3, 5, 7};

                simd<float, 16> gate_acc(0.f), up_acc(0.f);
                for (int kp = tid; kp < K_packed; kp += GS) {
                    simd<fp16, 8> x_chunk = block_load<fp16, 8>(x_row + kp * 8);
                    simd<uint32_t, 16> g_packed = block_load<uint32_t, 16>(
                        w_base + (size_t)kp * two_dff + g_offset);
                    simd<uint32_t, 16> u_packed = block_load<uint32_t, 16>(
                        w_base + (size_t)kp * two_dff + u_offset);

                    int kg = kp / 16;
                    simd<fp16, 16> g_scale = block_load<fp16, 16>(
                        s_base + (size_t)kg * two_dff + g_offset);
                    simd<fp16, 16> u_scale = block_load<fp16, 16>(
                        s_base + (size_t)kg * two_dff + u_offset);

                    #pragma unroll
                    for (int b = 0; b < 8; b++) {
                        int nib_pos = unshuffle[b];
                        simd<uint32_t, 16> g_nib = (g_packed >> (nib_pos * 4)) & 0xFu;
                        simd<uint32_t, 16> u_nib = (u_packed >> (nib_pos * 4)) & 0xFu;

                        simd<float, 16> g_dq = (convert<float>(g_nib) - 8.f) * convert<float>(g_scale);
                        simd<float, 16> u_dq = (convert<float>(u_nib) - 8.f) * convert<float>(u_scale);

                        float xv = (float)(fp16)x_chunk[b];
                        gate_acc += g_dq * xv;
                        up_acc   += u_dq * xv;
                    }
                }

                uint32_t slm_off = (uint32_t)(tid * 2 * 16) * 4u;
                slm_block_store<float, 16>(slm_off, gate_acc);
                slm_block_store<float, 16>(slm_off + 64u, up_acc);

                barrier();

                if (tid == 0) {
                    simd<float, 16> g_sum(0.f), u_sum(0.f);
                    #pragma unroll
                    for (int i = 0; i < GS; i++) {
                        uint32_t off = (uint32_t)(i * 2 * 16) * 4u;
                        g_sum += slm_block_load<float, 16>(off);
                        u_sum += slm_block_load<float, 16>(off + 64u);
                    }

                    simd<float, 16> silu = g_sum / (1.f + exp(-g_sum));
                    simd<float, 16> result = silu * u_sum;

                    const int routed_row = token * rows_per_token + k_idx;
                    block_store<fp16, 16>(
                        intermediates + (size_t)routed_row * intermediate_size + n_start,
                        convert<fp16>(result));
                }
            });
    };

    submit_kernel(cgf, device, "moe up routed int4 slm");
}

// ═══════════════════════════════════════════════════════════════════════════════
// Kernel 2: Fused Gate+Up+SiLU — Shared expert (FP16, NOT quantized)
// ═══════════════════════════════════════════════════════════════════════════════
// INT4 shared expert: weight is INT4 packed via SymInt4LinearMethod + IPEX OneDNN
// column-major repack. No marlin shuffle (unlike routed experts via GatedMLPMOE).
// Weight shape after IPEX: [2*inter_shared, hidden_size//8] column-major repacked
//   → reshape to [hidden_size//8, 2*inter_shared] to read correctly
// Scale: [2*inter_shared, hidden_size//128] (may also be column-major repacked)

void moe_up_shared_int4_kernel(
    const fp16* x,
    const uint32_t* shared_gate_up_qweight,  // INT4 packed, IPEX repacked
    const fp16* shared_gate_up_scale,         // per-group scales
    fp16* intermediates,
    const int n_tokens, const int hidden_size,
    const int shared_inter_size,
    const int buffer_row_width,
    const int top_k, const int num_shared_experts, const int rows_per_token,
    // Pre-reshaped dimensions (host does reshape before passing pointers)
    const int K_packed_shared,  // hidden_size // 8
    const int K_groups_shared,  // hidden_size // 128
    const torch::Device& device) {

    const int two_inter = 2 * shared_inter_size;

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeUpSharedInt4>(
            sycl::range<2>(n_tokens * num_shared_experts, shared_inter_size),
            [=](sycl::id<2> idx) SYCL_ESIMD_KERNEL {
                const int idx0  = (int)idx[0];
                const int token = idx0 / num_shared_experts;
                const int sid   = idx0 % num_shared_experts;
                const int row   = (int)idx[1];

                const fp16* x_row = x + (size_t)token * hidden_size;

                // IPEX OneDNN format: qweight is column-major repacked,
                // flat memory is [2*inter, K_packed] row-major after reshape.
                // But scales are NOT repacked — still [K_groups, 2*inter] row-major.
                const uint32_t* gw_base = shared_gate_up_qweight
                    + (size_t)sid * K_packed_shared * two_inter;
                const fp16* gs_base = shared_gate_up_scale
                    + (size_t)sid * K_groups_shared * two_inter;

                float g_acc = 0.f, u_acc = 0.f;
                for (int kp = 0; kp < K_packed_shared; kp++) {
                    simd<fp16, 8> x_chunk = block_load<fp16, 8>(x_row + kp * 8);
                    uint32_t g_packed = gw_base[(size_t)row * K_packed_shared + kp];
                    uint32_t u_packed = gw_base[(size_t)(shared_inter_size + row) * K_packed_shared + kp];
                    int gi = kp / 16;
                    fp16 g_scale = gs_base[(size_t)gi * two_inter + row];
                    fp16 u_scale = gs_base[(size_t)gi * two_inter + shared_inter_size + row];

                    #pragma unroll
                    for (int b = 0; b < 8; b++) {
                        float g_val = (float(((g_packed >> (b * 4)) & 0xFu)) - 8.f) * (float)g_scale;
                        float u_val = (float(((u_packed >> (b * 4)) & 0xFu)) - 8.f) * (float)u_scale;
                        float xv = (float)(fp16)x_chunk[b];
                        g_acc += g_val * xv;
                        u_acc += u_val * xv;
                    }
                }

                float gv = g_acc;
                float uv = u_acc;

                float silu_g = gv / (1.f + sycl::exp(-gv));
                const int shared_row = token * rows_per_token + top_k + sid;
                intermediates[(size_t)shared_row * buffer_row_width + row] = fp16(silu_g * uv);
            });
    };

    submit_kernel(cgf, device, "moe up shared int4");
}

// ═══════════════════════════════════════════════════════════════════════════════
// FP16 shared expert (legacy, for when shared_expert is not quantized)
// Weight: [2*inter_shared, hidden_size] fp16

void moe_up_shared_fp16_kernel(
    const fp16* x,
    const fp16* shared_gate_up_weight,
    fp16* intermediates,
    const int n_tokens, const int hidden_size,
    const int shared_inter_size,    // actual shared expert intermediate_size
    const int buffer_row_width,     // intermediates buffer row width (= routed d_ff, may be larger)
    const int top_k, const int num_shared_experts, const int rows_per_token,
    const torch::Device& device) {

    const int two_inter = 2 * shared_inter_size;

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeUpSharedFP16>(
            sycl::range<2>(n_tokens * num_shared_experts, shared_inter_size),
            [=](sycl::id<2> idx) SYCL_ESIMD_KERNEL {
                const int idx0  = (int)idx[0];
                const int token = idx0 / num_shared_experts;
                const int sid   = idx0 % num_shared_experts;
                const int row   = (int)idx[1];

                const fp16* x_row = x + (size_t)token * hidden_size;
                const fp16* gw = shared_gate_up_weight
                    + (size_t)sid * two_inter * hidden_size
                    + (size_t)row * hidden_size;
                const fp16* uw = shared_gate_up_weight
                    + (size_t)sid * two_inter * hidden_size
                    + (size_t)(shared_inter_size + row) * hidden_size;

                simd<float, 64> ag(0.f), au(0.f);
                for (int k = 0; k < hidden_size; k += 64) {
                    auto xv = block_load<fp16, 64>(x_row + k);
                    auto g  = block_load<fp16, 64>(gw + k);
                    auto u  = block_load<fp16, 64>(uw + k);
                    ag += convert<float>(xv * g);
                    au += convert<float>(xv * u);
                }

                float gv = sycl::ext::intel::esimd::detail::sum<float, float, 64>(ag);
                float uv = sycl::ext::intel::esimd::detail::sum<float, float, 64>(au);

                float silu_g = gv / (1.f + sycl::exp(-gv));
                const int shared_row = token * rows_per_token + top_k + sid;
                // Use buffer_row_width as stride (may differ from shared_inter_size)
                intermediates[(size_t)shared_row * buffer_row_width + row] = fp16(silu_g * uv);
            });
    };

    submit_kernel(cgf, device, "moe up shared fp16");
}

// ═══════════════════════════════════════════════════════════════════════════════
// Kernel 3: Down projection — Routed experts (INT4, IPEX K-major + marlin shuffled)
// ═══════════════════════════════════════════════════════════════════════════════
// Weight (IPEX): [E, K_packed_inter, d_model] int32, marlin shuffled
// Scale (IPEX):  [E, K_groups_inter, d_model] fp16
// 1 WI computes 16 consecutive hidden outputs along N

void moe_down_routed_int4_kernel(
    const fp16* intermediates,
    const uint32_t* down_qweight,     // IPEX: [E, K_packed_inter, d_model] or GGML: [E, d_model, K_packed_inter]
    const fp16* down_scales,          // IPEX: [E, K_groups_inter, d_model] or GGML: [E, d_model, K_groups_inter]
    const fp16* routing_weights,
    const int* selected_experts,
    fp16* output,
    const int n_tokens, const int hidden_size, const int intermediate_size,
    const int top_k, const int rows_per_token,
    const bool ggml_layout,
    const torch::Device& device) {

    const int K_packed = intermediate_size / 8;
    const int K_groups = intermediate_size / 128;
    const int n_out_tiles = hidden_size / 16;

    if (ggml_layout) {
        // GGML N-major: weight [E, d_model, K_packed_inter], scale [E, d_model, K_groups_inter]
        auto cgf = [&](sycl::handler& cgh) {
            cgh.parallel_for<class MoeDownRoutedInt4GGML>(
                sycl::range<2>(n_tokens * top_k, hidden_size),
                [=](sycl::id<2> idx) SYCL_ESIMD_KERNEL {
                    const int route_idx = (int)idx[0];
                    const int j         = (int)idx[1];
                    const int token     = route_idx / top_k;
                    const int k_idx     = route_idx % top_k;

                    const int eid = selected_experts[route_idx];
                    const int routed_row = token * rows_per_token + k_idx;
                    const fp16* hi = intermediates + (size_t)routed_row * intermediate_size;

                    const uint32_t* w_row = down_qweight + (size_t)eid * hidden_size * K_packed + (size_t)j * K_packed;
                    const fp16* s_row = down_scales + (size_t)eid * hidden_size * K_groups + (size_t)j * K_groups;

                    float acc = 0.f;
                    for (int kp = 0; kp < K_packed; kp++) {
                        uint32_t packed = w_row[kp];
                        int gi = kp / 16;
                        fp16 s = s_row[gi];

                        #pragma unroll
                        for (int b = 0; b < 8; b++) {
                            float w_val = (float(((packed >> (b * 4)) & 0xFu)) - 8.f) * (float)s;
                            acc += w_val * (float)hi[kp * 8 + b];
                        }
                    }

                    float w = (float)routing_weights[route_idx];
                    output[(size_t)routed_row * hidden_size + j] = fp16(acc * w);
                });
        };
        submit_kernel(cgf, device, "moe down routed int4 ggml");
    } else {
        // IPEX K-major layout — optimized: 64-wide tiles (2×32), preload hi
        const int n_out_tiles_ipex = hidden_size / 64;
        auto cgf = [&](sycl::handler& cgh) {
            cgh.parallel_for<class MoeDownRoutedInt4>(
                sycl::range<2>(n_tokens * top_k, n_out_tiles_ipex),
                [=](sycl::id<2> idx) SYCL_ESIMD_KERNEL {
                    const int route_idx = (int)idx[0];
                    const int tile_idx  = (int)idx[1];
                    const int token     = route_idx / top_k;
                    const int k_idx     = route_idx % top_k;
                    const int n_start   = tile_idx * 64;

                    const int eid = selected_experts[route_idx];
                    const int routed_row = token * rows_per_token + k_idx;
                    const fp16* hi = intermediates + (size_t)routed_row * intermediate_size;

                    const uint32_t* w_base = down_qweight + (size_t)eid * K_packed * hidden_size;
                    const fp16* s_base = down_scales + (size_t)eid * K_groups * hidden_size;

                    constexpr int unshuffle[8] = {0, 2, 4, 6, 1, 3, 5, 7};
                    simd<float, 32> acc0(0.f), acc1(0.f);

                    for (int kp = 0; kp < K_packed; kp++) {
                        simd<fp16, 8> hi_chunk = block_load<fp16, 8>(hi + kp * 8);

                        simd<uint32_t, 32> pk0 = block_load<uint32_t, 32>(w_base + (size_t)kp * hidden_size + n_start);
                        simd<uint32_t, 32> pk1 = block_load<uint32_t, 32>(w_base + (size_t)kp * hidden_size + n_start + 32);

                        int kg = kp / 16;
                        simd<fp16, 32> sc0 = block_load<fp16, 32>(s_base + (size_t)kg * hidden_size + n_start);
                        simd<fp16, 32> sc1 = block_load<fp16, 32>(s_base + (size_t)kg * hidden_size + n_start + 32);

                        #pragma unroll
                        for (int b = 0; b < 8; b++) {
                            int shift = unshuffle[b] * 4;
                            float hv = (float)(fp16)hi_chunk[b];
                            acc0 += (convert<float>((pk0 >> shift) & 0xFu) - 8.f) * convert<float>(sc0) * hv;
                            acc1 += (convert<float>((pk1 >> shift) & 0xFu) - 8.f) * convert<float>(sc1) * hv;
                        }
                    }

                    float w = (float)routing_weights[route_idx];
                    fp16* out = output + (size_t)routed_row * hidden_size + n_start;
                    block_store<fp16, 32>(out,      convert<fp16>(acc0 * w));
                    block_store<fp16, 32>(out + 32, convert<fp16>(acc1 * w));
                });
        };
        submit_kernel(cgf, device, "moe down routed int4");
    }
}

// ── SLM reduction version for down routed ────────────────────────────────────

void moe_down_routed_int4_slm_kernel(
    const fp16* intermediates,
    const uint32_t* down_qweight,
    const fp16* down_scales,
    const fp16* routing_weights,
    const int* selected_experts,
    fp16* output,
    const int n_tokens, const int hidden_size, const int intermediate_size,
    const int top_k, const int rows_per_token,
    const bool ggml_layout,
    const torch::Device& device) {

    if (ggml_layout) {
        moe_down_routed_int4_kernel(intermediates, down_qweight, down_scales,
            routing_weights, selected_experts, output, n_tokens, hidden_size,
            intermediate_size, top_k, rows_per_token, true, device);
        return;
    }

    const int K_packed = intermediate_size / 8;
    const int K_groups = intermediate_size / 128;
    const int n_out_tiles = hidden_size / 16;
    constexpr int GS = 16;

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeDownRoutedInt4SLM>(
            sycl::nd_range<2>(
                sycl::range<2>(n_tokens * top_k, n_out_tiles * GS),
                sycl::range<2>(1, GS)),
            [=](sycl::nd_item<2> item) SYCL_ESIMD_KERNEL {
                slm_init<GS * 16 * sizeof(float)>();

                const int route_idx = (int)item.get_global_id(0);
                const int tile_idx  = (int)item.get_group(1);
                const int tid       = (int)item.get_local_id(1);
                const int token     = route_idx / top_k;
                const int k_idx     = route_idx % top_k;
                const int n_start   = tile_idx * 16;

                const int eid = selected_experts[route_idx];
                const int routed_row = token * rows_per_token + k_idx;
                const fp16* hi = intermediates + (size_t)routed_row * intermediate_size;

                const uint32_t* w_base = down_qweight + (size_t)eid * K_packed * hidden_size;
                const fp16* s_base = down_scales + (size_t)eid * K_groups * hidden_size;

                constexpr int unshuffle[8] = {0, 2, 4, 6, 1, 3, 5, 7};
                simd<float, 16> acc(0.f);

                for (int kp = tid; kp < K_packed; kp += GS) {
                    simd<fp16, 8> hi_chunk = block_load<fp16, 8>(hi + kp * 8);
                    simd<uint32_t, 16> packed = block_load<uint32_t, 16>(
                        w_base + (size_t)kp * hidden_size + n_start);

                    int kg = kp / 16;
                    simd<fp16, 16> scale = block_load<fp16, 16>(
                        s_base + (size_t)kg * hidden_size + n_start);

                    #pragma unroll
                    for (int b = 0; b < 8; b++) {
                        int nib_pos = unshuffle[b];
                        simd<uint32_t, 16> nib = (packed >> (nib_pos * 4)) & 0xFu;
                        simd<float, 16> dq = (convert<float>(nib) - 8.f) * convert<float>(scale);
                        float hv = (float)(fp16)hi_chunk[b];
                        acc += dq * hv;
                    }
                }

                uint32_t slm_off = (uint32_t)(tid * 16) * 4u;
                slm_block_store<float, 16>(slm_off, acc);

                barrier();

                if (tid == 0) {
                    simd<float, 16> sum(0.f);
                    #pragma unroll
                    for (int i = 0; i < GS; i++)
                        sum += slm_block_load<float, 16>((uint32_t)(i * 16) * 4u);

                    float w = (float)routing_weights[route_idx];
                    block_store<fp16, 16>(
                        output + (size_t)routed_row * hidden_size + n_start,
                        convert<fp16>(sum * w));
                }
            });
    };

    submit_kernel(cgf, device, "moe down routed int4 slm");
}

// ═══════════════════════════════════════════════════════════════════════════════
// Kernel 4: Down Finalize — gate + shared_down(FP16) + accumulate
// ═══════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// BSZ>1 standalone down path: gate_precompute + down_shared + accumulate
// (Avoids redundant shared expert weight reads in down_finalize)
// ═══════════════════════════════════════════════════════════════════════════════

void moe_down_gate_precompute_int4_kernel(
    const fp16* x,
    const fp16* shared_expert_gate_weight,
    float* gate_values,
    const int n_tokens, const int hidden_size, const int num_shared_experts,
    const torch::Device& device) {

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeDownGatePrecomputeInt4>(
            sycl::range<1>(n_tokens * num_shared_experts),
            [=](sycl::id<1> idx) SYCL_ESIMD_KERNEL {
                const int flat = (int)idx[0];
                const int token = flat / num_shared_experts;
                const int sid   = flat % num_shared_experts;

                const fp16* x_row = x + (size_t)token * hidden_size;

                simd<float, 64> seg_acc(0.f);
                for (int k = 0; k < hidden_size; k += 64) {
                    seg_acc += convert<float>(
                        block_load<fp16, 64>(x_row + k) *
                        block_load<fp16, 64>(
                            shared_expert_gate_weight + (size_t)sid * hidden_size + k));
                }
                float seg_dot = sycl::ext::intel::esimd::detail::sum<float, float, 64>(seg_acc);
                gate_values[flat] = 1.f / (1.f + sycl::exp(-seg_dot));
            });
    };

    submit_kernel(cgf, device, "moe down gate precompute int4");
}

void moe_down_shared_int4_standalone_kernel(
    const fp16* intermediates,
    const uint32_t* shared_down_qweight,  // IPEX column-major repacked
    const fp16* shared_down_scale,        // NOT repacked [K_groups, hidden]
    const float* gate_values,
    fp16* output,
    const int n_tokens, const int hidden_size,
    const int shared_inter_size,
    const int buffer_row_width,           // intermediate buffer row width
    const int K_packed_down, const int K_groups_down,
    const int top_k, const int num_shared_experts, const int rows_per_token,
    const torch::Device& device) {

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeDownSharedInt4Standalone>(
            sycl::range<2>(n_tokens * num_shared_experts, hidden_size),
            [=](sycl::id<2> idx) SYCL_ESIMD_KERNEL {
                const int idx0  = (int)idx[0];
                const int token = idx0 / num_shared_experts;
                const int sid   = idx0 % num_shared_experts;
                const int j     = (int)idx[1];

                const int shared_row = token * rows_per_token + top_k + sid;
                const fp16* hi = intermediates + (size_t)shared_row * buffer_row_width;

                // qweight: [hidden, K_packed_down] row-major (IPEX column-major repacked)
                const uint32_t* dw_base = shared_down_qweight
                    + (size_t)sid * K_packed_down * hidden_size;
                // scales: [K_groups_down, hidden] row-major (NOT repacked)
                const fp16* ds_base = shared_down_scale
                    + (size_t)sid * K_groups_down * hidden_size;

                float acc = 0.f;
                for (int kp = 0; kp < K_packed_down; kp++) {
                    simd<fp16, 8> hi_chunk = block_load<fp16, 8>(hi + kp * 8);
                    uint32_t packed = dw_base[(size_t)j * K_packed_down + kp];
                    int gi = kp / 16;
                    fp16 s = ds_base[(size_t)gi * hidden_size + j];

                    #pragma unroll
                    for (int b = 0; b < 8; b++) {
                        float w_val = (float(((packed >> (b * 4)) & 0xFu)) - 8.f) * (float)s;
                        acc += w_val * (float)(fp16)hi_chunk[b];
                    }
                }

                float w = gate_values[idx0];
                output[(size_t)shared_row * hidden_size + j] = fp16(acc * w);
            });
    };

    submit_kernel(cgf, device, "moe down shared int4 standalone");
}

void moe_down_shared_fp16_standalone_kernel(
    const fp16* intermediates,
    const fp16* shared_down_weight,
    const float* gate_values,
    fp16* output,
    const int n_tokens, const int hidden_size,
    const int shared_inter_size,
    const int buffer_row_width,
    const int top_k, const int num_shared_experts, const int rows_per_token,
    const torch::Device& device) {

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeDownSharedFP16Standalone>(
            sycl::range<2>(n_tokens * num_shared_experts, hidden_size),
            [=](sycl::id<2> idx) SYCL_ESIMD_KERNEL {
                const int idx0  = (int)idx[0];
                const int token = idx0 / num_shared_experts;
                const int sid   = idx0 % num_shared_experts;
                const int j     = (int)idx[1];

                const int shared_row = token * rows_per_token + top_k + sid;
                const fp16* hi = intermediates + (size_t)shared_row * buffer_row_width;
                const fp16* dw = shared_down_weight
                    + (size_t)sid * hidden_size * shared_inter_size
                    + (size_t)j * shared_inter_size;

                simd<float, 64> acc(0.f);
                for (int k = 0; k < shared_inter_size; k += 64)
                    acc += convert<float>(
                        block_load<fp16, 64>(dw + k) * block_load<fp16, 64>(hi + k));

                float w = gate_values[idx0];
                output[(size_t)shared_row * hidden_size + j] =
                    fp16(w * sycl::ext::intel::esimd::detail::sum<float, float, 64>(acc));
            });
    };

    submit_kernel(cgf, device, "moe down shared fp16 standalone");
}

void moe_accumulate_int4_kernel(
    const fp16* partials,
    fp16* final_output,
    const int n_tokens, const int hidden_size,
    const int rows_per_token,
    const torch::Device& device) {

    const int num_chunks = hidden_size / 64;

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeAccumulateInt4>(
            sycl::range<2>(n_tokens, num_chunks),
            [=](sycl::id<2> idx) SYCL_ESIMD_KERNEL {
                const int token = (int)idx[0];
                const int base  = (int)idx[1] * 64;

                simd<float, 64> sum(0.f);
                for (int b = 0; b < rows_per_token; b++) {
                    sum += convert<float>(
                        block_load<fp16, 64>(partials + (size_t)(token * rows_per_token + b) * hidden_size + base));
                }
                block_store<fp16, 64>(final_output + (size_t)token * hidden_size + base, convert<fp16>(sum));
            });
    };

    submit_kernel(cgf, device, "moe accumulate int4");
}

// ═══════════════════════════════════════════════════════════════════════════════
// BSZ=1 fused down path (kept for lowest launch overhead)
// ═══════════════════════════════════════════════════════════════════════════════

void moe_down_finalize_fp16_kernel(
    const fp16* x,
    const fp16* intermediates,
    const fp16* routed_output,
    const fp16* shared_down_weight,
    const fp16* shared_expert_gate_weight,
    fp16* final_output,
    const int n_tokens, const int hidden_size,
    const int shared_inter_size,
    const int buffer_row_width,
    const int top_k, const int num_shared_experts, const int rows_per_token,
    const torch::Device& device) {

    // Tiled: 1 WG of GS=16 WIs computes 16 hidden outputs + 1 shared gate sigmoid.
    // Gate sigmoid computed once by tid==0, broadcast via SLM to all 16 WIs.
    const int n_tiles = hidden_size / 16;
    constexpr int GS = 16;

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeDownFinalizeFP16>(
            sycl::nd_range<2>(
                sycl::range<2>(n_tokens, n_tiles * GS),
                sycl::range<2>(1, GS)),
            [=](sycl::nd_item<2> item) SYCL_ESIMD_KERNEL {
                // SLM: num_shared_experts floats for gate_w values
                slm_init<16 * sizeof(float)>();  // max 16 shared experts

                const int token    = (int)item.get_global_id(0);
                const int tile_idx = (int)item.get_group(1);
                const int tid      = (int)item.get_local_id(1);
                const int j        = tile_idx * 16 + tid;  // each WI handles 1 output element

                // tid==0: compute gate sigmoid for all shared experts, store to SLM
                if (tid == 0) {
                    const fp16* x_row = x + (size_t)token * hidden_size;
                    for (int sid = 0; sid < num_shared_experts; sid++) {
                        simd<float, 64> gate_acc(0.f);
                        for (int gk = 0; gk < hidden_size; gk += 64)
                            gate_acc += convert<float>(block_load<fp16, 64>(x_row + gk))
                                      * convert<float>(block_load<fp16, 64>(
                                            shared_expert_gate_weight + sid * hidden_size + gk));
                        float gate_w = 1.f / (1.f + sycl::exp(
                            -sycl::ext::intel::esimd::detail::sum<float, float, 64>(gate_acc)));
                        slm_scalar_store<float>((uint32_t)(sid * sizeof(float)), gate_w);
                    }
                }

                barrier();

                // All WIs: accumulate routed outputs + shared down GEMV
                float sum = 0.f;
                for (int k = 0; k < top_k; k++)
                    sum += (float)routed_output[
                        (size_t)(token * rows_per_token + k) * hidden_size + j];

                for (int sid = 0; sid < num_shared_experts; sid++) {
                    float gate_w = slm_scalar_load<float>((uint32_t)(sid * sizeof(float)));

                    const int shared_row = token * rows_per_token + top_k + sid;
                    const fp16* hi = intermediates + (size_t)shared_row * buffer_row_width;
                    const fp16* dw = shared_down_weight
                        + (size_t)sid * hidden_size * shared_inter_size
                        + (size_t)j * shared_inter_size;

                    simd<float, 64> acc(0.f);
                    for (int k = 0; k < shared_inter_size; k += 64) {
                        auto d_fp16 = block_load<fp16, 64>(dw + k);
                        acc += convert<float>(d_fp16 * block_load<fp16, 64>(hi + k));
                    }
                    sum += sycl::ext::intel::esimd::detail::sum<float, float, 64>(acc) * gate_w;
                }

                final_output[(size_t)token * hidden_size + j] = fp16(sum);
            });
    };

    submit_kernel(cgf, device, "moe down finalize fp16");
}

void moe_tiny_shared_up_gate_fp16_kernel(
    const fp16* x,
    const fp16* shared_gate_up_weight,
    const fp16* shared_expert_gate_weight,
    fp16* shared_intermediates,
    float* shared_gate_values,
    const int hidden_size,
    const int shared_inter_size,
    const int num_shared_experts,
    const torch::Device& device) {

    const int two_inter = 2 * shared_inter_size;

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeTinySharedUpGateFP16>(
            sycl::range<2>(num_shared_experts, shared_inter_size + 1),
            [=](sycl::id<2> idx) SYCL_ESIMD_KERNEL {
                const int sid = (int)idx[0];
                const int row = (int)idx[1];

                const fp16* x_row = x;
                if (row < shared_inter_size) {
                    const fp16* gw = shared_gate_up_weight
                        + (size_t)sid * two_inter * hidden_size
                        + (size_t)row * hidden_size;
                    const fp16* uw = shared_gate_up_weight
                        + (size_t)sid * two_inter * hidden_size
                        + (size_t)(shared_inter_size + row) * hidden_size;

                    simd<float, 64> ag(0.f), au(0.f);
                    for (int k = 0; k < hidden_size; k += 64) {
                        auto xv = block_load<fp16, 64>(x_row + k);
                        ag += convert<float>(xv * block_load<fp16, 64>(gw + k));
                        au += convert<float>(xv * block_load<fp16, 64>(uw + k));
                    }

                    float gv = sycl::ext::intel::esimd::detail::sum<float, float, 64>(ag);
                    float uv = sycl::ext::intel::esimd::detail::sum<float, float, 64>(au);
                    float silu_g = gv / (1.f + sycl::exp(-gv));
                    shared_intermediates[(size_t)sid * shared_inter_size + row] = fp16(silu_g * uv);
                } else {
                    const fp16* gate = shared_expert_gate_weight + (size_t)sid * hidden_size;
                    simd<float, 64> acc(0.f);
                    for (int k = 0; k < hidden_size; k += 64) {
                        acc += convert<float>(block_load<fp16, 64>(x_row + k))
                             * convert<float>(block_load<fp16, 64>(gate + k));
                    }
                    float v = sycl::ext::intel::esimd::detail::sum<float, float, 64>(acc);
                    shared_gate_values[sid] = 1.f / (1.f + sycl::exp(-v));
                }
            });
    };

    submit_kernel(cgf, device, "moe tiny shared up gate fp16");
}

void moe_tiny_shared_finalize_precomputed_gate_fp16_kernel(
    const fp16* shared_intermediates,
    const float* shared_gate_values,
    const fp16* routed_output,
    const fp16* shared_down_weight,
    fp16* final_output,
    const int hidden_size,
    const int shared_inter_size,
    const int num_shared_experts,
    const torch::Device& device) {

    const int n_tiles = hidden_size / 16;
    constexpr int GS = 16;

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeTinySharedFinalizePrecomputedGateFP16>(
            sycl::nd_range<1>(sycl::range<1>(n_tiles * GS), sycl::range<1>(GS)),
            [=](sycl::nd_item<1> item) SYCL_ESIMD_KERNEL {
                const int tile_idx = (int)item.get_group(0);
                const int tid = (int)item.get_local_id(0);
                const int j = tile_idx * 16 + tid;

                float sum = (float)routed_output[j];
                for (int sid = 0; sid < num_shared_experts; sid++) {
                    const fp16* hi = shared_intermediates + (size_t)sid * shared_inter_size;
                    const fp16* dw = shared_down_weight
                        + (size_t)sid * hidden_size * shared_inter_size
                        + (size_t)j * shared_inter_size;

                    simd<float, 64> acc(0.f);
                    for (int k = 0; k < shared_inter_size; k += 64) {
                        acc += convert<float>(block_load<fp16, 64>(dw + k)
                                             * block_load<fp16, 64>(hi + k));
                    }
                    sum += sycl::ext::intel::esimd::detail::sum<float, float, 64>(acc)
                         * shared_gate_values[sid];
                }

                final_output[j] = fp16(sum);
            });
    };

    submit_kernel(cgf, device, "moe tiny shared finalize precomputed gate fp16");
}

// ── INT4 version of down finalize (shared expert is INT4 quantized) ──────────

void moe_down_finalize_int4_kernel(
    const fp16* x,
    const fp16* intermediates,
    const fp16* routed_output,
    const uint32_t* shared_down_qweight,    // INT4 packed, IPEX column-major repacked
    const fp16* shared_down_scale,           // per-group scales
    const fp16* shared_expert_gate_weight,   // FP16 (always unquantized)
    fp16* final_output,
    const int n_tokens, const int hidden_size,
    const int shared_inter_size,
    const int buffer_row_width,
    const int K_packed_down,     // shared_inter_size // 8
    const int K_groups_down,     // shared_inter_size // 128
    const int top_k, const int num_shared_experts, const int rows_per_token,
    const torch::Device& device) {

    const int n_tiles = hidden_size / 16;
    constexpr int GS = 16;

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeDownFinalizeInt4>(
            sycl::nd_range<2>(
                sycl::range<2>(n_tokens, n_tiles * GS),
                sycl::range<2>(1, GS)),
            [=](sycl::nd_item<2> item) SYCL_ESIMD_KERNEL {
                slm_init<16 * sizeof(float)>();

                const int token    = (int)item.get_global_id(0);
                const int tile_idx = (int)item.get_group(1);
                const int tid      = (int)item.get_local_id(1);
                const int j        = tile_idx * 16 + tid;

                // tid==0: compute gate sigmoid, store to SLM
                if (tid == 0) {
                    const fp16* x_row = x + (size_t)token * hidden_size;
                    for (int sid = 0; sid < num_shared_experts; sid++) {
                        simd<float, 64> gate_acc(0.f);
                        for (int gk = 0; gk < hidden_size; gk += 64)
                            gate_acc += convert<float>(block_load<fp16, 64>(x_row + gk))
                                      * convert<float>(block_load<fp16, 64>(
                                            shared_expert_gate_weight + sid * hidden_size + gk));
                        float gate_w = 1.f / (1.f + sycl::exp(
                            -sycl::ext::intel::esimd::detail::sum<float, float, 64>(gate_acc)));
                        slm_scalar_store<float>((uint32_t)(sid * sizeof(float)), gate_w);
                    }
                }

                barrier();

                // Accumulate routed outputs
                float sum = 0.f;
                for (int k = 0; k < top_k; k++)
                    sum += (float)routed_output[
                        (size_t)(token * rows_per_token + k) * hidden_size + j];

                // Shared down GEMV with INT4 dequant
                // Weight layout after reshape: [K_packed_down, hidden_size] row-major
                // (IPEX column-major repack of [hidden_size, K_packed_down])
                for (int sid = 0; sid < num_shared_experts; sid++) {
                    float gate_w = slm_scalar_load<float>((uint32_t)(sid * sizeof(float)));

                    const int shared_row = token * rows_per_token + top_k + sid;
                    const fp16* hi = intermediates + (size_t)shared_row * buffer_row_width;
                    // qweight: IPEX column-major repacked → [hidden, K_packed_down] row-major
                    // scales: NOT repacked → [K_groups_down, hidden] row-major
                    const uint32_t* dw_base = shared_down_qweight
                        + (size_t)sid * K_packed_down * hidden_size;
                    const fp16* ds_base = shared_down_scale
                        + (size_t)sid * K_groups_down * hidden_size;

                    float acc = 0.f;
                    for (int kp = 0; kp < K_packed_down; kp++) {
                        simd<fp16, 8> hi_chunk = block_load<fp16, 8>(hi + kp * 8);
                        uint32_t packed = dw_base[(size_t)j * K_packed_down + kp];
                        int gi = kp / 16;
                        fp16 s = ds_base[(size_t)gi * hidden_size + j];

                        #pragma unroll
                        for (int b = 0; b < 8; b++) {
                            float w_val = (float(((packed >> (b * 4)) & 0xFu)) - 8.f) * (float)s;
                            acc += w_val * (float)(fp16)hi_chunk[b];
                        }
                    }
                    sum += acc * gate_w;
                }

                final_output[(size_t)token * hidden_size + j] = fp16(sum);
            });
    };

    submit_kernel(cgf, device, "moe down finalize int4");
}

// ═══════════════════════════════════════════════════════════════════════════════
// moe_forward_full_int4 — Full pipeline: TopK → Up → Down → Finalize
// ═══════════════════════════════════════════════════════════════════════════════

static thread_local torch::Tensor s_int4_topk_idx, s_int4_topk_weight;
static thread_local torch::Tensor s_int4_routed_output, s_int4_final_output;
static thread_local torch::Tensor s_int4_intermediates;
static thread_local torch::Tensor s_int4_gate_values;  // BSZ>1 precomputed gate sigmoid
static thread_local int s_int4_cached_ntokens = -1;

static void ensure_int4_moe_buffers(int n_tokens, int top_k, int num_shared_experts,
                                     int hidden_size, int intermediate_size,
                                     const torch::Device& dev) {
    int rows_per_token = top_k + num_shared_experts;
    if (s_int4_cached_ntokens != n_tokens) {
        s_int4_topk_idx = torch::empty({n_tokens, top_k},
            torch::device(dev).dtype(torch::kInt32));
        s_int4_topk_weight = torch::empty({n_tokens, top_k},
            torch::device(dev).dtype(torch::kHalf));
        s_int4_routed_output = torch::empty(
            {n_tokens * rows_per_token, hidden_size},
            torch::device(dev).dtype(torch::kHalf));
        s_int4_final_output = torch::empty({n_tokens, hidden_size},
            torch::device(dev).dtype(torch::kHalf));
        s_int4_intermediates = torch::empty(
            {n_tokens * rows_per_token, intermediate_size},
            torch::device(dev).dtype(torch::kHalf));
        s_int4_gate_values = torch::empty(
            {n_tokens * num_shared_experts},
            torch::device(dev).dtype(torch::kFloat));
        s_int4_cached_ntokens = n_tokens;
    }
}

template <typename IndexT>
class MoeRoutePrecomputeInt4;
template <typename IndexT>
class MoeRouteZeroInt4;
template <typename IndexT>
class MoeRoutePrefixInt4;
template <typename IndexT>
class MoeRouteCountInt4;
template <typename IndexT>
class MoeRouteFillInt4;
template <typename IndexT>
class MoeTinyMUpCutlassInt4;
template <typename IndexT>
class MoeTinyMDownCutlassInt4;
template <typename IndexT>
class MoeTinyMDownCutlassInt4WithSharedFP16;
template <typename IndexT>
class MoeTinyMUpCutlassInt4WithSharedFP16;

template <typename IndexT>
void moe_route_precompute_kernel(
    const IndexT* topk_idx,
    const fp16* topk_weight,
    int64_t* sorted_rows,
    fp16* sorted_weights,
    int32_t* rows_per_expert,
    int32_t* expert_offsets,
    const int n_tokens, const int top_k, const int num_experts,
    const torch::Device& device) {

    const int num_routes = n_tokens * top_k;
    if (num_routes <= 0) {
        auto cgf = [&](sycl::handler& cgh) {
            cgh.single_task<MoeRoutePrecomputeInt4<IndexT>>([=]() {
                int write_offset = 0;
                for (int expert = 0; expert < num_experts; ++expert) {
                    int count = 0;
                    for (int route = 0; route < num_routes; ++route) {
                        if ((int)topk_idx[route] == expert) {
                            sorted_rows[write_offset] = (int64_t)(route / top_k);
                            sorted_weights[write_offset] = topk_weight[route];
                            ++write_offset;
                            ++count;
                        }
                    }
                    rows_per_expert[expert] = count;
                }
            });
        };
        submit_kernel(cgf, device, "moe route precompute int4 serial");
        return;
    }

    auto zero_cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<MoeRouteZeroInt4<IndexT>>(sycl::range<1>(num_experts), [=](sycl::id<1> idx) {
            int expert = (int)idx[0];
            rows_per_expert[expert] = 0;
            expert_offsets[expert] = 0;
        });
    };
    submit_kernel(zero_cgf, device, "moe route zero int4");

    auto count_cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<MoeRouteCountInt4<IndexT>>(sycl::range<1>(num_routes), [=](sycl::id<1> idx) {
            int route = (int)idx[0];
            int expert = (int)topk_idx[route];
            sycl::atomic_ref<int32_t, sycl::memory_order::relaxed,
                             sycl::memory_scope::device,
                             sycl::access::address_space::global_space>
                count_ref(rows_per_expert[expert]);
            count_ref.fetch_add(1);
        });
    };
    submit_kernel(count_cgf, device, "moe route count int4");

    auto prefix_cgf = [&](sycl::handler& cgh) {
        cgh.single_task<MoeRoutePrefixInt4<IndexT>>([=]() {
            int offset = 0;
            for (int expert = 0; expert < num_experts; ++expert) {
                expert_offsets[expert] = offset;
                offset += rows_per_expert[expert];
            }
        });
    };
    submit_kernel(prefix_cgf, device, "moe route prefix int4");

    auto fill_cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<MoeRouteFillInt4<IndexT>>(sycl::range<1>(num_routes), [=](sycl::id<1> idx) {
            int route = (int)idx[0];
            int expert = (int)topk_idx[route];
            sycl::atomic_ref<int32_t, sycl::memory_order::relaxed,
                             sycl::memory_scope::device,
                             sycl::access::address_space::global_space>
                offset_ref(expert_offsets[expert]);
            int pos = offset_ref.fetch_add(1);
            sorted_rows[pos] = (int64_t)(route / top_k);
            sorted_weights[pos] = topk_weight[route];
        });
    };
    submit_kernel(fill_cgf, device, "moe route fill int4");
}

std::tuple<torch::Tensor, torch::Tensor, torch::Tensor> moe_route_precompute_int4(
    torch::Tensor topk_weight,
    torch::Tensor topk_idx,
    int64_t num_experts) {

    TORCH_CHECK(topk_weight.dim() == 2 && topk_weight.is_contiguous());
    TORCH_CHECK(topk_weight.scalar_type() == torch::kHalf);
    TORCH_CHECK(topk_idx.dim() == 2 && topk_idx.is_contiguous());
    TORCH_CHECK(topk_idx.scalar_type() == torch::kInt || topk_idx.scalar_type() == torch::kLong);
    TORCH_CHECK(topk_idx.size(0) == topk_weight.size(0) && topk_idx.size(1) == topk_weight.size(1));

    int n_tokens = topk_idx.size(0);
    int top_k = topk_idx.size(1);
    int num_routes = n_tokens * top_k;
    auto sorted_rows = torch::empty({num_routes}, torch::device(topk_idx.device()).dtype(torch::kInt64));
    auto sorted_weights = torch::empty({num_routes}, torch::device(topk_weight.device()).dtype(torch::kHalf));
    auto rows_per_expert = torch::empty({num_experts}, torch::device(topk_idx.device()).dtype(torch::kInt32));
    auto expert_offsets = torch::empty({num_experts}, torch::device(topk_idx.device()).dtype(torch::kInt32));

    if (topk_idx.scalar_type() == torch::kInt) {
        moe_route_precompute_kernel<int32_t>(
            topk_idx.data_ptr<int32_t>(), (const fp16*)topk_weight.data_ptr(),
            sorted_rows.data_ptr<int64_t>(), (fp16*)sorted_weights.data_ptr(),
            rows_per_expert.data_ptr<int32_t>(), expert_offsets.data_ptr<int32_t>(),
            n_tokens, top_k, (int)num_experts, topk_idx.device());
    } else {
        moe_route_precompute_kernel<int64_t>(
            topk_idx.data_ptr<int64_t>(), (const fp16*)topk_weight.data_ptr(),
            sorted_rows.data_ptr<int64_t>(), (fp16*)sorted_weights.data_ptr(),
            rows_per_expert.data_ptr<int32_t>(), expert_offsets.data_ptr<int32_t>(),
            n_tokens, top_k, (int)num_experts, topk_idx.device());
    }

    return {sorted_rows, sorted_weights, rows_per_expert};
}

void moe_silu_mul_int4_kernel(
    const fp16* gate_up,
    fp16* output,
    const int num_routes, const int intermediate_size,
    const torch::Device& device) {

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeSiluMulInt4>(
            sycl::range<2>(num_routes, intermediate_size),
            [=](sycl::id<2> idx) {
                const int route = (int)idx[0];
                const int col = (int)idx[1];
                const float gate = (float)gate_up[(size_t)route * 2 * intermediate_size + col];
                const float up = (float)gate_up[(size_t)route * 2 * intermediate_size + intermediate_size + col];
                const float silu = gate / (1.0f + sycl::exp(-gate));
                output[(size_t)route * intermediate_size + col] = fp16(silu * up);
            });
    };
    submit_kernel(cgf, device, "moe silu mul int4");
}

torch::Tensor moe_silu_mul_int4(torch::Tensor gate_up) {
    TORCH_CHECK(gate_up.dim() == 2 && gate_up.is_contiguous());
    TORCH_CHECK(gate_up.scalar_type() == torch::kHalf);
    TORCH_CHECK(gate_up.size(1) % 2 == 0);

    int num_routes = gate_up.size(0);
    int intermediate_size = gate_up.size(1) / 2;
    auto output = torch::empty({num_routes, intermediate_size},
        torch::device(gate_up.device()).dtype(torch::kHalf));
    moe_silu_mul_int4_kernel(
        (const fp16*)gate_up.data_ptr(), (fp16*)output.data_ptr(),
        num_routes, intermediate_size, gate_up.device());
    return output;
}

void moe_route_gather_int4_kernel(
    const fp16* route_output,
    const int64_t* sorted_rows,
    const fp16* sorted_weights,
    fp16* output,
    const int n_tokens, const int hidden_size, const int num_routes,
    const torch::Device& device) {

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeRouteGatherInt4>(
            sycl::range<2>(n_tokens, hidden_size),
            [=](sycl::id<2> idx) {
                const int token = (int)idx[0];
                const int h = (int)idx[1];
                float acc = 0.0f;
                for (int route = 0; route < num_routes; ++route) {
                    if ((int)sorted_rows[route] == token) {
                        acc += (float)sorted_weights[route] *
                               (float)route_output[(size_t)route * hidden_size + h];
                    }
                }
                output[(size_t)token * hidden_size + h] = fp16(acc);
            });
    };
    submit_kernel(cgf, device, "moe route gather int4");
}

torch::Tensor moe_route_gather_int4(
    torch::Tensor route_output,
    torch::Tensor sorted_rows,
    torch::Tensor sorted_weights,
    int64_t n_tokens) {

    TORCH_CHECK(route_output.dim() == 2 && route_output.is_contiguous());
    TORCH_CHECK(route_output.scalar_type() == torch::kHalf);
    TORCH_CHECK(sorted_rows.dim() == 1 && sorted_rows.is_contiguous());
    TORCH_CHECK(sorted_rows.scalar_type() == torch::kLong);
    TORCH_CHECK(sorted_weights.dim() == 1 && sorted_weights.is_contiguous());
    TORCH_CHECK(sorted_weights.scalar_type() == torch::kHalf);
    TORCH_CHECK(sorted_rows.size(0) == sorted_weights.size(0));
    TORCH_CHECK(sorted_rows.size(0) == route_output.size(0));

    int num_routes = route_output.size(0);
    int hidden_size = route_output.size(1);
    auto output = torch::empty({n_tokens, hidden_size},
        torch::device(route_output.device()).dtype(torch::kHalf));
    moe_route_gather_int4_kernel(
        (const fp16*)route_output.data_ptr(), sorted_rows.data_ptr<int64_t>(),
        (const fp16*)sorted_weights.data_ptr(), (fp16*)output.data_ptr(),
        (int)n_tokens, hidden_size, num_routes, route_output.device());
    return output;
}

static inline int decode_s4_nibble(uint8_t nibble) {
    int v = (int)(nibble & 0x0F);
    return v >= 8 ? v - 16 : v;
}

template <typename IndexT>
void moe_tiny_m_up_cutlass_int4_kernel(
    const fp16* x,
    const uint8_t* w13,
    const fp16* w13_scales,
    const IndexT* topk_idx,
    fp16* intermediates,
    const int top_k, const int hidden_size, const int intermediate_size,
    const torch::Device& device) {

    const int two_inter = 2 * intermediate_size;
    const int k_bytes = hidden_size / 2;
    const int k_groups = hidden_size / 128;
    constexpr int WG_SIZE = 64;

    auto cgf = [&](sycl::handler& cgh) {
        sycl::local_accessor<float, 1> gate_acc(sycl::range<1>(WG_SIZE), cgh);
        sycl::local_accessor<float, 1> up_acc(sycl::range<1>(WG_SIZE), cgh);
        const int groups = top_k * intermediate_size;
        cgh.parallel_for<class MoeTinyMUpCutlassInt4<IndexT>>(
            sycl::nd_range<1>(sycl::range<1>(groups * WG_SIZE),
                              sycl::range<1>(WG_SIZE)),
            [=](sycl::nd_item<1> item) {
                const int group_id = (int)item.get_group(0);
                const int lid = (int)item.get_local_id(0);
                const int route = group_id / intermediate_size;
                const int col = group_id - route * intermediate_size;
                const int expert = (int)topk_idx[route];

                const uint8_t* gate_row = w13 + ((size_t)expert * two_inter + col) * k_bytes;
                const uint8_t* up_row = w13 + ((size_t)expert * two_inter + intermediate_size + col) * k_bytes;
                const fp16* gate_s = w13_scales + ((size_t)expert * two_inter + col) * k_groups;
                const fp16* up_s = w13_scales + ((size_t)expert * two_inter + intermediate_size + col) * k_groups;

                float gate_sum = 0.0f;
                float up_sum = 0.0f;
                for (int kb = lid; kb < k_bytes; kb += WG_SIZE) {
                    int k0 = kb << 1;
                    int group = kb >> 6;
                    uint8_t gate_packed = gate_row[kb];
                    uint8_t up_packed = up_row[kb];
                    int gate0 = decode_s4_nibble(gate_packed & 0x0F);
                    int gate1 = decode_s4_nibble((gate_packed >> 4) & 0x0F);
                    int up0 = decode_s4_nibble(up_packed & 0x0F);
                    int up1 = decode_s4_nibble((up_packed >> 4) & 0x0F);
                    float x0 = (float)x[k0];
                    float x1 = (float)x[k0 + 1];
                    gate_sum += x0 * ((float)gate0 * (float)gate_s[group]);
                    gate_sum += x1 * ((float)gate1 * (float)gate_s[group]);
                    up_sum += x0 * ((float)up0 * (float)up_s[group]);
                    up_sum += x1 * ((float)up1 * (float)up_s[group]);
                }
                gate_acc[lid] = gate_sum;
                up_acc[lid] = up_sum;
                item.barrier(sycl::access::fence_space::local_space);

                for (int stride = WG_SIZE / 2; stride > 0; stride >>= 1) {
                    if (lid < stride) {
                        gate_acc[lid] += gate_acc[lid + stride];
                        up_acc[lid] += up_acc[lid + stride];
                    }
                    item.barrier(sycl::access::fence_space::local_space);
                }
                if (lid == 0) {
                    float gate = gate_acc[0];
                    float up = up_acc[0];
                    float silu = gate / (1.0f + sycl::exp(-gate));
                    intermediates[(size_t)route * intermediate_size + col] = fp16(silu * up);
                }
            });
    };
    submit_kernel(cgf, device, "moe tiny m up cutlass int4");
}

template <typename IndexT>
void moe_tiny_m_up_cutlass_int4_with_shared_fp16_kernel(
    const fp16* x,
    const uint8_t* w13,
    const fp16* w13_scales,
    const IndexT* topk_idx,
    const fp16* shared_gate_up_weight,
    const fp16* shared_expert_gate_weight,
    fp16* routed_intermediates,
    fp16* shared_intermediates,
    float* shared_gate_values,
    const int top_k, const int hidden_size, const int intermediate_size,
    const int shared_inter_size, const int num_shared_experts,
    const torch::Device& device) {

    const int two_inter = 2 * intermediate_size;
    const int shared_two_inter = 2 * shared_inter_size;
    const int k_bytes = hidden_size / 2;
    const int k_groups = hidden_size / 128;
    constexpr int WG_SIZE = 64;

    auto cgf = [&](sycl::handler& cgh) {
        sycl::local_accessor<float, 1> gate_acc(sycl::range<1>(WG_SIZE), cgh);
        sycl::local_accessor<float, 1> up_acc(sycl::range<1>(WG_SIZE), cgh);
        const int routed_groups = top_k * intermediate_size;
        const int shared_groups = num_shared_experts * (shared_inter_size + 1);
        cgh.parallel_for<class MoeTinyMUpCutlassInt4WithSharedFP16<IndexT>>(
            sycl::nd_range<1>(sycl::range<1>((routed_groups + shared_groups) * WG_SIZE),
                              sycl::range<1>(WG_SIZE)),
            [=](sycl::nd_item<1> item) {
                const int group_id = (int)item.get_group(0);
                const int lid = (int)item.get_local_id(0);
                float gate_sum = 0.0f;
                float up_sum = 0.0f;

                if (group_id < routed_groups) {
                    const int route = group_id / intermediate_size;
                    const int col = group_id - route * intermediate_size;
                    const int expert = (int)topk_idx[route];

                    const uint8_t* gate_row = w13 + ((size_t)expert * two_inter + col) * k_bytes;
                    const uint8_t* up_row = w13 + ((size_t)expert * two_inter + intermediate_size + col) * k_bytes;
                    const fp16* gate_s = w13_scales + ((size_t)expert * two_inter + col) * k_groups;
                    const fp16* up_s = w13_scales + ((size_t)expert * two_inter + intermediate_size + col) * k_groups;

                    for (int kb = lid; kb < k_bytes; kb += WG_SIZE) {
                        int k0 = kb << 1;
                        int group = kb >> 6;
                        uint8_t gate_packed = gate_row[kb];
                        uint8_t up_packed = up_row[kb];
                        int gate0 = decode_s4_nibble(gate_packed & 0x0F);
                        int gate1 = decode_s4_nibble((gate_packed >> 4) & 0x0F);
                        int up0 = decode_s4_nibble(up_packed & 0x0F);
                        int up1 = decode_s4_nibble((up_packed >> 4) & 0x0F);
                        float x0 = (float)x[k0];
                        float x1 = (float)x[k0 + 1];
                        gate_sum += x0 * ((float)gate0 * (float)gate_s[group]);
                        gate_sum += x1 * ((float)gate1 * (float)gate_s[group]);
                        up_sum += x0 * ((float)up0 * (float)up_s[group]);
                        up_sum += x1 * ((float)up1 * (float)up_s[group]);
                    }
                } else {
                    const int local_group = group_id - routed_groups;
                    const int sid = local_group / (shared_inter_size + 1);
                    const int row = local_group - sid * (shared_inter_size + 1);

                    if (row < shared_inter_size) {
                        const fp16* gw = shared_gate_up_weight
                            + (size_t)sid * shared_two_inter * hidden_size
                            + (size_t)row * hidden_size;
                        const fp16* uw = shared_gate_up_weight
                            + (size_t)sid * shared_two_inter * hidden_size
                            + (size_t)(shared_inter_size + row) * hidden_size;

                        for (int k = lid; k < hidden_size; k += WG_SIZE) {
                            float xv = (float)x[k];
                            gate_sum += xv * (float)gw[k];
                            up_sum += xv * (float)uw[k];
                        }
                    } else {
                        const fp16* gate = shared_expert_gate_weight + (size_t)sid * hidden_size;
                        for (int k = lid; k < hidden_size; k += WG_SIZE) {
                            gate_sum += (float)x[k] * (float)gate[k];
                        }
                    }
                }

                gate_acc[lid] = gate_sum;
                up_acc[lid] = up_sum;
                item.barrier(sycl::access::fence_space::local_space);

                for (int stride = WG_SIZE / 2; stride > 0; stride >>= 1) {
                    if (lid < stride) {
                        gate_acc[lid] += gate_acc[lid + stride];
                        up_acc[lid] += up_acc[lid + stride];
                    }
                    item.barrier(sycl::access::fence_space::local_space);
                }
                if (lid == 0) {
                    if (group_id < routed_groups) {
                        const int route = group_id / intermediate_size;
                        const int col = group_id - route * intermediate_size;
                        float gate = gate_acc[0];
                        float up = up_acc[0];
                        float silu = gate / (1.0f + sycl::exp(-gate));
                        routed_intermediates[(size_t)route * intermediate_size + col] = fp16(silu * up);
                    } else {
                        const int local_group = group_id - routed_groups;
                        const int sid = local_group / (shared_inter_size + 1);
                        const int row = local_group - sid * (shared_inter_size + 1);
                        if (row < shared_inter_size) {
                            float gate = gate_acc[0];
                            float up = up_acc[0];
                            float silu = gate / (1.0f + sycl::exp(-gate));
                            shared_intermediates[(size_t)sid * shared_inter_size + row] = fp16(silu * up);
                        } else {
                            float v = gate_acc[0];
                            shared_gate_values[sid] = 1.f / (1.f + sycl::exp(-v));
                        }
                    }
                }
            });
    };
    submit_kernel(cgf, device, "moe tiny m up cutlass int4 with shared fp16");
}

template <typename IndexT>
void moe_tiny_m_down_cutlass_int4_kernel(
    const fp16* intermediates,
    const uint8_t* w2,
    const fp16* w2_scales,
    const fp16* topk_weight,
    const IndexT* topk_idx,
    fp16* output,
    const int top_k, const int hidden_size, const int intermediate_size,
    const torch::Device& device) {

    const int k_bytes = intermediate_size / 2;
    const int k_groups = intermediate_size / 128;
    constexpr int WG_SIZE = 64;

    auto cgf = [&](sycl::handler& cgh) {
        sycl::local_accessor<float, 1> local_acc(sycl::range<1>(WG_SIZE), cgh);
        cgh.parallel_for<class MoeTinyMDownCutlassInt4<IndexT>>(
            sycl::nd_range<1>(sycl::range<1>(hidden_size * WG_SIZE),
                              sycl::range<1>(WG_SIZE)),
            [=](sycl::nd_item<1> item) {
                const int h = (int)item.get_group(0);
                const int lid = (int)item.get_local_id(0);
                float sum = 0.0f;
                for (int route = 0; route < top_k; ++route) {
                    int expert = (int)topk_idx[route];
                    const uint8_t* w_row = w2 + ((size_t)expert * hidden_size + h) * k_bytes;
                    const fp16* s_row = w2_scales + ((size_t)expert * hidden_size + h) * k_groups;
                    const fp16* in_row = intermediates + (size_t)route * intermediate_size;
                    float route_weight = (float)topk_weight[route];
                    for (int k = lid; k < intermediate_size; k += WG_SIZE) {
                        uint8_t packed = w_row[k >> 1];
                        uint8_t nibble = (k & 1) ? ((packed >> 4) & 0x0F) : (packed & 0x0F);
                        int v = decode_s4_nibble(nibble);
                        float scale = (float)s_row[k >> 7];
                        sum += route_weight * (float)in_row[k] * ((float)v * scale);
                    }
                }
                local_acc[lid] = sum;
                item.barrier(sycl::access::fence_space::local_space);

                for (int stride = WG_SIZE / 2; stride > 0; stride >>= 1) {
                    if (lid < stride) {
                        local_acc[lid] += local_acc[lid + stride];
                    }
                    item.barrier(sycl::access::fence_space::local_space);
                }
                if (lid == 0) {
                    output[h] = fp16(local_acc[0]);
                }
            });
    };
    submit_kernel(cgf, device, "moe tiny m down cutlass int4");
}

template <typename IndexT>
void moe_tiny_m_down_cutlass_int4_with_shared_fp16_kernel(
    const fp16* intermediates,
    const uint8_t* w2,
    const fp16* w2_scales,
    const fp16* topk_weight,
    const IndexT* topk_idx,
    const fp16* shared_intermediates,
    const float* shared_gate_values,
    const fp16* shared_down_weight,
    fp16* output,
    const int top_k, const int hidden_size, const int intermediate_size,
    const int shared_inter_size, const int num_shared_experts,
    const torch::Device& device) {

    const int k_bytes = intermediate_size / 2;
    const int k_groups = intermediate_size / 128;
    constexpr int WG_SIZE = 64;

    auto cgf = [&](sycl::handler& cgh) {
        sycl::local_accessor<float, 1> local_acc(sycl::range<1>(WG_SIZE), cgh);
        cgh.parallel_for<class MoeTinyMDownCutlassInt4WithSharedFP16<IndexT>>(
            sycl::nd_range<1>(sycl::range<1>(hidden_size * WG_SIZE),
                              sycl::range<1>(WG_SIZE)),
            [=](sycl::nd_item<1> item) {
                const int h = (int)item.get_group(0);
                const int lid = (int)item.get_local_id(0);
                float sum = 0.0f;

                for (int route = 0; route < top_k; ++route) {
                    int expert = (int)topk_idx[route];
                    const uint8_t* w_row = w2 + ((size_t)expert * hidden_size + h) * k_bytes;
                    const fp16* s_row = w2_scales + ((size_t)expert * hidden_size + h) * k_groups;
                    const fp16* in_row = intermediates + (size_t)route * intermediate_size;
                    float route_weight = (float)topk_weight[route];
                    for (int k = lid; k < intermediate_size; k += WG_SIZE) {
                        uint8_t packed = w_row[k >> 1];
                        uint8_t nibble = (k & 1) ? ((packed >> 4) & 0x0F) : (packed & 0x0F);
                        int v = decode_s4_nibble(nibble);
                        float scale = (float)s_row[k >> 7];
                        sum += route_weight * (float)in_row[k] * ((float)v * scale);
                    }
                }

                for (int sid = 0; sid < num_shared_experts; sid++) {
                    const fp16* hi = shared_intermediates + (size_t)sid * shared_inter_size;
                    const fp16* dw = shared_down_weight
                        + (size_t)sid * hidden_size * shared_inter_size
                        + (size_t)h * shared_inter_size;
                    float gate = shared_gate_values[sid];
                    for (int k = lid; k < shared_inter_size; k += WG_SIZE) {
                        sum += gate * (float)hi[k] * (float)dw[k];
                    }
                }

                local_acc[lid] = sum;
                item.barrier(sycl::access::fence_space::local_space);

                for (int stride = WG_SIZE / 2; stride > 0; stride >>= 1) {
                    if (lid < stride) {
                        local_acc[lid] += local_acc[lid + stride];
                    }
                    item.barrier(sycl::access::fence_space::local_space);
                }
                if (lid == 0) {
                    output[h] = fp16(local_acc[0]);
                }
            });
    };
    submit_kernel(cgf, device, "moe tiny m down cutlass int4 with shared fp16");
}

torch::Tensor moe_forward_tiny_cutlass_nmajor_int4(
    torch::Tensor x,
    torch::Tensor w13_qweight_s4,
    torch::Tensor w13_scales,
    torch::Tensor w2_qweight_s4,
    torch::Tensor w2_scales,
    torch::Tensor topk_weight,
    torch::Tensor topk_idx) {

    TORCH_CHECK(x.dim() == 2 && x.size(0) == 1 && x.is_contiguous());
    TORCH_CHECK(x.scalar_type() == torch::kHalf);
    TORCH_CHECK(w13_qweight_s4.scalar_type() == torch::kByte && w13_qweight_s4.is_contiguous());
    TORCH_CHECK(w2_qweight_s4.scalar_type() == torch::kByte && w2_qweight_s4.is_contiguous());
    TORCH_CHECK(w13_scales.scalar_type() == torch::kHalf && w13_scales.is_contiguous());
    TORCH_CHECK(w2_scales.scalar_type() == torch::kHalf && w2_scales.is_contiguous());
    TORCH_CHECK(topk_weight.dim() == 2 && topk_weight.size(0) == 1 && topk_weight.is_contiguous());
    TORCH_CHECK(topk_weight.scalar_type() == torch::kHalf);
    TORCH_CHECK(topk_idx.dim() == 2 && topk_idx.size(0) == 1 && topk_idx.is_contiguous());
    TORCH_CHECK(topk_idx.scalar_type() == torch::kInt || topk_idx.scalar_type() == torch::kLong);

    int hidden_size = x.size(1);
    int top_k = topk_idx.size(1);
    int two_inter = w13_qweight_s4.size(1);
    int intermediate_size = two_inter / 2;
    TORCH_CHECK(w13_qweight_s4.size(2) == hidden_size / 2);
    TORCH_CHECK(w2_qweight_s4.size(1) == hidden_size);
    TORCH_CHECK(w2_qweight_s4.size(2) == intermediate_size / 2);

    auto intermediates = torch::empty({top_k, intermediate_size},
        torch::device(x.device()).dtype(torch::kHalf));
    auto output = torch::empty({1, hidden_size},
        torch::device(x.device()).dtype(torch::kHalf));

    if (topk_idx.scalar_type() == torch::kInt) {
        const int32_t* idx_ptr = topk_idx.data_ptr<int32_t>();
        moe_tiny_m_up_cutlass_int4_kernel<int32_t>(
            (const fp16*)x.data_ptr(), (const uint8_t*)w13_qweight_s4.data_ptr(),
            (const fp16*)w13_scales.data_ptr(), idx_ptr,
            (fp16*)intermediates.data_ptr(), top_k, hidden_size,
            intermediate_size, x.device());
        moe_tiny_m_down_cutlass_int4_kernel<int32_t>(
            (const fp16*)intermediates.data_ptr(), (const uint8_t*)w2_qweight_s4.data_ptr(),
            (const fp16*)w2_scales.data_ptr(), (const fp16*)topk_weight.data_ptr(),
            idx_ptr, (fp16*)output.data_ptr(), top_k, hidden_size,
            intermediate_size, x.device());
    } else {
        const int64_t* idx_ptr = topk_idx.data_ptr<int64_t>();
        moe_tiny_m_up_cutlass_int4_kernel<int64_t>(
            (const fp16*)x.data_ptr(), (const uint8_t*)w13_qweight_s4.data_ptr(),
            (const fp16*)w13_scales.data_ptr(), idx_ptr,
            (fp16*)intermediates.data_ptr(), top_k, hidden_size,
            intermediate_size, x.device());
        moe_tiny_m_down_cutlass_int4_kernel<int64_t>(
            (const fp16*)intermediates.data_ptr(), (const uint8_t*)w2_qweight_s4.data_ptr(),
            (const fp16*)w2_scales.data_ptr(), (const fp16*)topk_weight.data_ptr(),
            idx_ptr, (fp16*)output.data_ptr(), top_k, hidden_size,
            intermediate_size, x.device());
    }
    return output;
}

torch::Tensor moe_tiny_cutlass_nmajor_int4_up(
    torch::Tensor x,
    torch::Tensor w13_qweight_s4,
    torch::Tensor w13_scales,
    torch::Tensor topk_idx) {

    TORCH_CHECK(x.dim() == 2 && x.size(0) == 1 && x.is_contiguous());
    TORCH_CHECK(x.scalar_type() == torch::kHalf);
    TORCH_CHECK(w13_qweight_s4.scalar_type() == torch::kByte && w13_qweight_s4.is_contiguous());
    TORCH_CHECK(w13_scales.scalar_type() == torch::kHalf && w13_scales.is_contiguous());
    TORCH_CHECK(topk_idx.dim() == 2 && topk_idx.size(0) == 1 && topk_idx.is_contiguous());
    TORCH_CHECK(topk_idx.scalar_type() == torch::kInt || topk_idx.scalar_type() == torch::kLong);

    int hidden_size = x.size(1);
    int top_k = topk_idx.size(1);
    int two_inter = w13_qweight_s4.size(1);
    int intermediate_size = two_inter / 2;
    TORCH_CHECK(w13_qweight_s4.size(2) == hidden_size / 2);

    auto intermediates = torch::empty({top_k, intermediate_size},
        torch::device(x.device()).dtype(torch::kHalf));

    if (topk_idx.scalar_type() == torch::kInt) {
        moe_tiny_m_up_cutlass_int4_kernel<int32_t>(
            (const fp16*)x.data_ptr(), (const uint8_t*)w13_qweight_s4.data_ptr(),
            (const fp16*)w13_scales.data_ptr(), topk_idx.data_ptr<int32_t>(),
            (fp16*)intermediates.data_ptr(), top_k, hidden_size,
            intermediate_size, x.device());
    } else {
        moe_tiny_m_up_cutlass_int4_kernel<int64_t>(
            (const fp16*)x.data_ptr(), (const uint8_t*)w13_qweight_s4.data_ptr(),
            (const fp16*)w13_scales.data_ptr(), topk_idx.data_ptr<int64_t>(),
            (fp16*)intermediates.data_ptr(), top_k, hidden_size,
            intermediate_size, x.device());
    }
    return intermediates;
}

torch::Tensor moe_tiny_cutlass_nmajor_int4_down(
    torch::Tensor intermediates,
    torch::Tensor w2_qweight_s4,
    torch::Tensor w2_scales,
    torch::Tensor topk_weight,
    torch::Tensor topk_idx) {

    TORCH_CHECK(intermediates.dim() == 2 && intermediates.is_contiguous());
    TORCH_CHECK(intermediates.scalar_type() == torch::kHalf);
    TORCH_CHECK(w2_qweight_s4.scalar_type() == torch::kByte && w2_qweight_s4.is_contiguous());
    TORCH_CHECK(w2_scales.scalar_type() == torch::kHalf && w2_scales.is_contiguous());
    TORCH_CHECK(topk_weight.dim() == 2 && topk_weight.size(0) == 1 && topk_weight.is_contiguous());
    TORCH_CHECK(topk_weight.scalar_type() == torch::kHalf);
    TORCH_CHECK(topk_idx.dim() == 2 && topk_idx.size(0) == 1 && topk_idx.is_contiguous());
    TORCH_CHECK(topk_idx.scalar_type() == torch::kInt || topk_idx.scalar_type() == torch::kLong);

    int top_k = topk_idx.size(1);
    int intermediate_size = intermediates.size(1);
    int hidden_size = w2_qweight_s4.size(1);
    TORCH_CHECK(intermediates.size(0) == top_k);
    TORCH_CHECK(w2_qweight_s4.size(2) == intermediate_size / 2);

    auto output = torch::empty({1, hidden_size},
        torch::device(intermediates.device()).dtype(torch::kHalf));

    if (topk_idx.scalar_type() == torch::kInt) {
        moe_tiny_m_down_cutlass_int4_kernel<int32_t>(
            (const fp16*)intermediates.data_ptr(), (const uint8_t*)w2_qweight_s4.data_ptr(),
            (const fp16*)w2_scales.data_ptr(), (const fp16*)topk_weight.data_ptr(),
            topk_idx.data_ptr<int32_t>(), (fp16*)output.data_ptr(), top_k,
            hidden_size, intermediate_size, intermediates.device());
    } else {
        moe_tiny_m_down_cutlass_int4_kernel<int64_t>(
            (const fp16*)intermediates.data_ptr(), (const uint8_t*)w2_qweight_s4.data_ptr(),
            (const fp16*)w2_scales.data_ptr(), (const fp16*)topk_weight.data_ptr(),
            topk_idx.data_ptr<int64_t>(), (fp16*)output.data_ptr(), top_k,
            hidden_size, intermediate_size, intermediates.device());
    }
    return output;
}

torch::Tensor moe_forward_tiny_cutlass_nmajor_int4_full_fp16_shared(
    torch::Tensor x,
    torch::Tensor w13_qweight_s4,
    torch::Tensor w13_scales,
    torch::Tensor w2_qweight_s4,
    torch::Tensor w2_scales,
    torch::Tensor topk_weight,
    torch::Tensor topk_idx,
    torch::Tensor shared_gate_up_weight,
    torch::Tensor shared_down_weight,
    torch::Tensor shared_expert_gate_weight,
    int64_t num_shared_experts) {

    TORCH_CHECK(x.dim() == 2 && x.size(0) == 1 && x.is_contiguous());
    TORCH_CHECK(x.scalar_type() == torch::kHalf);
    TORCH_CHECK(shared_gate_up_weight.scalar_type() == torch::kHalf && shared_gate_up_weight.is_contiguous());
    TORCH_CHECK(shared_down_weight.scalar_type() == torch::kHalf && shared_down_weight.is_contiguous());
    TORCH_CHECK(shared_expert_gate_weight.scalar_type() == torch::kHalf && shared_expert_gate_weight.is_contiguous());
    TORCH_CHECK(num_shared_experts > 0);

    int hidden_size = x.size(1);
    int shared_gate_rows = shared_gate_up_weight.numel() / hidden_size;
    int shared_inter_size = shared_gate_rows / (2 * (int)num_shared_experts);
    TORCH_CHECK(shared_inter_size > 0);
    TORCH_CHECK(shared_gate_rows == 2 * (int)num_shared_experts * shared_inter_size);
    TORCH_CHECK(shared_down_weight.numel() == (int64_t)num_shared_experts * hidden_size * shared_inter_size);
    TORCH_CHECK(shared_expert_gate_weight.numel() == (int64_t)num_shared_experts * hidden_size);

    TORCH_CHECK(topk_weight.dim() == 2 && topk_weight.size(0) == 1 && topk_weight.is_contiguous());
    TORCH_CHECK(topk_weight.scalar_type() == torch::kHalf);
    TORCH_CHECK(topk_idx.dim() == 2 && topk_idx.size(0) == 1 && topk_idx.is_contiguous());
    TORCH_CHECK(topk_idx.scalar_type() == torch::kInt || topk_idx.scalar_type() == torch::kLong);
    TORCH_CHECK(w13_qweight_s4.scalar_type() == torch::kByte && w13_qweight_s4.is_contiguous());
    TORCH_CHECK(w13_scales.scalar_type() == torch::kHalf && w13_scales.is_contiguous());
    TORCH_CHECK(w2_qweight_s4.scalar_type() == torch::kByte && w2_qweight_s4.is_contiguous());
    TORCH_CHECK(w2_scales.scalar_type() == torch::kHalf && w2_scales.is_contiguous());

    int top_k = topk_idx.size(1);
    int two_inter = w13_qweight_s4.size(1);
    int intermediate_size = two_inter / 2;
    TORCH_CHECK(w13_qweight_s4.size(2) == hidden_size / 2);
    TORCH_CHECK(w2_qweight_s4.size(1) == hidden_size);
    TORCH_CHECK(w2_qweight_s4.size(2) == intermediate_size / 2);

    TORCH_CHECK(shared_inter_size == intermediate_size,
        "tiny full FP16 shared path currently requires shared_inter_size == routed intermediate_size");
    ensure_int4_moe_buffers(1, top_k, (int)num_shared_experts, hidden_size,
                            intermediate_size, x.device());

    fp16* routed_intermediates_ptr = (fp16*)s_int4_intermediates.data_ptr();
    fp16* shared_intermediates_ptr = routed_intermediates_ptr + (size_t)top_k * intermediate_size;
    float* shared_gate_values_ptr = (float*)s_int4_gate_values.data_ptr();
    auto final_output = s_int4_final_output;

    if (topk_idx.scalar_type() == torch::kInt) {
        moe_tiny_m_up_cutlass_int4_with_shared_fp16_kernel<int32_t>(
            (const fp16*)x.data_ptr(), (const uint8_t*)w13_qweight_s4.data_ptr(),
            (const fp16*)w13_scales.data_ptr(), topk_idx.data_ptr<int32_t>(),
            (const fp16*)shared_gate_up_weight.data_ptr(),
            (const fp16*)shared_expert_gate_weight.data_ptr(),
            routed_intermediates_ptr, shared_intermediates_ptr,
            shared_gate_values_ptr, top_k, hidden_size,
            intermediate_size, shared_inter_size, (int)num_shared_experts, x.device());
    } else {
        moe_tiny_m_up_cutlass_int4_with_shared_fp16_kernel<int64_t>(
            (const fp16*)x.data_ptr(), (const uint8_t*)w13_qweight_s4.data_ptr(),
            (const fp16*)w13_scales.data_ptr(), topk_idx.data_ptr<int64_t>(),
            (const fp16*)shared_gate_up_weight.data_ptr(),
            (const fp16*)shared_expert_gate_weight.data_ptr(),
            routed_intermediates_ptr, shared_intermediates_ptr,
            shared_gate_values_ptr, top_k, hidden_size,
            intermediate_size, shared_inter_size, (int)num_shared_experts, x.device());
    }

    if (topk_idx.scalar_type() == torch::kInt) {
        moe_tiny_m_down_cutlass_int4_with_shared_fp16_kernel<int32_t>(
            (const fp16*)routed_intermediates_ptr, (const uint8_t*)w2_qweight_s4.data_ptr(),
            (const fp16*)w2_scales.data_ptr(), (const fp16*)topk_weight.data_ptr(),
            topk_idx.data_ptr<int32_t>(), (const fp16*)shared_intermediates_ptr,
            (const float*)shared_gate_values_ptr, (const fp16*)shared_down_weight.data_ptr(),
            (fp16*)final_output.data_ptr(), top_k, hidden_size, intermediate_size,
            shared_inter_size, (int)num_shared_experts, x.device());
    } else {
        moe_tiny_m_down_cutlass_int4_with_shared_fp16_kernel<int64_t>(
            (const fp16*)routed_intermediates_ptr, (const uint8_t*)w2_qweight_s4.data_ptr(),
            (const fp16*)w2_scales.data_ptr(), (const fp16*)topk_weight.data_ptr(),
            topk_idx.data_ptr<int64_t>(), (const fp16*)shared_intermediates_ptr,
            (const float*)shared_gate_values_ptr, (const fp16*)shared_down_weight.data_ptr(),
            (fp16*)final_output.data_ptr(), top_k, hidden_size, intermediate_size,
            shared_inter_size, (int)num_shared_experts, x.device());
    }

    return final_output;
}

torch::Tensor moe_tiny_fp16_shared_up(
    torch::Tensor x,
    torch::Tensor shared_gate_up_weight,
    int64_t num_shared_experts) {

    TORCH_CHECK(x.dim() == 2 && x.size(0) == 1 && x.is_contiguous());
    TORCH_CHECK(x.scalar_type() == torch::kHalf);
    TORCH_CHECK(shared_gate_up_weight.scalar_type() == torch::kHalf && shared_gate_up_weight.is_contiguous());
    TORCH_CHECK(num_shared_experts > 0);

    int hidden_size = x.size(1);
    int shared_gate_rows = shared_gate_up_weight.numel() / hidden_size;
    int shared_inter_size = shared_gate_rows / (2 * (int)num_shared_experts);
    TORCH_CHECK(shared_gate_rows == 2 * (int)num_shared_experts * shared_inter_size);

    constexpr int routed_rows = 1;
    int rows_per_token = routed_rows + (int)num_shared_experts;
    auto shared_intermediates = torch::empty({rows_per_token, shared_inter_size},
        torch::device(x.device()).dtype(torch::kHalf));

    moe_up_shared_fp16_kernel(
        (const fp16*)x.data_ptr(), (const fp16*)shared_gate_up_weight.data_ptr(),
        (fp16*)shared_intermediates.data_ptr(), 1, hidden_size, shared_inter_size,
        shared_inter_size, routed_rows, (int)num_shared_experts, rows_per_token,
        x.device());
    return shared_intermediates;
}

torch::Tensor moe_tiny_fp16_shared_finalize(
    torch::Tensor x,
    torch::Tensor shared_intermediates,
    torch::Tensor routed_output,
    torch::Tensor shared_down_weight,
    torch::Tensor shared_expert_gate_weight,
    int64_t num_shared_experts) {

    TORCH_CHECK(x.dim() == 2 && x.size(0) == 1 && x.is_contiguous());
    TORCH_CHECK(shared_intermediates.dim() == 2 && shared_intermediates.is_contiguous());
    TORCH_CHECK(routed_output.dim() == 2 && routed_output.size(0) == 1 && routed_output.is_contiguous());
    TORCH_CHECK(x.scalar_type() == torch::kHalf);
    TORCH_CHECK(shared_intermediates.scalar_type() == torch::kHalf);
    TORCH_CHECK(routed_output.scalar_type() == torch::kHalf);
    TORCH_CHECK(shared_down_weight.scalar_type() == torch::kHalf && shared_down_weight.is_contiguous());
    TORCH_CHECK(shared_expert_gate_weight.scalar_type() == torch::kHalf && shared_expert_gate_weight.is_contiguous());
    TORCH_CHECK(num_shared_experts > 0);

    int hidden_size = x.size(1);
    int shared_inter_size = shared_intermediates.size(1);
    constexpr int routed_rows = 1;
    int rows_per_token = routed_rows + (int)num_shared_experts;
    TORCH_CHECK(shared_intermediates.size(0) == rows_per_token);
    TORCH_CHECK(shared_down_weight.numel() == (int64_t)num_shared_experts * hidden_size * shared_inter_size);
    TORCH_CHECK(shared_expert_gate_weight.numel() == (int64_t)num_shared_experts * hidden_size);

    auto final_output = torch::empty({1, hidden_size},
        torch::device(x.device()).dtype(torch::kHalf));

    moe_down_finalize_fp16_kernel(
        (const fp16*)x.data_ptr(), (const fp16*)shared_intermediates.data_ptr(),
        (const fp16*)routed_output.data_ptr(), (const fp16*)shared_down_weight.data_ptr(),
        (const fp16*)shared_expert_gate_weight.data_ptr(), (fp16*)final_output.data_ptr(),
        1, hidden_size, shared_inter_size, shared_inter_size, routed_rows,
        (int)num_shared_experts, rows_per_token, x.device());
    return final_output;
}

torch::Tensor moe_forward_full_int4(
    torch::Tensor x, torch::Tensor logits,
    // Routed experts — INT4 (IPEX K-major + marlin shuffled)
    torch::Tensor gate_up_qweight, torch::Tensor gate_up_scales,
    // Shared expert — INT4 (IPEX column-major repacked, no marlin shuffle)
    torch::Tensor shared_gate_up_weight, torch::Tensor shared_gate_up_scale,
    // Routed experts — INT4
    torch::Tensor down_qweight, torch::Tensor down_scales,
    // Shared expert — INT4
    torch::Tensor shared_down_weight, torch::Tensor shared_down_scale,
    // Shared expert gate — FP16 (always unquantized)
    torch::Tensor shared_expert_gate_weight,
    int64_t top_k, int64_t num_shared_experts, int64_t n_routed_experts,
    bool use_ggml_layout) {

    TORCH_CHECK(x.scalar_type() == torch::kHalf);
    TORCH_CHECK(gate_up_qweight.scalar_type() == torch::kInt);
    TORCH_CHECK(gate_up_scales.scalar_type() == torch::kHalf);
    TORCH_CHECK(down_qweight.scalar_type() == torch::kInt);
    TORCH_CHECK(down_scales.scalar_type() == torch::kHalf);

    int n_tokens = x.size(0), hidden_size = x.size(1);
    // IPEX K-major: gate_up_qweight [E, K_packed, 2*d_ff]
    // GGML N-major: gate_up_qweight [E, 2*d_ff, K_packed]
    int two_dff = use_ggml_layout ? gate_up_qweight.size(1) : gate_up_qweight.size(2);
    int intermediate_size = two_dff / 2;
    int rows_per_token = top_k + num_shared_experts;

    // Shared expert intermediate size — detect INT4 vs FP16
    // INT4: shared_gate_up_weight is int32 packed, shape depends on IPEX repack
    // FP16: shared_gate_up_weight is fp16, shape [2*shared_inter, hidden_size]
    int shared_intermediate_size;
    bool shared_is_int4 = (shared_gate_up_weight.scalar_type() == torch::kInt);
    if (shared_is_int4) {
        // INT4: reshape to get dimensions. IPEX column-major repack of
        // [2*shared_inter, hidden_size//8] → flat memory is [hidden_size//8, 2*shared_inter] row-major
        // Use numel to infer: numel = 2*shared_inter * (hidden_size/8)
        int K_packed_shared = hidden_size / 8;
        shared_intermediate_size = shared_gate_up_weight.numel() / K_packed_shared / 2;
    } else {
        shared_intermediate_size = shared_gate_up_weight.size(0) / 2;
    }

    TORCH_CHECK(intermediate_size % 16 == 0, "intermediate_size must be divisible by 16");
    TORCH_CHECK(hidden_size % 16 == 0, "hidden_size must be divisible by 16");

    ensure_int4_moe_buffers(n_tokens, top_k, num_shared_experts, hidden_size,
                            intermediate_size, x.device());

    sycl::queue& queue = c10::xpu::getCurrentXPUStream(x.device().index()).queue();

    // ── TopK (V2 vectorized argmax when supported, fallback to heap-based) ──
    if (n_routed_experts == 256 && top_k == 8) {
        moe_topk_v2_host<256, 8>(
            (const fp16*)logits.data_ptr(),
            (fp16*)s_int4_topk_weight.data_ptr(),
            s_int4_topk_idx.data_ptr<int32_t>(),
            n_tokens, queue);
    } else {
        moe_topk_forward_kernel_impl<class MoeTopKInt4>(
            (const fp16*)logits.data_ptr(),
            s_int4_topk_idx.data_ptr<int>(),
            (fp16*)s_int4_topk_weight.data_ptr(),
            n_tokens, (int)n_routed_experts, (int)top_k, /*norm=*/true,
            queue);
    }

    // ── Up: routed (INT4) — hybrid dispatch based on WI count ──
    int up_wis = n_tokens * top_k * (intermediate_size / 16);
    if (up_wis < 2048) {
        // Few WIs → use SLM reduction for better GPU utilization
        moe_up_routed_int4_slm_kernel(
            (const fp16*)x.data_ptr(),
            (const uint32_t*)gate_up_qweight.data_ptr(),
            (const fp16*)gate_up_scales.data_ptr(),
            s_int4_topk_idx.data_ptr<int>(),
            (fp16*)s_int4_intermediates.data_ptr(),
            n_tokens, hidden_size, intermediate_size,
            top_k, rows_per_token, use_ggml_layout, x.device());
    } else {
        moe_up_routed_int4_kernel(
            (const fp16*)x.data_ptr(),
            (const uint32_t*)gate_up_qweight.data_ptr(),
            (const fp16*)gate_up_scales.data_ptr(),
            s_int4_topk_idx.data_ptr<int>(),
            (fp16*)s_int4_intermediates.data_ptr(),
            n_tokens, hidden_size, intermediate_size,
            top_k, rows_per_token, use_ggml_layout, x.device());
    }

    // ── Up: shared — dispatch INT4 or FP16 based on weight dtype ──
    int K_packed_shared = hidden_size / 8;
    int K_groups_shared = hidden_size / 128;
    if (shared_is_int4) {
        // IPEX OneDNN column-major repack of qweight [K_packed, 2*shared_inter]:
        // flat memory becomes [2*shared_inter, K_packed] row-major.
        // Scales are NOT repacked — still [K_groups, 2*shared_inter] row-major.
        auto shared_gu_reshaped = shared_gate_up_weight.reshape(
            {2 * shared_intermediate_size, K_packed_shared});
        moe_up_shared_int4_kernel(
            (const fp16*)x.data_ptr(),
            (const uint32_t*)shared_gu_reshaped.data_ptr(),
            (const fp16*)shared_gate_up_scale.data_ptr(),  // scales NOT repacked
            (fp16*)s_int4_intermediates.data_ptr(),
            n_tokens, hidden_size, shared_intermediate_size,
            intermediate_size,
            top_k, num_shared_experts, rows_per_token,
            K_packed_shared, K_groups_shared, x.device());
    } else {
        moe_up_shared_fp16_kernel(
            (const fp16*)x.data_ptr(),
            (const fp16*)shared_gate_up_weight.data_ptr(),
            (fp16*)s_int4_intermediates.data_ptr(),
            n_tokens, hidden_size, shared_intermediate_size,
            intermediate_size,
            top_k, num_shared_experts, rows_per_token, x.device());
    }

    // ── Down: routed (INT4) — hybrid dispatch ──
    int down_wis = n_tokens * top_k * (hidden_size / 16);
    if (down_wis < 2048) {
        moe_down_routed_int4_slm_kernel(
            (const fp16*)s_int4_intermediates.data_ptr(),
            (const uint32_t*)down_qweight.data_ptr(),
            (const fp16*)down_scales.data_ptr(),
            (const fp16*)s_int4_topk_weight.data_ptr(),
            s_int4_topk_idx.data_ptr<int>(),
            (fp16*)s_int4_routed_output.data_ptr(),
            n_tokens, hidden_size, intermediate_size,
            top_k, rows_per_token, use_ggml_layout, x.device());
    } else {
        moe_down_routed_int4_kernel(
            (const fp16*)s_int4_intermediates.data_ptr(),
            (const uint32_t*)down_qweight.data_ptr(),
            (const fp16*)down_scales.data_ptr(),
            (const fp16*)s_int4_topk_weight.data_ptr(),
            s_int4_topk_idx.data_ptr<int>(),
            (fp16*)s_int4_routed_output.data_ptr(),
            n_tokens, hidden_size, intermediate_size,
            top_k, rows_per_token, use_ggml_layout, x.device());
    }

    // ── Down Finalize: shared + accumulate ──
    // BSZ>1: standalone path (gate_precompute → down_shared → accumulate)
    //   avoids redundant shared expert weight reads per WI
    // BSZ=1: fused down_finalize (lowest launch overhead)
    if (n_tokens > 1) {
        // V2 path: precompute gate sigmoid
        moe_down_gate_precompute_int4_kernel(
            (const fp16*)x.data_ptr(),
            (const fp16*)shared_expert_gate_weight.data_ptr(),
            s_int4_gate_values.data_ptr<float>(),
            n_tokens, hidden_size, num_shared_experts, x.device());

        // Shared expert down GEMV (standalone, parallel over tokens × hidden)
        if (shared_is_int4) {
            int K_packed_down = shared_intermediate_size / 8;
            int K_groups_down = shared_intermediate_size / 128;
            auto shared_dw_reshaped = shared_down_weight.reshape(
                {hidden_size, K_packed_down});
            moe_down_shared_int4_standalone_kernel(
                (const fp16*)s_int4_intermediates.data_ptr(),
                (const uint32_t*)shared_dw_reshaped.data_ptr(),
                (const fp16*)shared_down_scale.data_ptr(),
                s_int4_gate_values.data_ptr<float>(),
                (fp16*)s_int4_routed_output.data_ptr(),
                n_tokens, hidden_size, shared_intermediate_size,
                intermediate_size, K_packed_down, K_groups_down,
                top_k, num_shared_experts, rows_per_token, x.device());
        } else {
            moe_down_shared_fp16_standalone_kernel(
                (const fp16*)s_int4_intermediates.data_ptr(),
                (const fp16*)shared_down_weight.data_ptr(),
                s_int4_gate_values.data_ptr<float>(),
                (fp16*)s_int4_routed_output.data_ptr(),
                n_tokens, hidden_size, shared_intermediate_size,
                intermediate_size,
                top_k, num_shared_experts, rows_per_token, x.device());
        }

        // Accumulate all rows (routed + shared) per token
        moe_accumulate_int4_kernel(
            (const fp16*)s_int4_routed_output.data_ptr(),
            (fp16*)s_int4_final_output.data_ptr(),
            n_tokens, hidden_size, rows_per_token, x.device());
    } else {
        // BSZ=1: fused down_finalize (gate sigmoid dedup via SLM)
        if (shared_is_int4) {
            int K_packed_down = shared_intermediate_size / 8;
            int K_groups_down = shared_intermediate_size / 128;
            auto shared_dw_reshaped = shared_down_weight.reshape(
                {hidden_size, K_packed_down});
            moe_down_finalize_int4_kernel(
                (const fp16*)x.data_ptr(),
                (const fp16*)s_int4_intermediates.data_ptr(),
                (const fp16*)s_int4_routed_output.data_ptr(),
                (const uint32_t*)shared_dw_reshaped.data_ptr(),
                (const fp16*)shared_down_scale.data_ptr(),
                (const fp16*)shared_expert_gate_weight.data_ptr(),
                (fp16*)s_int4_final_output.data_ptr(),
                n_tokens, hidden_size, shared_intermediate_size,
                intermediate_size, K_packed_down, K_groups_down,
                top_k, num_shared_experts, rows_per_token, x.device());
        } else {
            moe_down_finalize_fp16_kernel(
                (const fp16*)x.data_ptr(),
                (const fp16*)s_int4_intermediates.data_ptr(),
                (const fp16*)s_int4_routed_output.data_ptr(),
                (const fp16*)shared_down_weight.data_ptr(),
                (const fp16*)shared_expert_gate_weight.data_ptr(),
                (fp16*)s_int4_final_output.data_ptr(),
                n_tokens, hidden_size, shared_intermediate_size,
                intermediate_size,
                top_k, num_shared_experts, rows_per_token, x.device());
        }
    }

    return s_int4_final_output;
}

// ═══════════════════════════════════════════════════════════════════════════════
// ═══════════════════════════════════════════════════════════════════════════════
// Standalone shared expert forward — CUTLASS N-major uint8 (implement_zp signed)
// ═══════════════════════════════════════════════════════════════════════════════
// Weight: [N, K/2] uint8, implement_zp encoding (two's complement int4)
// Scale:  [N, K/GS] fp16 (N-major, contiguous)
// Gate:   [num_shared, H] fp16 (always unquantized)
//
// Dequant: byte → lo = byte & 0xF, hi = (byte >> 4) & 0xF
//          val = (nibble >= 8) ? (float)(nibble - 16) : (float)nibble

void moe_up_shared_int4_nmajor_kernel(
    const fp16* x,
    const uint8_t* shared_gate_up_qweight,  // [2*inter, H/2] uint8 implement_zp
    const fp16* shared_gate_up_scale,        // [2*inter, H/GS] fp16 N-major
    fp16* intermediates,                     // [n_tokens, inter] output
    const int n_tokens, const int hidden_size,
    const int shared_inter_size,
    const int num_shared_experts,
    const torch::Device& device) {

    const int two_inter = 2 * shared_inter_size;
    const int K_half = hidden_size / 2;
    const int n_groups = hidden_size / 128;
    // K_packed = K_half / 4 = number of uint32 words per weight row
    // Each uint32 holds 4 bytes = 8 nibbles = 8 K elements
    const int K_packed = K_half / 4;

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeUpSharedInt4NMajor>(
            sycl::range<2>(n_tokens * num_shared_experts, shared_inter_size),
            [=](sycl::id<2> idx) SYCL_ESIMD_KERNEL {
                const int idx0  = (int)idx[0];
                const int token = idx0 / num_shared_experts;
                const int sid   = idx0 % num_shared_experts;
                const int row   = (int)idx[1];

                const fp16* x_row = x + (size_t)token * hidden_size;

                // Reinterpret uint8 weight rows as uint32 for SIMD load
                const uint32_t* gw_base = reinterpret_cast<const uint32_t*>(
                    shared_gate_up_qweight + (size_t)sid * two_inter * K_half);
                const fp16* gs_base = shared_gate_up_scale
                    + (size_t)sid * two_inter * n_groups;

                const uint32_t* g_row_u32 = gw_base + (size_t)row * K_packed;
                const uint32_t* u_row_u32 = gw_base + (size_t)(shared_inter_size + row) * K_packed;
                const fp16* g_scale_row = gs_base + (size_t)row * n_groups;
                const fp16* u_scale_row = gs_base + (size_t)(shared_inter_size + row) * n_groups;

                float g_acc = 0.f, u_acc = 0.f;
                // Process 8 K elements per iteration (1 uint32 = 4 bytes = 8 nibbles)
                for (int kp = 0; kp < K_packed; kp++) {
                    simd<fp16, 8> x_chunk = block_load<fp16, 8>(x_row + kp * 8);
                    uint32_t g_packed = g_row_u32[kp];
                    uint32_t u_packed = u_row_u32[kp];
                    int gi = kp / 16;  // 16 uint32 words = 128 K elements = 1 group
                    float g_s = (float)g_scale_row[gi];
                    float u_s = (float)u_scale_row[gi];

                    #pragma unroll
                    for (int b = 0; b < 8; b++) {
                        uint32_t g_nib = (g_packed >> (b * 4)) & 0xFu;
                        uint32_t u_nib = (u_packed >> (b * 4)) & 0xFu;
                        float gv = (g_nib >= 8u ? (float)g_nib - 16.f : (float)g_nib) * g_s;
                        float uv = (u_nib >= 8u ? (float)u_nib - 16.f : (float)u_nib) * u_s;
                        float xv = (float)(fp16)x_chunk[b];
                        g_acc += gv * xv;
                        u_acc += uv * xv;
                    }
                }

                float silu_g = g_acc / (1.f + sycl::exp(-g_acc));
                const int out_row = token * num_shared_experts + sid;
                intermediates[(size_t)out_row * shared_inter_size + row] = fp16(silu_g * u_acc);
            });
    };

    submit_kernel(cgf, device, "moe up shared int4 nmajor");
}

void moe_down_shared_int4_nmajor_kernel(
    const fp16* intermediates,               // [n_tokens * num_shared, inter] from up kernel
    const uint8_t* shared_down_qweight,      // [H, I/2] uint8 implement_zp
    const fp16* shared_down_scale,           // [H, I/GS] fp16 N-major
    const float* gate_values,                // [n_tokens * num_shared] sigmoid
    fp16* output,                            // [n_tokens, H]
    const int n_tokens, const int hidden_size,
    const int shared_inter_size,
    const int num_shared_experts,
    const torch::Device& device) {

    const int K_half_down = shared_inter_size / 2;
    const int K_packed_down = K_half_down / 4;  // uint32 words per weight row
    const int n_groups_down = shared_inter_size / 128;

    auto cgf = [&](sycl::handler& cgh) {
        cgh.parallel_for<class MoeDownSharedInt4NMajorStandalone>(
            sycl::range<2>(n_tokens * num_shared_experts, hidden_size),
            [=](sycl::id<2> idx) SYCL_ESIMD_KERNEL {
                const int idx0  = (int)idx[0];
                const int token = idx0 / num_shared_experts;
                const int sid   = idx0 % num_shared_experts;
                const int j     = (int)idx[1];

                const int inter_row = token * num_shared_experts + sid;
                const fp16* hi = intermediates + (size_t)inter_row * shared_inter_size;

                const uint32_t* dw_base = reinterpret_cast<const uint32_t*>(
                    shared_down_qweight + (size_t)sid * hidden_size * K_half_down);
                const fp16* ds_base = shared_down_scale
                    + (size_t)sid * hidden_size * n_groups_down;

                const uint32_t* w_row_u32 = dw_base + (size_t)j * K_packed_down;
                const fp16* s_row = ds_base + (size_t)j * n_groups_down;

                float acc = 0.f;
                for (int kp = 0; kp < K_packed_down; kp++) {
                    simd<fp16, 8> hi_chunk = block_load<fp16, 8>(hi + kp * 8);
                    uint32_t packed = w_row_u32[kp];
                    int gi = kp / 16;
                    float s = (float)s_row[gi];

                    #pragma unroll
                    for (int b = 0; b < 8; b++) {
                        uint32_t nib = (packed >> (b * 4)) & 0xFu;
                        float wv = (nib >= 8u ? (float)nib - 16.f : (float)nib) * s;
                        acc += wv * (float)(fp16)hi_chunk[b];
                    }
                }

                float w = gate_values[idx0];
                if (sid == 0) {
                    output[(size_t)token * hidden_size + j] = fp16(acc * w);
                } else {
                    output[(size_t)token * hidden_size + j] =
                        fp16((float)output[(size_t)token * hidden_size + j] + acc * w);
                }
            });
    };

    submit_kernel(cgf, device, "moe down shared int4 nmajor standalone");
}

torch::Tensor moe_shared_expert_forward_int4_nmajor(
    torch::Tensor x,                         // [n_tokens, H] fp16
    torch::Tensor gate_up_qweight,            // [2*I, H/2] uint8
    torch::Tensor gate_up_scale,              // [2*I, H/GS] fp16
    torch::Tensor down_qweight,               // [H, I/2] uint8
    torch::Tensor down_scale,                 // [H, I/GS] fp16
    torch::Tensor gate_weight) {              // [num_shared, H] fp16

    const int n_tokens = x.size(0);
    const int hidden_size = x.size(1);
    const int num_shared_experts = gate_weight.size(0);
    const int two_inter = gate_up_qweight.size(0);
    const int shared_inter_size = two_inter / 2;

    auto intermediates = torch::empty(
        {n_tokens * num_shared_experts, shared_inter_size},
        x.options());

    moe_up_shared_int4_nmajor_kernel(
        (const fp16*)x.data_ptr(),
        (const uint8_t*)gate_up_qweight.data_ptr(),
        (const fp16*)gate_up_scale.data_ptr(),
        (fp16*)intermediates.data_ptr(),
        n_tokens, hidden_size, shared_inter_size, num_shared_experts,
        x.device());

    auto gate_values = torch::empty(
        {n_tokens * num_shared_experts}, x.options().dtype(torch::kFloat32));

    moe_down_gate_precompute_int4_kernel(
        (const fp16*)x.data_ptr(),
        (const fp16*)gate_weight.data_ptr(),
        gate_values.data_ptr<float>(),
        n_tokens, hidden_size, num_shared_experts,
        x.device());

    auto output = torch::empty({n_tokens, hidden_size}, x.options());

    moe_down_shared_int4_nmajor_kernel(
        (const fp16*)intermediates.data_ptr(),
        (const uint8_t*)down_qweight.data_ptr(),
        (const fp16*)down_scale.data_ptr(),
        gate_values.data_ptr<float>(),
        (fp16*)output.data_ptr(),
        n_tokens, hidden_size, shared_inter_size, num_shared_experts,
        x.device());

    return output;
}

// Registration
// ═══════════════════════════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════════════════════════
// INT4 N-major grouped GEMM (DPAS-based) — standalone for benchmarking
// ═══════════════════════════════════════════════════════════════════════════════
#include "int4_nmajor_gemm.h"

// Standalone INT4 N-major GEMM for benchmarking (no MoE routing, no gather/scatter)
// Computes: output[M, N] = input[M, K] @ dequant(weight[E, N, K]).T
// Simple version: E=1 expert, all tokens go to expert 0
torch::Tensor moe_gemm_int4_nmajor(
    torch::Tensor x,              // [M, K] fp16
    torch::Tensor weight,          // [E, N, K/2] uint8
    torch::Tensor scale,           // [E, N, K/GS] fp16
    torch::Tensor expert_idx,      // [E+1] int32 — cumulative token offsets
    int64_t group_size) {

    const int M = x.size(0);
    const int K = x.size(1);
    const int E = weight.size(0);
    const int N = weight.size(1);
    const int K_packed = K / 8;
    const int K_groups = K / (int)group_size;

    auto output = torch::zeros({M, N}, x.options());

    sycl::queue& q = c10::xpu::getCurrentXPUStream(x.device().index()).queue();

    // View uint8 as int32
    auto w_int32 = weight.view(torch::kInt32).reshape({E, N, K_packed});

    // Simple grouped GEMM: each WI handles one expert × N_TILE=16 N outputs
    // M loop over MAX_M=32 chunks, DPAS<8,8> inside
    constexpr int N_TILE = 16;
    constexpr int MAX_M = 32;
    constexpr int BS = 128;

    q.submit([&](sycl::handler& cgh) {
        const fp16* inp = (const fp16*)x.data_ptr();
        const uint32_t* wt = (const uint32_t*)w_int32.data_ptr();
        const fp16* sc = (const fp16*)scale.data_ptr();
        fp16* out = (fp16*)output.data_ptr();
        const int* eidx = (const int*)expert_idx.data_ptr();

        cgh.parallel_for(
            sycl::range<2>(E, N / N_TILE),
            [=](sycl::id<2> id) SYCL_ESIMD_KERNEL {
                constexpr int MS = MAX_M / 16;
                constexpr int NS = N_TILE / 8;
                constexpr int ACC_SZ = MS * NS * 128;
                constexpr int KP_PER_GROUP = BS / 8;

                const int eid = (int)id[0];
                const int tid = (int)id[1];
                const int n_start = tid * N_TILE;

                const int t0 = eidx[eid];
                const int t1 = eidx[eid + 1];
                if (t0 >= t1) return;

                const uint32_t* w_base = wt + (size_t)eid * N * K_packed;
                const fp16* s_base = sc + (size_t)eid * N * K_groups;

                for (int m_base = t0; m_base < t1; m_base += MAX_M) {
                    int m_end = m_base + MAX_M;
                    if (m_end > t1) m_end = t1;
                    int m_count = m_end - m_base;

                    simd<fp16, ACC_SZ> acc(fp16(0));

                    for (int kg = 0; kg < K_groups; kg++) {
                        // Load scale once per group for N_TILE rows
                        simd<fp16, N_TILE> scl;
                        #pragma unroll
                        for (int ni = 0; ni < N_TILE; ni++) {
                            scl[ni] = s_base[(n_start + ni) * K_groups + kg];
                        }

                        for (int kp_off = 0; kp_off < KP_PER_GROUP; kp_off += 2) {
                            const int kp_start = kg * KP_PER_GROUP + kp_off;

                            // b_tile: load input [MS*16, 16K] using gather (same as prefill)
                            // Each of 16 M rows loads 8 uint32 = 16 fp16 K elements
                            simd<fp16, MS * 256> b_tile;
                            const uint32_t k_byte_off = (uint32_t)(kp_start * 8) * (uint32_t)sizeof(fp16);
                            #pragma unroll
                            for (int ms = 0; ms < MS; ms++) {
                                // Build byte offsets for 16 M rows
                                simd<uint32_t, 16> row_offs;
                                #pragma unroll
                                for (int mi = 0; mi < 16; mi++) {
                                    int row = m_base + ms * 16 + mi;
                                    row_offs[mi] = (row < t1)
                                        ? (uint32_t)row * (uint32_t)(K * sizeof(fp16))
                                        : (uint32_t)(t1 - 1) * (uint32_t)(K * sizeof(fp16));
                                }
                                simd<fp16, 256> btmp;
                                btmp.template bit_cast_view<uint32_t>() =
                                    xesimd::lsc_gather<uint32_t, 8,
                                        xesimd::lsc_data_size::u32,
                                        xesimd::cache_hint::cached, xesimd::cache_hint::cached,
                                        16, uint32_t>(
                                        reinterpret_cast<const uint32_t*>(inp),
                                        row_offs + k_byte_off);
                                b_tile.template select<256, 1>(ms * 256) = btmp;
                            }

                            // a_tile: weight dequant from N-major [N, K_packed] int32
                            // Use lsc_gather to batch-load 8 N-rows at once
                            #pragma unroll
                            for (int ns = 0; ns < NS; ns++) {
                                // Gather 8 int32 from 8 different N-rows at kp_start
                                simd<uint32_t, 8> w0_off, w1_off;
                                #pragma unroll
                                for (int r = 0; r < 8; r++) {
                                    w0_off[r] = (uint32_t)((size_t)(n_start + ns * 8 + r) * K_packed + kp_start) * 4u;
                                    w1_off[r] = (uint32_t)((size_t)(n_start + ns * 8 + r) * K_packed + kp_start + 1) * 4u;
                                }
                                simd<uint32_t, 8> w0_gathered =
                                    xesimd::lsc_gather<uint32_t, 1,
                                        xesimd::lsc_data_size::u32,
                                        xesimd::cache_hint::cached, xesimd::cache_hint::cached,
                                        8, uint32_t>(
                                        reinterpret_cast<const uint32_t*>(w_base), w0_off);
                                simd<uint32_t, 8> w1_gathered =
                                    xesimd::lsc_gather<uint32_t, 1,
                                        xesimd::lsc_data_size::u32,
                                        xesimd::cache_hint::cached, xesimd::cache_hint::cached,
                                        8, uint32_t>(
                                        reinterpret_cast<const uint32_t*>(w_base), w1_off);

                                simd<fp16, 128> a_tile;
                                #pragma unroll
                                for (int r = 0; r < 8; r++) {
                                    const uint32_t w0r = w0_gathered[r];
                                    const uint32_t w1r = w1_gathered[r];
                                    const fp16 s = scl[ns * 8 + r];
                                    simd<fp16, 16> row;
                                    #pragma unroll
                                    for (int k = 0; k < 8; k++) {
                                        uint32_t n0 = (w0r >> (k * 4)) & 0xFu;
                                        uint32_t n1 = (w1r >> (k * 4)) & 0xFu;
                                        row[k]     = fp16((int)(n0 >= 8u ? n0 - 16u : n0));
                                        row[8 + k] = fp16((int)(n1 >= 8u ? n1 - 16u : n1));
                                    }
                                    row *= s;
                                    a_tile.template select<16, 1>(r * 16) = row;
                                }

                                #pragma unroll
                                for (int ms = 0; ms < MS; ms++) {
                                    const int idx = ms * NS * 128 + ns * 128;
                                    simd<fp16, 128> a = acc.template select<128, 1>(idx);
                                    simd<fp16, 256> bv = b_tile.template select<256, 1>(ms * 256);
                                    a = xmx_ns::dpas<8, 8, fp16, fp16, fp16, fp16>(a, bv, a_tile);
                                    acc.template select<128, 1>(idx) = a;
                                }
                            }
                        }
                    }

                    // Store output using scatter (16 M-rows per scatter)
                    // acc layout: acc[ms*NS*128 + ns*128 + n_local*16 + m_local]
                    #pragma unroll
                    for (int ms = 0; ms < MS; ms++) {
                        // Build byte offsets for 16 M rows
                        simd<uint32_t, 16> store_offs;
                        #pragma unroll
                        for (int mi = 0; mi < 16; mi++) {
                            int row = m_base + ms * 16 + mi;
                            store_offs[mi] = (row < t1)
                                ? (uint32_t)((size_t)row * N) * (uint32_t)sizeof(fp16)
                                : (uint32_t)((size_t)(t1 - 1) * N) * (uint32_t)sizeof(fp16);
                        }
                        #pragma unroll
                        for (int r = 0; r < N_TILE; r++) {
                            int ns_local = r / 8;
                            int n_local  = r % 8;
                            const int idx = ms * NS * 128 + ns_local * 128 + n_local * 16;
                            simd<fp16, 16> val = acc.template select<16, 1>(idx);
                            uint32_t col_off = (uint32_t)(n_start + r) * (uint32_t)sizeof(fp16);
                            scatter<fp16, 16>(out, store_offs + col_off, val);
                        }
                    }
                }
            });
    });

    return output;
}


TORCH_LIBRARY_FRAGMENT(moe_int4_ops, m) {
    m.def("moe_router_forward_int4(Tensor x, Tensor weight, Tensor scale, bool use_ggml_layout) -> Tensor");
    m.def("moe_route_precompute_int4(Tensor topk_weight, Tensor topk_idx, int num_experts) -> (Tensor, Tensor, Tensor)");
    m.def("moe_silu_mul_int4(Tensor gate_up) -> Tensor");
    m.def("moe_route_gather_int4(Tensor route_output, Tensor sorted_rows, Tensor sorted_weights, int n_tokens) -> Tensor");
        m.def("moe_forward_tiny_cutlass_nmajor_int4(Tensor x, Tensor w13_qweight_s4, Tensor w13_scales, "
            "Tensor w2_qweight_s4, Tensor w2_scales, Tensor topk_weight, Tensor topk_idx) -> Tensor");
        m.def("moe_tiny_cutlass_nmajor_int4_up(Tensor x, Tensor w13_qweight_s4, Tensor w13_scales, Tensor topk_idx) -> Tensor");
        m.def("moe_tiny_cutlass_nmajor_int4_down(Tensor intermediates, Tensor w2_qweight_s4, Tensor w2_scales, "
                    "Tensor topk_weight, Tensor topk_idx) -> Tensor");
            m.def("moe_forward_tiny_cutlass_nmajor_int4_full_fp16_shared(Tensor x, Tensor w13_qweight_s4, Tensor w13_scales, "
                "Tensor w2_qweight_s4, Tensor w2_scales, Tensor topk_weight, Tensor topk_idx, "
                "Tensor shared_gate_up_weight, Tensor shared_down_weight, Tensor shared_expert_gate_weight, "
                "int num_shared_experts) -> Tensor");
                m.def("moe_tiny_fp16_shared_up(Tensor x, Tensor shared_gate_up_weight, int num_shared_experts) -> Tensor");
                m.def("moe_tiny_fp16_shared_finalize(Tensor x, Tensor shared_intermediates, Tensor routed_output, "
                    "Tensor shared_down_weight, Tensor shared_expert_gate_weight, int num_shared_experts) -> Tensor");
    m.def("moe_forward_full_int4(Tensor x, Tensor logits, "
          "Tensor gate_up_qweight, Tensor gate_up_scales, "
          "Tensor shared_gate_up_weight, Tensor shared_gate_up_scale, "
          "Tensor down_qweight, Tensor down_scales, "
          "Tensor shared_down_weight, Tensor shared_down_scale, "
          "Tensor shared_expert_gate_weight, "
          "int top_k, int num_shared_experts, int n_routed_experts, "
          "bool use_ggml_layout) -> Tensor");
    m.def("moe_shared_expert_forward_int4_nmajor(Tensor x, "
          "Tensor gate_up_qweight, Tensor gate_up_scale, "
          "Tensor down_qweight, Tensor down_scale, "
          "Tensor gate_weight) -> Tensor");
    m.def("moe_gemm_int4_nmajor(Tensor x, Tensor weight, Tensor scale, "
          "Tensor expert_idx, int group_size) -> Tensor");
}

TORCH_LIBRARY_IMPL(moe_int4_ops, XPU, m) {
    m.impl("moe_router_forward_int4", &moe_router_forward_int4);
    m.impl("moe_route_precompute_int4", &moe_route_precompute_int4);
    m.impl("moe_silu_mul_int4", &moe_silu_mul_int4);
    m.impl("moe_route_gather_int4", &moe_route_gather_int4);
    m.impl("moe_forward_tiny_cutlass_nmajor_int4", &moe_forward_tiny_cutlass_nmajor_int4);
    m.impl("moe_tiny_cutlass_nmajor_int4_up", &moe_tiny_cutlass_nmajor_int4_up);
    m.impl("moe_tiny_cutlass_nmajor_int4_down", &moe_tiny_cutlass_nmajor_int4_down);
    m.impl("moe_forward_tiny_cutlass_nmajor_int4_full_fp16_shared", &moe_forward_tiny_cutlass_nmajor_int4_full_fp16_shared);
    m.impl("moe_tiny_fp16_shared_up", &moe_tiny_fp16_shared_up);
    m.impl("moe_tiny_fp16_shared_finalize", &moe_tiny_fp16_shared_finalize);
    m.impl("moe_forward_full_int4", &moe_forward_full_int4);
    m.impl("moe_shared_expert_forward_int4_nmajor", &moe_shared_expert_forward_int4_nmajor);
    m.impl("moe_gemm_int4_nmajor", &moe_gemm_int4_nmajor);
}

PYBIND11_MODULE(TORCH_EXTENSION_NAME, m) {
    m.def("moe_router_forward_int4", &moe_router_forward_int4);
    m.def("moe_route_precompute_int4", &moe_route_precompute_int4);
    m.def("moe_silu_mul_int4", &moe_silu_mul_int4);
    m.def("moe_route_gather_int4", &moe_route_gather_int4);
    m.def("moe_forward_tiny_cutlass_nmajor_int4", &moe_forward_tiny_cutlass_nmajor_int4);
    m.def("moe_tiny_cutlass_nmajor_int4_up", &moe_tiny_cutlass_nmajor_int4_up);
    m.def("moe_tiny_cutlass_nmajor_int4_down", &moe_tiny_cutlass_nmajor_int4_down);
    m.def("moe_forward_tiny_cutlass_nmajor_int4_full_fp16_shared", &moe_forward_tiny_cutlass_nmajor_int4_full_fp16_shared);
    m.def("moe_tiny_fp16_shared_up", &moe_tiny_fp16_shared_up);
    m.def("moe_tiny_fp16_shared_finalize", &moe_tiny_fp16_shared_finalize);
    m.def("moe_forward_full_int4", &moe_forward_full_int4);
    m.def("moe_shared_expert_forward_int4_nmajor", &moe_shared_expert_forward_int4_nmajor);
    m.def("moe_gemm_int4_nmajor", &moe_gemm_int4_nmajor);
}
